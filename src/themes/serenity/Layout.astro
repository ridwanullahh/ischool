---
import '../../styles/global.css';
import LanguageSelector from '../../components/LanguageSelector.astro';
import SchoolBannerPopup from '../../components/SchoolBannerPopup.astro';
import PublicAIChatWidget from '../../components/PublicAIChatWidget.astro';
import { getSchoolNav, getSchoolContacts, getSchoolPalette } from '../../lib/school.ts';
import { normalizeSocialUrl, getSocialIcon } from '../../lib/social.ts';

interface Props { school: any; title?: string; }
const { school, title } = Astro.props;
const nav = getSchoolNav(school.id);
const contacts = getSchoolContacts(school.id);
const palette = getSchoolPalette(school);
const pageTitle = title ? `${title} — ${school.name}` : school.name;
const prefix = `/${school.slug}`;
const { pathname } = Astro.url;
const social = (school.socialHandles as Record<string, string>) || {};
const socialEntries = Object.entries(social).filter(([, v]) => v && v !== '#');
---
<!doctype html>
<html lang={school.locale || 'en'} dir={['ar','he','fa','ur'].includes(school.locale || 'en') ? 'rtl' : 'ltr'} class="light scroll-smooth">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="description" content={school.tagline || school.name} />
  {school.faviconUrl && <link rel="icon" href={school.faviconUrl} />}
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <title>{pageTitle}</title>
  <script is:inline>
    (function(){var s=localStorage.getItem('themeMode');var d=window.matchMedia('(prefers-color-scheme:dark)').matches;var dk=s==='dark'||(!s&&d);document.documentElement.classList.remove('light','dark');document.documentElement.classList.add(dk?'dark':'light')})();
  </script>
  <style is:inline>{`
    html.light{--bg:${palette.backgroundLight};--surface:${palette.surfaceLight};--text:${palette.textLight};--muted:${palette.mutedLight};--border:${palette.borderLight};--accent:${palette.accent};--primary:${palette.primary}}
    html.dark{--bg:${palette.backgroundDark};--surface:${palette.surfaceDark};--text:${palette.textDark};--muted:${palette.mutedDark};--border:${palette.borderDark};--accent:${palette.accent};--primary:${palette.primary}}
    :root{--tp:${palette.primary}}.tp{color:var(--tp)}
    .zen-serif{font-family:'Noto Serif JP',Georgia,serif}
    .zen-sans{font-family:'Inter',sans-serif}
    .zen-divider{width:40px;height:1px;background:var(--primary);margin:1.5rem auto}
  `}</style>
</head>
<body class="min-h-screen zen-sans" style="background:var(--bg);color:var(--text)">
  <header class="z-50" style="border-bottom:1px solid var(--border)">
    <div class="max-w-5xl mx-auto px-6 sm:px-8">
      <div class="flex items-center justify-center py-6">
        <a href={`${prefix}/`} class="text-center">
          {school.logoUrl ? <img src={school.logoUrl} alt={school.name} class="h-10 mx-auto mb-2" /> : null}
          <h1 class="zen-serif text-2xl font-light tracking-wide" style="color:var(--text)">{school.name}</h1>
          {school.tagline && <p class="text-[11px] tracking-[0.3em] uppercase mt-1" style="color:var(--muted)">{school.tagline}</p>}
        </a>
      </div>
      <nav class="hidden lg:flex items-center justify-center gap-10 pb-4">
        {nav.map(item => (
          <a href={`${prefix}${item.url}`} class:list={[
            'text-[13px] tracking-wide transition-colors relative py-1',
            pathname === `${prefix}${item.url}` ? 'tp font-medium' : ''
          ]} style={pathname === `${prefix}${item.url}` ? '' : `color:var(--muted)`}>
            {item.label}
            {pathname === `${prefix}${item.url}` && <span class="absolute -bottom-0.5 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full" style="background:var(--primary)"></span>}
          </a>
        ))}
      </nav>
      <div class="flex lg:hidden items-center justify-between py-3" style="border-top:1px solid var(--border)">
        <button id="mob-tog" class="p-2" style="color:var(--muted)"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg></button>
        <LanguageSelector />
          <button id="theme-toggle" class="p-2" style="color:var(--muted)" aria-label="Toggle dark mode">
          <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        </button>
      </div>
    </div>
    <div id="mob-menu" class="hidden lg:hidden" style="border-top:1px solid var(--border);background:var(--surface)">
      <div class="px-6 py-6 space-y-4 max-w-5xl mx-auto">
        {nav.map(item => (
          <a href={`${prefix}${item.url}`} class:list={['block text-sm tracking-wide', pathname === `${prefix}${item.url}` ? 'tp font-medium' : '']} style={pathname === `${prefix}${item.url}` ? '' : `color:var(--muted)`}>{item.label}</a>
        ))}
      </div>
    </div>
  </header>
  <main><slot /></main>
  <footer style="border-top:1px solid var(--border)">
    <div class="max-w-5xl mx-auto px-6 sm:px-8 py-20 text-center">
      <h2 class="zen-serif text-xl font-light mb-2" style="color:var(--text)">{school.name}</h2>
      {school.tagline && <p class="text-xs tracking-[0.2em] uppercase" style="color:var(--muted)">{school.tagline}</p>}
      <div class="zen-divider"></div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-left mt-10">
        <div>
          <h4 class="text-[10px] tracking-[0.3em] uppercase mb-4 font-medium" style="color:var(--muted)">Navigation</h4>
          <ul class="space-y-2">{nav.slice(0,6).map(item => <li><a href={`${prefix}${item.url}`} class="text-sm hover:opacity-70 transition-opacity" style="color:var(--muted)">{item.label}</a></li>)}</ul>
        </div>
        <div>
          <h4 class="text-[10px] tracking-[0.3em] uppercase mb-4 font-medium" style="color:var(--muted)">Contact</h4>
          <ul class="space-y-2">{contacts.slice(0,4).map(c => <li class="text-sm" style="color:var(--muted)">{c.value}</li>)}</ul>
        </div>
        <div>
          <h4 class="text-[10px] tracking-[0.3em] uppercase mb-4 font-medium" style="color:var(--muted)">Connect</h4>
          {socialEntries.length > 0 && (
            <div class="flex items-center gap-4">
              {socialEntries.map(([platform, handle]) => (
                <a href={normalizeSocialUrl(handle, platform)} aria-label={platform} target="_blank" rel="noopener" class="hover:opacity-70 transition-opacity" style="color:var(--muted)">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d={getSocialIcon(platform)}/></svg>
                </a>
              ))}
            </div>
          )}
          <a href={`${prefix}/admissions`} class="inline-block mt-6 text-xs tracking-widest uppercase font-medium tp" style="border-bottom:1px solid var(--primary);padding-bottom:2px">Apply</a>
        </div>
      </div>
      <div class="mt-16 pt-8" style="border-top:1px solid var(--border)">
        <p class="text-[10px] tracking-[0.3em] uppercase" style="color:var(--muted)">&copy; {new Date().getFullYear()} {school.name}</p>
      </div>
      <button id="theme-toggle-d" class="lg:hidden mt-4 p-2" style="color:var(--muted)" aria-label="Toggle dark mode">
        <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
      </button>
    </div>
  </footer>
  <script>
    document.getElementById('mob-tog')?.addEventListener('click',()=>document.getElementById('mob-menu')?.classList.toggle('hidden'));
    const toggleTheme=()=>{const h=document.documentElement;const d=h.classList.contains('dark');h.classList.remove('light','dark');h.classList.add(d?'light':'dark');localStorage.setItem('themeMode',d?'light':'dark')};
    document.getElementById('theme-toggle')?.addEventListener('click',toggleTheme);
    document.getElementById('theme-toggle-d')?.addEventListener('click',toggleTheme);
  </script>
    <SchoolBannerPopup schoolId={school.id} />
  <PublicAIChatWidget schoolSlug={school.slug} />
</body>
</html>
