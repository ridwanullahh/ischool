---
import '../../styles/global.css';
import LanguageSelector from '../../components/LanguageSelector.astro';
import SchoolBannerPopup from '../../components/SchoolBannerPopup.astro';
import PublicAIChatWidget from '../../components/PublicAIChatWidget.astro';
import { getSchoolNav, getSchoolContacts, getSchoolPalette } from '../../lib/school.ts';
import { normalizeSocialUrl, getSocialIcon } from '../../lib/social.ts';

interface Props { school: any; title?: string; }
const { school, title } = Astro.props;
const nav = getSchoolNav(school.id);
const contacts = getSchoolContacts(school.id);
const palette = getSchoolPalette(school);
const pageTitle = title ? `${title} — ${school.name}` : school.name;
const prefix = `/${school.slug}`;
const { pathname } = Astro.url;
const social = (school.socialHandles as Record<string, string>) || {};
const socialEntries = Object.entries(social).filter(([, v]) => v && v !== '#');
---
<!doctype html>
<html lang={school.locale || 'en'} dir={['ar','he','fa','ur'].includes(school.locale || 'en') ? 'rtl' : 'ltr'} class="light scroll-smooth">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="description" content={school.tagline || school.name} />
  {school.faviconUrl && <link rel="icon" href={school.faviconUrl} />}
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet" />
  <title>{pageTitle}</title>
  <script is:inline>
    (function(){var s=localStorage.getItem('themeMode');var d=window.matchMedia('(prefers-color-scheme:dark)').matches;var dk=s==='dark'||(!s&&d);document.documentElement.classList.remove('light','dark');document.documentElement.classList.add(dk?'dark':'light')})();
  </script>
  <style is:inline>{`
    html.light{--bg:${palette.backgroundLight};--surface:${palette.surfaceLight};--text:${palette.textLight};--muted:${palette.mutedLight};--border:${palette.borderLight};--accent:${palette.accent};--primary:${palette.primary}}
    html.dark{--bg:${palette.backgroundDark};--surface:${palette.surfaceDark};--text:${palette.textDark};--muted:${palette.mutedDark};--border:${palette.borderDark};--accent:${palette.accent};--primary:${palette.primary}}
    :root{--tp:${palette.primary}}.tp{color:var(--tp)}.tbg{background:var(--tp)}
    .ht-serif{font-family:'Crimson Text',Georgia,serif}
    .ht-sans{font-family:'Lato',sans-serif}
    .ht-ornament{display:flex;align-items:center;gap:12px;color:var(--primary)}
    .ht-ornament::before,.ht-ornament::after{content:'';flex:1;height:1px;background:linear-gradient(to right,transparent,var(--primary),transparent)}
  `}</style>
</head>
<body class="min-h-screen ht-sans" style="background:var(--bg);color:var(--text)">
  <div style="height:4px;background:linear-gradient(to right,var(--primary),var(--accent),var(--primary))"></div>
  <header class="sticky top-0 z-50" style="background:var(--surface);border-bottom:2px solid var(--border)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between py-2 text-[11px]" style="color:var(--muted);border-bottom:1px solid var(--border)">
        <span>{contacts.find(c=>c.label==='Phone')?.value || ''}</span>
        <span>{contacts.find(c=>c.label==='Email')?.value || ''}</span>
      </div>
      <div class="flex items-center justify-between py-5">
        <a href={`${prefix}/`} class="flex items-center gap-4">
          {school.logoUrl ? <img src={school.logoUrl} alt={school.name} class="h-14 w-auto" /> : (
            <div class="w-14 h-14 rounded-full border-2 flex items-center justify-center ht-serif text-2xl font-bold" style="border-color:var(--primary);color:var(--primary)">{school.name.charAt(0)}</div>
          )}
          <div>
            <span class="text-2xl font-bold ht-serif block" style="color:var(--text)">{school.name}</span>
            {school.tagline && <span class="text-xs italic" style="color:var(--muted)">{school.tagline}</span>}
          </div>
        </a>
        <div class="flex items-center gap-3">
          <LanguageSelector />
          <button id="theme-toggle" class="p-2 rounded" style="color:var(--muted)" aria-label="Toggle dark mode">
            <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
          </button>
          <a href={`${prefix}/admissions`} class="hidden lg:inline-block px-6 py-2.5 text-sm font-bold text-white rounded ht-serif tracking-wide tbg">Admissions</a>
          <button id="mob-tog" class="lg:hidden p-2" style="color:var(--primary)"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg></button>
        </div>
      </div>
      <nav class="hidden lg:flex items-center justify-center gap-1 py-3" style="border-top:1px solid var(--border)">
        {nav.map(item => (
          <a href={`${prefix}${item.url}`} class:list={[
            'px-5 py-2 text-[13px] font-bold uppercase tracking-wider transition-colors ht-serif',
            pathname === `${prefix}${item.url}` ? 'tp' : ''
          ]} style={pathname === `${prefix}${item.url}` ? `border-bottom:2px solid var(--primary)` : `color:var(--muted);border-bottom:2px solid transparent`}>{item.label}</a>
        ))}
      </nav>
    </div>
    <div id="mob-menu" class="hidden lg:hidden" style="border-top:2px solid var(--border);background:var(--surface)">
      <div class="px-4 py-4 space-y-1">
        {nav.map(item => (
          <a href={`${prefix}${item.url}`} class:list={['block px-4 py-3 text-sm font-bold uppercase tracking-wider ht-serif rounded', pathname === `${prefix}${item.url}` ? 'tp' : '']} style={pathname === `${prefix}${item.url}` ? `background:color-mix(in srgb, var(--primary) 10%, transparent)` : `color:var(--muted)`}>{item.label}</a>
        ))}
      </div>
    </div>
  </header>
  <main><slot /></main>
  <footer style="background:var(--surface);border-top:4px double var(--primary)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="text-center mb-10">
        <div class="ht-ornament ht-serif text-lg font-bold">{school.name}</div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div>
          <h4 class="ht-serif text-sm font-bold uppercase tracking-widest mb-4 tp">Navigation</h4>
          <ul class="space-y-2">{nav.slice(0,7).map(item => <li><a href={`${prefix}${item.url}`} class="text-sm hover:opacity-80 transition-colors" style="color:var(--muted)">{item.label}</a></li>)}</ul>
        </div>
        <div>
          <h4 class="ht-serif text-sm font-bold uppercase tracking-widest mb-4 tp">Contact</h4>
          <ul class="space-y-2">{contacts.slice(0,5).map(c => <li class="text-sm" style="color:var(--muted)"><strong>{c.label}:</strong> {c.value}</li>)}</ul>
        </div>
        <div>
          <h4 class="ht-serif text-sm font-bold uppercase tracking-widest mb-4 tp">Follow Us</h4>
          {socialEntries.length > 0 && (
            <div class="flex flex-wrap items-center gap-3">
              {socialEntries.map(([platform, handle]) => (
                <a href={normalizeSocialUrl(handle, platform)} aria-label={platform} target="_blank" rel="noopener" class="w-10 h-10 rounded-full border-2 flex items-center justify-center transition-all hover:opacity-80" style="border-color:var(--primary);color:var(--primary)">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d={getSocialIcon(platform)}/></svg>
                </a>
              ))}
            </div>
          )}
          <a href={`${prefix}/admissions`} class="inline-block mt-6 px-6 py-2.5 text-sm font-bold text-white rounded ht-serif tbg">Apply Now</a>
        </div>
      </div>
      <div class="mt-12 pt-8 text-center text-xs" style="border-top:2px solid var(--border);color:var(--muted)">
        &copy; {new Date().getFullYear()} {school.name} — Powered by <a href="/" class="tp hover:opacity-80">iSchool</a>
      </div>
    </div>
  </footer>
  <script>
    document.getElementById('mob-tog')?.addEventListener('click',()=>document.getElementById('mob-menu')?.classList.toggle('hidden'));
    document.getElementById('theme-toggle')?.addEventListener('click',()=>{const h=document.documentElement;const d=h.classList.contains('dark');h.classList.remove('light','dark');h.classList.add(d?'light':'dark');localStorage.setItem('themeMode',d?'light':'dark')});
  </script>
    <SchoolBannerPopup schoolId={school.id} />
  <PublicAIChatWidget schoolSlug={school.slug} />
</body>
</html>
