---
import '../../styles/global.css';
import LanguageSelector from '../../components/LanguageSelector.astro';
import SchoolBannerPopup from '../../components/SchoolBannerPopup.astro';
import PublicAIChatWidget from '../../components/PublicAIChatWidget.astro';
import { getSchoolNav, getSchoolContacts, getSchoolPalette } from '../../lib/school.ts';
import { normalizeSocialUrl, getSocialIcon } from '../../lib/social.ts';

interface Props { school: any; title?: string; }
const { school, title } = Astro.props;
const nav = getSchoolNav(school.id);
const contacts = getSchoolContacts(school.id);
const palette = getSchoolPalette(school);
const pageTitle = title ? `${title} — ${school.name}` : school.name;
const prefix = `/${school.slug}`;
const { pathname } = Astro.url;
const social = (school.socialHandles as Record<string, string>) || {};
const socialEntries = Object.entries(social).filter(([, v]) => v && v !== '#');
---
<!doctype html>
<html lang={school.locale || 'en'} dir={['ar','he','fa','ur'].includes(school.locale || 'en') ? 'rtl' : 'ltr'} class="light scroll-smooth">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="description" content={school.tagline || school.name} />
  {school.faviconUrl && <link rel="icon" href={school.faviconUrl} />}
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <title>{pageTitle}</title>
  <script is:inline>
    (function(){var s=localStorage.getItem('themeMode');var d=window.matchMedia('(prefers-color-scheme:dark)').matches;var dk=s==='dark'||(!s&&d);document.documentElement.classList.remove('light','dark');document.documentElement.classList.add(dk?'dark':'light')})();
  </script>
  <style is:inline>{`
    html.light{--bg:${palette.backgroundLight};--surface:${palette.surfaceLight};--text:${palette.textLight};--muted:${palette.mutedLight};--border:${palette.borderLight};--accent:${palette.accent};--primary:${palette.primary}}
    html.dark{--bg:${palette.backgroundDark};--surface:${palette.surfaceDark};--text:${palette.textDark};--muted:${palette.mutedDark};--border:${palette.borderDark};--accent:${palette.accent};--primary:${palette.primary}}
    :root{--tp:${palette.primary};--gold:linear-gradient(135deg,#b8860b,#daa520,#f0c040,#daa520,#b8860b)}
    .luxe-gold{background:var(--gold)}
    .luxe-gold-text{background:var(--gold);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .luxe-border{border:1px solid;color:var(--border)}
    .luxe-shadow{box-shadow:0 4px 30px rgba(0,0,0,.08)}
    @keyframes shimmer{0%{background-position:-200% center}100%{background-position:200% center}}
    .luxe-shimmer{background:var(--gold);background-size:200% auto;animation:shimmer 4s linear infinite}
  `}</style>
</head>
<body class="min-h-screen font-[Inter,sans-serif]" style="background:var(--bg);color:var(--text)">
  <div class="luxe-shimmer h-1 fixed top-0 left-0 right-0 z-[60]"></div>
  <header class="sticky top-1 z-50" style="background:color-mix(in srgb, var(--bg) 92%, transparent);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid var(--border)">
    <nav class="max-w-7xl mx-auto px-6 lg:px-8 h-24 flex items-center justify-between">
      <a href={`${prefix}/`} class="flex items-center gap-4 group">
        {school.logoUrl ? <img src={school.logoUrl} alt={school.name} class="h-14 w-auto" /> : (
          <div class="w-14 h-14 luxe-gold flex items-center justify-center text-white font-[Playfair_Display] font-bold text-2xl shadow-lg">{school.name.charAt(0)}</div>
        )}
        <div class="flex flex-col">
          <span class="text-xl font-[Playfair_Display] font-bold tracking-wide" style="color:var(--text)">{school.name}</span>
          {school.tagline && <span class="text-[10px] uppercase tracking-[.25em] font-medium" style="color:var(--muted)">{school.tagline}</span>}
        </div>
      </a>
      <div class="hidden xl:flex items-center gap-0.5">
        {nav.map(item => (
          <a href={`${prefix}${item.url}`} class:list={[
            'relative px-5 py-2 text-[13px] font-medium uppercase tracking-wider transition-all',
            pathname === `${prefix}${item.url}` ? 'luxe-gold-text' : ''
          ]} style={pathname === `${prefix}${item.url}` ? '' : `color:var(--muted)`}>{item.label}</a>
        ))}
      </div>
      <div class="flex items-center gap-4">
        <LanguageSelector />
        <button id="theme-toggle" class="p-2 transition-all" style="color:var(--muted)" aria-label="Toggle dark mode">
          <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        </button>
        <a href={`${prefix}/admissions`} class="hidden xl:inline-flex items-center px-8 py-3 text-[13px] font-semibold uppercase tracking-widest text-white luxe-gold hover:shadow-xl transition-all">Enroll</a>
        <button id="mob-tog" class="xl:hidden p-2" style="color:var(--muted)"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg></button>
      </div>
    </nav>
    <div id="mob-menu" class="hidden xl:hidden" style="background:var(--surface);border-top:1px solid var(--border)">
      <div class="px-6 py-6 space-y-1">
        {nav.map(item => (
          <a href={`${prefix}${item.url}`} class:list={['block px-5 py-3 text-sm font-medium uppercase tracking-wider', pathname === `${prefix}${item.url}` ? 'luxe-gold-text' : '']} style={pathname === `${prefix}${item.url}` ? '' : `color:var(--muted)`}>{item.label}</a>
        ))}
      </div>
    </div>
  </header>
  <main><slot /></main>
  <footer style="background:var(--surface);border-top:1px solid var(--border)">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
        <div class="md:col-span-5">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 luxe-gold flex items-center justify-center text-white font-[Playfair_Display] font-bold text-xl">{school.name.charAt(0)}</div>
            <span class="text-2xl font-[Playfair_Display] font-bold" style="color:var(--text)">{school.name}</span>
          </div>
          {school.tagline && <p class="text-sm leading-relaxed max-w-md font-light" style="color:var(--muted)">{school.tagline}</p>}
        </div>
        <div class="md:col-span-3">
          <h4 class="text-[11px] font-semibold uppercase tracking-[.2em] mb-6" style="color:var(--text)">Navigate</h4>
          <ul class="space-y-3">{nav.slice(0,7).map(item => <li><a href={`${prefix}${item.url}`} class="text-sm font-light hover:opacity-80 transition-colors" style="color:var(--muted)">{item.label}</a></li>)}</ul>
        </div>
        <div class="md:col-span-4">
          <h4 class="text-[11px] font-semibold uppercase tracking-[.2em] mb-6" style="color:var(--text)">Contact</h4>
          <ul class="space-y-3">{contacts.slice(0,5).map(c => <li class="text-sm font-light" style="color:var(--muted)">{c.label}: {c.value}</li>)}</ul>
          {socialEntries.length > 0 && (
            <div class="flex items-center gap-3 mt-6 pt-6" style="border-top:1px solid var(--border)">
              {socialEntries.map(([platform, handle]) => (
                <a href={normalizeSocialUrl(handle, platform)} aria-label={platform} target="_blank" rel="noopener" class="w-10 h-10 flex items-center justify-center transition-all hover:opacity-80 luxe-border">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" style="color:var(--primary)"><path d={getSocialIcon(platform)}/></svg>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
      <div class="mt-16 pt-8 text-center text-xs font-light" style="border-top:1px solid var(--border);color:var(--muted)">
        &copy; {new Date().getFullYear()} {school.name} — Powered by <a href="/" class="hover:opacity-80">iSchool</a>
      </div>
    </div>
  </footer>
  <script>
    document.getElementById('mob-tog')?.addEventListener('click',()=>document.getElementById('mob-menu')?.classList.toggle('hidden'));
    document.getElementById('theme-toggle')?.addEventListener('click',()=>{const h=document.documentElement;const d=h.classList.contains('dark');h.classList.remove('light','dark');h.classList.add(d?'light':'dark');localStorage.setItem('themeMode',d?'light':'dark')});
  </script>
  <SchoolBannerPopup schoolId={school.id} />
  <PublicAIChatWidget schoolSlug={school.slug} />
</body>
</html>
