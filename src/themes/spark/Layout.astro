---
import { getSchoolNav, getSchoolContacts, getSchoolPalette } from '../../lib/school.ts';
import { normalizeSocialUrl, getSocialIcon } from '../../lib/social.ts';
import LanguageSelector from '../../components/LanguageSelector.astro';
import SchoolBannerPopup from '../../components/SchoolBannerPopup.astro';
import PublicAIChatWidget from '../../components/PublicAIChatWidget.astro';

interface Props { school: any; title?: string; }
const { school, title } = Astro.props;
const nav = getSchoolNav(school.id);
const contacts = getSchoolContacts(school.id);
const palette = getSchoolPalette(school);
const pageTitle = title ? `${title} | ${school.name}` : school.name;
const social = (school.socialHandles as Record<string, string>) || {};
const socialEntries = Object.entries(social).filter(([, v]) => v && v !== '#');
---
<!DOCTYPE html>
<html lang={school.locale || 'en'} dir={['ar','he','fa','ur'].includes(school.locale || 'en') ? 'rtl' : 'ltr'} class="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <script is:inline>
    (function(){var s=localStorage.getItem('themeMode');var d=window.matchMedia('(prefers-color-scheme:dark)').matches;var dk=s==='dark'||(!s&&d);document.documentElement.classList.remove('light','dark');document.documentElement.classList.add(dk?'dark':'light')})();
  </script>
  <style is:inline>{`
    html.light{--bg:${palette.backgroundLight};--surface:${palette.surfaceLight};--text:${palette.textLight};--muted:${palette.mutedLight};--border:${palette.borderLight};--accent:${palette.accent};--primary:${palette.primary}}
    html.dark{--bg:${palette.backgroundDark};--surface:${palette.surfaceDark};--text:${palette.textDark};--muted:${palette.mutedDark};--border:${palette.borderDark};--accent:${palette.accent};--primary:${palette.primary}}
    :root{--spark-primary:${palette.primary}}
  `}</style>
</head>
<body class="antialiased" style="background:var(--bg);color:var(--text)">
  <header class="sticky top-0 z-50" style="background:var(--surface);border-bottom:4px solid var(--primary)">
    <div class="max-w-7xl mx-auto flex items-center justify-between px-5 md:px-8 py-4">
      <a href={`/${school.slug}`} class="flex items-center gap-3">
        {school.logoUrl ? (
          <img src={school.logoUrl} alt={school.name} class="h-10 w-10 rounded-lg" />
        ) : (
          <div class="h-10 w-10 rounded-lg flex items-center justify-center font-black text-white text-lg" style="background:var(--primary)">{school.name[0]}</div>
        )}
        <div>
          <h1 class="font-['Outfit'] text-lg font-extrabold leading-tight tracking-tight" style="color:var(--text)">{school.name}</h1>
          {school.tagline && <p class="text-[11px] font-['Space_Mono'] leading-tight" style="color:var(--muted)">{school.tagline}</p>}
        </div>
      </a>
      <nav class="hidden lg:flex items-center gap-1">
        {nav.map((item: any, i: number) => (
          <a href={item.url.startsWith('http') ? item.url : `/${school.slug}${item.url === '/' ? '' : item.url}`} class:list={[
            "px-3 py-2 text-sm font-['Outfit'] font-semibold rounded-lg transition-all duration-200",
            i === 0 ? 'text-white' : 'hover:opacity-80'
          ]} style={i === 0 ? `background:var(--primary)` : `color:var(--text)`}>{item.label}</a>
        ))}
      </nav>
      <div class="flex items-center gap-2">
        <LanguageSelector />
          <button id="theme-toggle" class="px-3 py-1.5 rounded-lg text-xs font-bold font-['Space_Mono'] transition-all hover:opacity-80" style="background:color-mix(in srgb, var(--primary) 15%, transparent);color:var(--primary)" aria-label="Toggle dark mode">
          <span class="hidden dark:inline">Light</span>
          <span class="inline dark:hidden">Dark</span>
        </button>
        <button id="mobile-toggle" class="lg:hidden p-2 rounded-lg transition-colors hover:opacity-80">
          <svg class="w-6 h-6" style="color:var(--text)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
        </button>
      </div>
    </div>
    <div id="mobile-nav" class="hidden lg:hidden" style="border-top:1px solid var(--border);background:var(--surface)">
      <nav class="flex flex-col p-4 gap-1">
        {nav.map((item: any, i: number) => (
          <a href={item.url.startsWith('http') ? item.url : `/${school.slug}${item.url === '/' ? '' : item.url}`} class:list={[
            "px-4 py-3 text-sm font-['Outfit'] font-semibold rounded-lg transition-all",
            i === 0 ? 'text-white' : 'hover:opacity-80'
          ]} style={i === 0 ? `background:var(--primary)` : `color:var(--text)`}>{item.label}</a>
        ))}
      </nav>
    </div>
  </header>
  <main><slot /></main>
  <footer class="mt-20 text-white" style="background:var(--primary)">
    <div class="max-w-7xl mx-auto px-5 md:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div>
          <h2 class="font-['Outfit'] text-2xl font-extrabold mb-2">{school.name}</h2>
          {school.tagline && <p class="text-white/80 text-sm font-['Space_Mono']">{school.tagline}</p>}
        </div>
        <div>
          <h3 class="font-['Outfit'] text-sm font-bold uppercase tracking-wider mb-4 text-white/60">Quick Links</h3>
          <nav class="flex flex-col gap-2">
            {nav.slice(0, 6).map((item: any) => (
              <a href={item.url.startsWith('http') ? item.url : `/${school.slug}${item.url === '/' ? '' : item.url}`} class="text-sm text-white/80 hover:text-white font-['Outfit'] font-medium transition-colors">{item.label}</a>
            ))}
          </nav>
        </div>
        <div>
          <h3 class="font-['Outfit'] text-sm font-bold uppercase tracking-wider mb-4 text-white/60">Stay Connected</h3>
          {contacts.slice(0,3).map(c => <p class="text-sm text-white/80 font-['Outfit'] font-light">{c.value}</p>)}
          {socialEntries.length > 0 && (
            <div class="flex items-center gap-3 mt-4">
              {socialEntries.map(([platform, handle]) => (
                <a href={normalizeSocialUrl(handle, platform)} aria-label={platform} target="_blank" rel="noopener" class="w-8 h-8 rounded-full bg-white/15 flex items-center justify-center hover:bg-white/25 transition-colors">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d={getSocialIcon(platform)}/></svg>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
      <div class="mt-10 pt-6 border-t border-white/20 text-center">
        <p class="text-xs text-white/50 font-['Space_Mono']">&copy; {new Date().getFullYear()} {school.name} — Powered by iSchool</p>
      </div>
    </div>
  </footer>
  <script>
    const toggle=document.getElementById('mobile-toggle');const nav=document.getElementById('mobile-nav');
    toggle?.addEventListener('click',()=>nav?.classList.toggle('hidden'));
    document.getElementById('theme-toggle')?.addEventListener('click',()=>{const h=document.documentElement;const d=h.classList.contains('dark');h.classList.remove('light','dark');h.classList.add(d?'light':'dark');localStorage.setItem('themeMode',d?'light':'dark')});
  </script>
    <SchoolBannerPopup schoolId={school.id} />
  <PublicAIChatWidget schoolSlug={school.slug} />
</body>
</html>
