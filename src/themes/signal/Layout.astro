---
import '../../styles/global.css';
import LanguageSelector from '../../components/LanguageSelector.astro';
import SchoolBannerPopup from '../../components/SchoolBannerPopup.astro';
import PublicAIChatWidget from '../../components/PublicAIChatWidget.astro';
import { getSchoolNav, getSchoolContacts, getSchoolPalette } from '../../lib/school.ts';
import { normalizeSocialUrl, getSocialIcon } from '../../lib/social.ts';

interface Props { school: any; title?: string; }
const { school, title } = Astro.props;
const nav = getSchoolNav(school.id);
const contacts = getSchoolContacts(school.id);
const palette = getSchoolPalette(school);
const pageTitle = title ? `${title} — ${school.name}` : school.name;
const prefix = `/${school.slug}`;
const { pathname } = Astro.url;
const social = (school.socialHandles as Record<string, string>) || {};
const socialEntries = Object.entries(social).filter(([, v]) => v && v !== '#');
---
<!doctype html>
<html lang={school.locale || 'en'} dir={['ar','he','fa','ur'].includes(school.locale || 'en') ? 'rtl' : 'ltr'} class="dark scroll-smooth">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="description" content={school.tagline || school.name} />
  {school.faviconUrl && <link rel="icon" href={school.faviconUrl} />}
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <title>{pageTitle}</title>
  <script is:inline>
    (function(){var s=localStorage.getItem('themeMode');var d=window.matchMedia('(prefers-color-scheme:dark)').matches;var dk=s==='dark'||(!s&&d&&!document.documentElement.classList.contains('theme-defaults-dark'));if(s==='light')dk=false;document.documentElement.classList.remove('light','dark');document.documentElement.classList.add(dk?'dark':'light')})();
  </script>
  <style is:inline>{`
    html.light{--bg:${palette.backgroundLight};--surface:${palette.surfaceLight};--text:${palette.textLight};--muted:${palette.mutedLight};--border:${palette.borderLight};--accent:${palette.accent};--primary:${palette.primary}}
    html.dark{--bg:${palette.backgroundDark};--surface:${palette.surfaceDark};--text:${palette.textDark};--muted:${palette.mutedDark};--border:${palette.borderDark};--accent:${palette.accent};--primary:${palette.primary}}
  `}</style>
  <style>
    .signal-glow{box-shadow:0 0 20px color-mix(in srgb, var(--primary) 30%, transparent)}
    .signal-border{border:1px solid var(--border);position:relative}
    .signal-border::after{content:'';position:absolute;inset:-1px;border-radius:inherit;border:1px solid transparent;background:linear-gradient(135deg,var(--primary),transparent,var(--accent)) border-box;-webkit-mask:linear-gradient(#fff 0 0) padding-box,linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude;opacity:.4;pointer-events:none}
  </style>
</head>
<body class="min-h-screen font-['IBM_Plex_Sans',sans-serif] bg-[var(--bg)] text-[var(--text)] transition-colors theme-defaults-dark">
  <header class="sticky top-0 z-50" style="background:var(--bg);border-bottom:1px solid var(--border)">
    <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-[64px] flex items-center justify-between">
      <a href={`${prefix}/`} class="flex items-center gap-3">
        {school.logoUrl ? <img src={school.logoUrl} alt={school.name} class="h-9 w-auto" /> : (
          <div class="w-9 h-9 flex items-center justify-center text-white font-bold font-['IBM_Plex_Mono',monospace] signal-glow" style="background:var(--primary);border-radius:8px">{school.name.charAt(0)}</div>
        )}
        <span class="hidden sm:block text-base font-semibold font-['IBM_Plex_Mono',monospace]" style="color:var(--text)">{school.name}</span>
      </a>
      <div class="hidden lg:flex items-center gap-1">
        {nav.map(item => (
          <a href={`${prefix}${item.url}`} class:list={[
            'px-3 py-1.5 text-sm font-medium rounded transition-all font-["IBM_Plex_Mono",monospace]',
            pathname === `${prefix}${item.url}` ? 'signal-glow' : 'hover:opacity-80'
          ]} style={pathname === `${prefix}${item.url}` ? `background:color-mix(in srgb, var(--primary) 15%, transparent);color:var(--primary)` : `color:var(--muted)`}>{item.label}</a>
        ))}
      </div>
      <div class="flex items-center gap-2">
        <button id="theme-toggle" class="w-8 h-8 flex items-center justify-center rounded-lg transition-colors" style="border:1px solid var(--border)" aria-label="Toggle theme">
          <span class="sun hidden">☀️</span><span class="moon">🌙</span>
        </button>
        <button id="mobile-toggle" class="lg:hidden w-8 h-8 flex items-center justify-center rounded-lg" style="border:1px solid var(--border)" aria-label="Menu">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </nav>
    <div id="mobile-menu" class="hidden lg:hidden px-4 pb-4">
      {nav.map(item => (
        <a href={`${prefix}${item.url}`} class="block px-3 py-2.5 text-sm font-['IBM_Plex_Mono',monospace] rounded-lg mb-1" style={pathname === `${prefix}${item.url}` ? `color:var(--primary);background:color-mix(in srgb, var(--primary) 10%, transparent)` : `color:var(--muted)`}>{item.label}</a>
      ))}
    </div>
  </header>
  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <slot />
  </main>
  <footer class="mt-16" style="border-top:1px solid var(--border);background:var(--surface)">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <span class="font-['IBM_Plex_Mono',monospace] font-bold text-base" style="color:var(--text)">{school.name}</span>
          {school.tagline && <p class="text-sm mt-2" style="color:var(--muted)">{school.tagline}</p>}
        </div>
        <div>
          <h4 class="font-['IBM_Plex_Mono',monospace] text-xs uppercase tracking-wider mb-3" style="color:var(--muted)">Navigation</h4>
          <div class="grid grid-cols-2 gap-1">
            {nav.map(item => (
              <a href={`${prefix}${item.url}`} class="text-sm py-1 hover:opacity-80" style="color:var(--muted)">{item.label}</a>
            ))}
          </div>
        </div>
        <div>
          <h4 class="font-['IBM_Plex_Mono',monospace] text-xs uppercase tracking-wider mb-3" style="color:var(--muted)">Contact</h4>
          {contacts.map(c => (
            <div class="text-sm py-1" style="color:var(--muted)">
              {c.address && <p>{c.address}</p>}
              {c.phone && <p>{c.phone}</p>}
              {c.email && <p>{c.email}</p>}
            </div>
          ))}
          {socialEntries.length > 0 && (
            <div class="flex gap-2 mt-3">
              {socialEntries.map(([platform, handle]) => {
                const icon = getSocialIcon(platform);
                return (
                  <a href={normalizeSocialUrl(handle, platform)} aria-label={platform} target="_blank" rel="noopener" class="w-8 h-8 flex items-center justify-center rounded-lg transition-colors hover:signal-glow" style="border:1px solid var(--border)">
                    <span class="text-xs">{icon}</span>
                  </a>
                );
              })}
            </div>
          )}
        </div>
      </div>
      <div class="mt-8 pt-5 text-center text-xs font-['IBM_Plex_Mono',monospace]" style="border-top:1px solid var(--border);color:var(--muted)">
        &copy; {new Date().getFullYear()} {school.name}
        <a href="/" class="ml-2 hover:opacity-80" style="color:var(--primary)">iSchool</a>
      </div>
    </div>
  </footer>
  <LanguageSelector />
  <SchoolBannerPopup schoolId={school.id} />
  <PublicAIChatWidget schoolSlug={school.slug} />
  <script>
    const toggle = document.getElementById('mobile-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    const themeBtn = document.getElementById('theme-toggle');
    themeBtn?.addEventListener('click', () => {
      const html = document.documentElement;
      const isDark = html.classList.contains('dark');
      html.classList.remove('light', 'dark');
      html.classList.add(isDark ? 'light' : 'dark');
      localStorage.setItem('themeMode', isDark ? 'light' : 'dark');
      updateIcons();
    });
    function updateIcons() {
      const isDark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('.sun').forEach(el => el.classList.toggle('hidden', !isDark));
      document.querySelectorAll('.moon').forEach(el => el.classList.toggle('hidden', isDark));
    }
    updateIcons();
  </script>
</body>
</html>
