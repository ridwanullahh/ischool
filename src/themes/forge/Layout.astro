---
import '../../styles/global.css';
import LanguageSelector from '../../components/LanguageSelector.astro';
import SchoolBannerPopup from '../../components/SchoolBannerPopup.astro';
import PublicAIChatWidget from '../../components/PublicAIChatWidget.astro';
import { getSchoolNav, getSchoolContacts, getSchoolPalette } from '../../lib/school.ts';
import { normalizeSocialUrl, getSocialIcon } from '../../lib/social.ts';

interface Props { school: any; title?: string; }
const { school, title } = Astro.props;
const nav = getSchoolNav(school.id);
const contacts = getSchoolContacts(school.id);
const palette = getSchoolPalette(school);
const pageTitle = title ? `${title} — ${school.name}` : school.name;
const prefix = `/${school.slug}`;
const { pathname } = Astro.url;
const social = (school.socialHandles as Record<string, string>) || {};
const socialEntries = Object.entries(social).filter(([, v]) => v && v !== '#');
---
<!doctype html>
<html lang={school.locale || 'en'} dir={['ar','he','fa','ur'].includes(school.locale || 'en') ? 'rtl' : 'ltr'} class="dark scroll-smooth">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="description" content={school.tagline || school.name} />
  {school.faviconUrl && <link rel="icon" href={school.faviconUrl} />}
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <title>{pageTitle}</title>
  <script is:inline>
    (function(){var s=localStorage.getItem('themeMode');var d=window.matchMedia('(prefers-color-scheme:dark)').matches;var dk=s==='dark'||(!s&&d&&!document.documentElement.classList.contains('theme-defaults-dark'));if(s==='light')dk=false;document.documentElement.classList.remove('light','dark');document.documentElement.classList.add(dk?'dark':'light')})();
  </script>
  <style is:inline>{`
    html.light{--bg:${palette.backgroundLight};--surface:${palette.surfaceLight};--text:${palette.textLight};--muted:${palette.mutedLight};--border:${palette.borderLight};--accent:${palette.accent};--primary:${palette.primary}}
    html.dark{--bg:${palette.backgroundDark};--surface:${palette.surfaceDark};--text:${palette.textDark};--muted:${palette.mutedDark};--border:${palette.borderDark};--accent:${palette.accent};--primary:${palette.primary}}
  `}</style>
  <style>
    .forge-bar{height:4px;background:var(--primary)}
  </style>
</head>
<body class="min-h-screen font-['Barlow',sans-serif] bg-[var(--bg)] text-[var(--text)] transition-colors theme-defaults-dark">
  <div class="forge-bar"></div>
  <header class="sticky top-0 z-50" style="background:var(--bg);border-bottom:2px solid var(--border)">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-[72px] flex items-center justify-between">
      <a href={`${prefix}/`} class="flex items-center gap-3">
        {school.logoUrl ? <img src={school.logoUrl} alt={school.name} class="h-10 w-auto" /> : (
          <div class="h-10 px-3 flex items-center justify-center text-white font-['Barlow_Condensed',sans-serif] font-bold text-lg uppercase tracking-wider" style="background:var(--primary)">{school.name.charAt(0)}</div>
        )}
        <div class="hidden sm:block">
          <span class="font-['Barlow_Condensed',sans-serif] text-xl font-bold uppercase tracking-wider block" style="color:var(--text)">{school.name}</span>
          {school.tagline && <span class="text-[10px] uppercase tracking-[0.25em] font-semibold" style="color:var(--muted)">{school.tagline}</span>}
        </div>
      </a>
      <div class="hidden lg:flex items-center gap-0">
        {nav.map(item => (
          <a href={`${prefix}${item.url}`} class:list={[
            'px-4 py-2 text-sm font-["Barlow_Condensed",sans-serif] font-semibold uppercase tracking-wider transition-colors',
            pathname === `${prefix}${item.url}` ? 'forge-active' : 'hover:opacity-70'
          ]} style={pathname === `${prefix}${item.url}` ? `color:var(--primary);border-bottom:2px solid var(--primary)` : `color:var(--muted)`}>{item.label}</a>
        ))}
      </div>
      <div class="flex items-center gap-2">
        <button id="theme-toggle" class="h-9 px-3 flex items-center justify-center transition-colors font-['Barlow_Condensed',sans-serif] text-xs uppercase tracking-wider font-semibold" style="border:2px solid var(--border)" aria-label="Toggle theme">
          <span class="sun hidden">☀️</span><span class="moon">🌙</span>
        </button>
        <button id="mobile-toggle" class="lg:hidden h-9 px-3 flex items-center justify-center" style="border:2px solid var(--border)" aria-label="Menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </nav>
    <div id="mobile-menu" class="hidden lg:hidden px-4 pb-4">
      {nav.map(item => (
        <a href={`${prefix}${item.url}`} class="block px-4 py-3 text-sm font-['Barlow_Condensed',sans-serif] font-semibold uppercase tracking-wider" style={pathname === `${prefix}${item.url}` ? `color:var(--primary)` : `color:var(--muted)`}>{item.label}</a>
      ))}
    </div>
  </header>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <slot />
  </main>
  <footer class="mt-16" style="background:var(--surface);border-top:2px solid var(--border)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <span class="font-['Barlow_Condensed',sans-serif] text-2xl font-bold uppercase tracking-wider" style="color:var(--text)">{school.name}</span>
          {school.tagline && <p class="text-sm mt-2 uppercase tracking-wider font-medium" style="color:var(--muted)">{school.tagline}</p>}
          {socialEntries.length > 0 && (
            <div class="flex gap-2 mt-5">
              {socialEntries.map(([platform, handle]) => {
                const icon = getSocialIcon(platform);
                return (
                  <a href={normalizeSocialUrl(handle, platform)} aria-label={platform} target="_blank" rel="noopener" class="h-9 px-3 flex items-center justify-center transition-colors hover:opacity-70 font-['Barlow_Condensed',sans-serif] text-xs uppercase tracking-wider font-semibold" style="border:2px solid var(--border)">
                    {icon}
                  </a>
                );
              })}
            </div>
          )}
        </div>
        <div>
          <h4 class="font-['Barlow_Condensed',sans-serif] font-bold text-sm uppercase tracking-[0.2em] mb-3" style="color:var(--primary)">Navigation</h4>
          {nav.map(item => (
            <a href={`${prefix}${item.url}`} class="block text-sm py-1.5 hover:opacity-70 font-medium" style="color:var(--muted)">{item.label}</a>
          ))}
        </div>
        <div>
          <h4 class="font-['Barlow_Condensed',sans-serif] font-bold text-sm uppercase tracking-[0.2em] mb-3" style="color:var(--primary)">Contact</h4>
          {contacts.map(c => (
            <div class="text-sm py-1 font-medium" style="color:var(--muted)">
              {c.address && <p>{c.address}</p>}
              {c.phone && <p>{c.phone}</p>}
              {c.email && <p>{c.email}</p>}
            </div>
          ))}
        </div>
      </div>
      <div class="mt-8 pt-5 text-center text-xs font-['Barlow_Condensed',sans-serif] uppercase tracking-[0.2em] font-semibold" style="border-top:2px solid var(--border);color:var(--muted)">
        &copy; {new Date().getFullYear()} {school.name}
        <a href="/" class="ml-2 hover:opacity-70" style="color:var(--primary)">iSchool</a>
      </div>
    </div>
  </footer>
  <LanguageSelector />
  <SchoolBannerPopup schoolId={school.id} />
  <PublicAIChatWidget schoolSlug={school.slug} />
  <script>
    const toggle = document.getElementById('mobile-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    const themeBtn = document.getElementById('theme-toggle');
    themeBtn?.addEventListener('click', () => {
      const html = document.documentElement;
      const isDark = html.classList.contains('dark');
      html.classList.remove('light', 'dark');
      html.classList.add(isDark ? 'light' : 'dark');
      localStorage.setItem('themeMode', isDark ? 'light' : 'dark');
      updateIcons();
    });
    function updateIcons() {
      const isDark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('.sun').forEach(el => el.classList.toggle('hidden', !isDark));
      document.querySelectorAll('.moon').forEach(el => el.classList.toggle('hidden', isDark));
    }
    updateIcons();
  </script>
</body>
</html>
