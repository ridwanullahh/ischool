---
interface Props {
  class?: string;
  padding?: 'none' | 'sm' | 'md' | 'lg';
}

const { class: className = '', padding = 'md' } = Astro.props;

const paddings = {
  none: '',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};
---

<div class={`bg-white rounded-xl border border-gray-200 shadow-sm ${paddings[padding]} ${className}`}>
  <slot />
</div>
