---
---
<div id="createSchoolModal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/50" id="closeCreateSchool"></div>
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Create New School</h3>
      <form method="POST" action="/api/onboarding/school" class="space-y-4">
        <div class="space-y-1">
          <label class="block text-sm font-medium text-gray-700">School Name</label>
          <input type="text" name="name" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
        </div>
        <div class="space-y-1">
          <label class="block text-sm font-medium text-gray-700">URL Slug</label>
          <input type="text" name="slug" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
        </div>
        <div class="space-y-1">
          <label class="block text-sm font-medium text-gray-700">Tagline</label>
          <input type="text" name="tagline" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
        </div>
        <div class="space-y-1">
          <label class="block text-sm font-medium text-gray-700">Primary Color</label>
          <input type="color" name="primaryColor" value="#2563eb" class="w-10 h-10 rounded border border-gray-300 cursor-pointer" />
        </div>
        <div class="flex justify-end gap-3 pt-2">
          <button type="button" id="cancelCreateSchool" class="px-4 py-2 text-sm text-gray-600 hover:text-gray-900">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white text-sm font-medium rounded-lg hover:bg-primary-700">Create School</button>
        </div>
      </form>
    </div>
  </div>
</div>
<script>
  const modal = document.getElementById('createSchoolModal');
  document.getElementById('openCreateSchool')?.addEventListener('click', () => modal?.classList.remove('hidden'));
  document.getElementById('closeCreateSchool')?.addEventListener('click', () => modal?.classList.add('hidden'));
  document.getElementById('cancelCreateSchool')?.addEventListener('click', () => modal?.classList.add('hidden'));
</script>
