import AIChatWidget from '../components/AIChatWidget.astro';

interface Props {
  title?: string;
}

const { title = 'Dashboard - iSchool' } = Astro.props;
const user = Astro.locals.user;
const { pathname } = Astro.url;

let school = null;
if (user) {
  const db = getDb();
  const membership = db.select().from(schoolMembers).where(eq(schoolMembers.userId, user.id)).get();
  if (membership) {
    school = db.select().from(schools).where(eq(schools.id, membership.schoolId)).get();
  }
}

