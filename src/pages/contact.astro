---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Input from '../components/ui/Input.astro';
import Button from '../components/ui/Button.astro';
---

<MarketingLayout title="Contact - iSchool" description="Get in touch with the iSchool team. We're here to help.">
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <h1 class="text-4xl font-bold text-gray-900">Get in touch</h1>
          <p class="mt-4 text-lg text-gray-600 leading-relaxed">
            Have questions about iSchool? Want a demo for your school? We'd love to hear from you.
          </p>

          <div class="mt-10 space-y-6">
            {[
              { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', label: 'Email', value: 'hello@ischool.com' },
              { icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z', label: 'Phone', value: '+1 (555) 000-0000' },
              { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', label: 'Office', value: '123 Education Way, San Francisco, CA 94102' },
            ].map(contact => (
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={contact.icon} /></svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-900">{contact.label}</p>
                  <p class="text-sm text-gray-600">{contact.value}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
          <h2 class="text-xl font-semibold text-gray-900 mb-6">Send us a message</h2>
          <form class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <Input label="First Name" name="firstName" placeholder="Jane" required />
              <Input label="Last Name" name="lastName" placeholder="Smith" required />
            </div>
            <Input label="Email" name="email" type="email" placeholder="jane@school.edu" required />
            <Input label="School Name" name="school" placeholder="Green Valley Academy" />
            <Input label="Message" name="message" placeholder="Tell us about your school and what you're looking for..." rows={4} required />
            <Button type="submit" full>Send Message</Button>
          </form>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
