---
import Layout from '../layouts/MarketingLayout.astro';
---

<Layout title="500 - Server Error">
  <div class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 py-12">
    <div class="text-center max-w-md">
      <div class="text-6xl font-bold text-gray-300 mb-4">500</div>
      <h1 class="text-2xl font-bold text-gray-900 mb-2">Something went wrong</h1>
      <p class="text-gray-600 mb-8">We encountered an unexpected error. Our team has been notified and is working to fix it.</p>
      <div class="space-x-4">
        <a href="/" class="inline-block bg-primary-600 text-white px-6 py-2.5 rounded-lg font-medium hover:bg-primary-700 transition-colors">Go Home</a>
        <a href="javascript:window.location.reload()" class="inline-block bg-gray-100 text-gray-700 px-6 py-2.5 rounded-lg font-medium hover:bg-gray-200 transition-colors">Try Again</a>
      </div>
    </div>
  </div>
</Layout>
