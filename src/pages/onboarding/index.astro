---
import OnboardingLayout from '../../layouts/OnboardingLayout.astro';
---
<OnboardingLayout title="Welcome - iSchool Setup" step={1}>
  <div class="bg-white rounded-xl border border-gray-200 p-8 text-center">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Welcome to iSchool</h1>
    <p class="text-gray-600 mb-8">Let's set up your school website in a few simple steps.</p>
    <a href="/onboarding/school" class="inline-flex items-center px-6 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors">
      Get Started
      <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </a>
  </div>
</OnboardingLayout>
