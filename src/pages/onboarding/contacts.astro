---
import OnboardingLayout from '../../layouts/OnboardingLayout.astro';
import Input from '../../components/ui/Input.astro';
import Button from '../../components/ui/Button.astro';
---
<OnboardingLayout title="Contact Info - iSchool Setup" step={3}>
  <div class="bg-white rounded-xl border border-gray-200 p-8">
    <h1 class="text-xl font-bold text-gray-900 mb-1">Contact Information</h1>
    <p class="text-sm text-gray-500 mb-6">How can visitors reach your school?</p>
    <form method="POST" action="/api/onboarding/contacts" class="space-y-4">
      <Input label="Email" name="email" type="email" required placeholder="info@school.edu" />
      <Input label="Phone" name="phone" placeholder="+1 (555) 123-4567" />
      <Input label="Address" name="address" placeholder="123 School Road, City, State 12345" />
      <div class="flex gap-3 pt-4">
        <a href="/onboarding/about" class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900">Back</a>
        <Button type="submit">Continue</Button>
      </div>
    </form>
  </div>
</OnboardingLayout>
