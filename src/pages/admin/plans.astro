---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDb } from '../../lib/db/index.js';
import { subscriptionPlans } from '../../lib/db/schema.js';

const db = getDb();
const plans = db.select().from(subscriptionPlans).orderBy(subscriptionPlans.sortOrder).all();
---

<AdminLayout title="Subscription Plans - iSchool">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-bold text-gray-900">Subscription Plans</h2>
      <p class="text-sm text-gray-500 mt-1">Manage billing plans for schools on the platform</p>
    </div>
    <button onclick="document.getElementById('create-plan-modal').classList.remove('hidden')" class="inline-flex items-center gap-2 px-4 py-2 bg-primary-600 text-white text-sm font-medium rounded-lg hover:bg-primary-700 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Create Plan
    </button>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {plans.map(plan => (
      <div class:list={['bg-white rounded-xl border-2 p-6 relative', plan.isPopular ? 'border-primary-500 shadow-lg' : 'border-gray-200']}>
        {plan.isPopular && <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary-600 text-white text-xs font-semibold px-3 py-1 rounded-full">Most Popular</div>}
        {plan.isFree && <div class="absolute -top-3 right-4 bg-green-500 text-white text-xs font-semibold px-3 py-1 rounded-full">Free</div>}
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-lg font-bold text-gray-900">{plan.name}</h3>
          <span class:list={['text-xs font-medium px-2 py-0.5 rounded-full', plan.isActive ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500']}>
            {plan.isActive ? 'Active' : 'Inactive'}
          </span>
        </div>
        <p class="text-sm text-gray-500 mb-4">{plan.description}</p>
        <div class="flex items-baseline gap-1 mb-4">
          <span class="text-3xl font-bold text-gray-900">${(plan.monthlyPrice / 100).toFixed(0)}</span>
          <span class="text-gray-500 text-sm">/mo</span>
          <span class="text-gray-400 mx-2">|</span>
          <span class="text-lg font-semibold text-gray-700">${(plan.annualPrice / 100).toFixed(0)}</span>
          <span class="text-gray-500 text-sm">/yr</span>
        </div>
        <div class="border-t border-gray-100 pt-4 mb-4">
          <div class="grid grid-cols-2 gap-2 text-xs text-gray-600">
            <div>Max Schools: <span class="font-medium">{plan.maxSchools || 'Unlimited'}</span></div>
            <div>Max Students: <span class="font-medium">{plan.maxStudents || 'Unlimited'}</span></div>
            <div>Max Staff: <span class="font-medium">{plan.maxStaff || 'Unlimited'}</span></div>
            <div>Storage: <span class="font-medium">{plan.maxStorage}MB</span></div>
            <div>Trial: <span class="font-medium">{plan.trialDays || 0} days</span></div>
            <div>Custom Domain: <span class="font-medium">{plan.customDomain ? 'Yes' : 'No'}</span></div>
          </div>
        </div>
        <div class="flex gap-2">
          <button onclick={`editPlan(${plan.id})`} class="flex-1 px-3 py-2 text-sm font-medium text-primary-600 border border-primary-200 rounded-lg hover:bg-primary-50 transition-colors">Edit</button>
          <button onclick={`togglePlan(${plan.id}, ${!plan.isActive})`} class:list={['flex-1 px-3 py-2 text-sm font-medium rounded-lg transition-colors', plan.isActive ? 'text-red-600 border border-red-200 hover:bg-red-50' : 'text-green-600 border border-green-200 hover:bg-green-50']}>
            {plan.isActive ? 'Deactivate' : 'Activate'}
          </button>
        </div>
      </div>
    ))}
  </div>

  <div id="create-plan-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/50" onclick="this.parentElement.classList.add('hidden')"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto p-8">
      <h3 class="text-lg font-bold text-gray-900 mb-6">Create Subscription Plan</h3>
      <form id="plan-form" class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Plan Name</label><input name="name" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Slug</label><input name="slug" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500" /></div>
        </div>
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Description</label><textarea name="description" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500"></textarea></div>
        <div class="grid grid-cols-3 gap-4">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Monthly Price (cents)</label><input name="monthlyPrice" type="number" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Annual Price (cents)</label><input name="annualPrice" type="number" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Trial Days</label><input name="trialDays" type="number" value="14" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" /></div>
        </div>
        <div class="grid grid-cols-4 gap-4">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Max Schools</label><input name="maxSchools" type="number" value="1" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Max Students</label><input name="maxStudents" type="number" value="100" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Max Staff</label><input name="maxStaff" type="number" value="10" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Storage (MB)</label><input name="maxStorage" type="number" value="500" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" /></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="flex items-center gap-2 text-sm"><input name="isFree" type="checkbox" class="rounded border-gray-300 text-primary-600" /> Free Plan</label></div>
          <div><label class="flex items-center gap-2 text-sm"><input name="isPopular" type="checkbox" class="rounded border-gray-300 text-primary-600" /> Mark as Popular</label></div>
          <div><label class="flex items-center gap-2 text-sm"><input name="customDomain" type="checkbox" class="rounded border-gray-300 text-primary-600" /> Custom Domain</label></div>
          <div><label class="flex items-center gap-2 text-sm"><input name="apiAccess" type="checkbox" class="rounded border-gray-300 text-primary-600" /> API Access</label></div>
          <div><label class="flex items-center gap-2 text-sm"><input name="prioritySupport" type="checkbox" class="rounded border-gray-300 text-primary-600" /> Priority Support</label></div>
          <div><label class="flex items-center gap-2 text-sm"><input name="whiteLabel" type="checkbox" class="rounded border-gray-300 text-primary-600" /> White Label</label></div>
        </div>
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Features (JSON array of strings)</label><textarea name="features" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono" placeholder='["Feature 1", "Feature 2"]'></textarea></div>
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Module Access (JSON array)</label><textarea name="moduleAccess" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono" placeholder='["cms","sis","lms"]'></textarea></div>
        <div class="flex gap-3 pt-4">
          <button type="submit" class="flex-1 px-4 py-2.5 bg-primary-600 text-white text-sm font-medium rounded-lg hover:bg-primary-700">Create Plan</button>
          <button type="button" onclick="document.getElementById('create-plan-modal').classList.add('hidden')" class="px-4 py-2.5 border border-gray-300 text-sm font-medium rounded-lg hover:bg-gray-50">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    document.getElementById('plan-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const fd = new FormData(form);
      const data = {
        name: fd.get('name'), slug: fd.get('slug'), description: fd.get('description'),
        monthlyPrice: Number(fd.get('monthlyPrice')), annualPrice: Number(fd.get('annualPrice')),
        trialDays: Number(fd.get('trialDays')), maxSchools: Number(fd.get('maxSchools')),
        maxStudents: Number(fd.get('maxStudents')), maxStaff: Number(fd.get('maxStaff')),
        maxStorage: Number(fd.get('maxStorage')), isFree: fd.get('isFree') === 'on',
        isPopular: fd.get('isPopular') === 'on', customDomain: fd.get('customDomain') === 'on',
        apiAccess: fd.get('apiAccess') === 'on', prioritySupport: fd.get('prioritySupport') === 'on',
        whiteLabel: fd.get('whiteLabel') === 'on',
        features: fd.get('features') || '[]', moduleAccess: fd.get('moduleAccess') || '[]',
      };
      const res = await fetch('/api/admin/plans', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if (res.ok) window.location.reload();
      else alert('Failed to create plan');
    });

    async function editPlan(id: number) { alert('Edit plan modal - extend in production'); }
    async function togglePlan(id: number, active: boolean) {
      const res = await fetch(`/api/admin/plans?id=${id}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ isActive: active }) });
      if (res.ok) window.location.reload();
    }
  </script>
</AdminLayout>
