---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDb } from '../../lib/db/index.js';
import { platformInvoices, platformPayments, schoolSubscriptions, schools, subscriptionPlans } from '../../lib/db/schema.js';
import { sql } from 'drizzle-orm';

const db = getDb();
const invoices = db.select({
  id: platformInvoices.id,
  invoiceNumber: platformInvoices.invoiceNumber,
  amount: platformInvoices.amount,
  totalAmount: platformInvoices.totalAmount,
  discount: platformInvoices.discount,
  status: platformInvoices.status,
  dueDate: platformInvoices.dueDate,
  paidAt: platformInvoices.paidAt,
  schoolId: platformInvoices.schoolId,
  createdAt: platformInvoices.createdAt,
}).from(platformInvoices).orderBy(sql`created_at DESC`).limit(50).all();

const totalRevenue = db.select({ total: sql<number>`COALESCE(SUM(total_amount), 0)` }).from(platformInvoices).where(sql`status = 'paid'`).get()?.total || 0;
const pendingAmount = db.select({ total: sql<number>`COALESCE(SUM(total_amount), 0)` }).from(platformInvoices).where(sql`status = 'pending'`).get()?.total || 0;
const paidCount = db.select({ count: sql<number>`count(*)` }).from(platformInvoices).where(sql`status = 'paid'`).get()?.count || 0;
const pendingCount = db.select({ count: sql<number>`count(*)` }).from(platformInvoices).where(sql`status = 'pending'`).get()?.count || 0;

const subscriptions = db.select({
  id: schoolSubscriptions.id,
  schoolId: schoolSubscriptions.schoolId,
  status: schoolSubscriptions.status,
  billingCycle: schoolSubscriptions.billingCycle,
  currentPeriodEnd: schoolSubscriptions.currentPeriodEnd,
  planName: subscriptionPlans.name,
}).from(schoolSubscriptions).leftJoin(subscriptionPlans, sql`${schoolSubscriptions.planId} = ${subscriptionPlans.id}`).limit(20).all();
---

<AdminLayout title="Billing & Revenue - iSchool">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <p class="text-sm text-gray-500">Total Revenue</p>
      <p class="text-3xl font-bold text-green-600 mt-1">${(totalRevenue / 100).toFixed(2)}</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <p class="text-sm text-gray-500">Pending Payments</p>
      <p class="text-3xl font-bold text-orange-600 mt-1">${(pendingAmount / 100).toFixed(2)}</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <p class="text-sm text-gray-500">Paid Invoices</p>
      <p class="text-3xl font-bold text-gray-900 mt-1">{paidCount}</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <p class="text-sm text-gray-500">Pending Invoices</p>
      <p class="text-3xl font-bold text-gray-900 mt-1">{pendingCount}</p>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 mb-8">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-base font-semibold text-gray-900">Active Subscriptions</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50"><tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">School ID</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Plan</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Cycle</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Period End</th>
        </tr></thead>
        <tbody class="divide-y divide-gray-100">
          {subscriptions.length === 0 && <tr><td colspan="5" class="px-6 py-8 text-center text-gray-500">No subscriptions yet</td></tr>}
          {subscriptions.map(sub => (
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-gray-900">School #{sub.schoolId}</td>
              <td class="px-6 py-4 text-gray-900 font-medium">{sub.planName || 'N/A'}</td>
              <td class="px-6 py-4"><span class:list={['text-xs font-medium px-2.5 py-0.5 rounded-full', sub.status === 'active' ? 'bg-green-100 text-green-700' : sub.status === 'trial' ? 'bg-blue-100 text-blue-700' : sub.status === 'expired' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700']}>{sub.status}</span></td>
              <td class="px-6 py-4 text-gray-600 capitalize">{sub.billingCycle}</td>
              <td class="px-6 py-4 text-gray-600">{sub.currentPeriodEnd ? new Date(sub.currentPeriodEnd).toLocaleDateString() : '-'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-base font-semibold text-gray-900">Recent Invoices</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50"><tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Invoice</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">School</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Discount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
        </tr></thead>
        <tbody class="divide-y divide-gray-100">
          {invoices.length === 0 && <tr><td colspan="6" class="px-6 py-8 text-center text-gray-500">No invoices yet</td></tr>}
          {invoices.map(inv => (
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 font-mono text-xs text-gray-900">{inv.invoiceNumber}</td>
              <td class="px-6 py-4 text-gray-900">School #{inv.schoolId}</td>
              <td class="px-6 py-4 text-gray-900 font-medium">${(inv.totalAmount / 100).toFixed(2)}</td>
              <td class="px-6 py-4 text-gray-600">{inv.discount > 0 ? `-$${(inv.discount / 100).toFixed(2)}` : '-'}</td>
              <td class="px-6 py-4"><span class:list={['text-xs font-medium px-2.5 py-0.5 rounded-full', inv.status === 'paid' ? 'bg-green-100 text-green-700' : inv.status === 'pending' ? 'bg-yellow-100 text-yellow-700' : inv.status === 'failed' ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-600']}>{inv.status}</span></td>
              <td class="px-6 py-4 text-gray-600">{inv.createdAt ? new Date(inv.createdAt).toLocaleDateString() : '-'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
