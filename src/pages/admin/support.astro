---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDb } from '../../lib/db/index.js';
import { supportTickets, supportTicketReplies, users, schools } from '../../lib/db/schema.js';
import { sql, eq, desc } from 'drizzle-orm';

const db = getDb();
const statusFilter = Astro.url.searchParams.get('status') || 'all';
const tickets = db.select({
  id: supportTickets.id,
  ticketNumber: supportTickets.ticketNumber,
  subject: supportTickets.subject,
  category: supportTickets.category,
  priority: supportTickets.priority,
  status: supportTickets.status,
  userId: supportTickets.userId,
  schoolId: supportTickets.schoolId,
  createdAt: supportTickets.createdAt,
  userName: users.name,
}).from(supportTickets).leftJoin(users, eq(supportTickets.userId, users.id)).orderBy(desc(supportTickets.createdAt)).limit(50).all();

const openCount = db.select({ count: sql<number>`count(*)` }).from(supportTickets).where(sql`status = 'open'`).get()?.count || 0;
const inProgressCount = db.select({ count: sql<number>`count(*)` }).from(supportTickets).where(sql`status = 'in_progress'`).get()?.count || 0;
const resolvedCount = db.select({ count: sql<number>`count(*)` }).from(supportTickets).where(sql`status = 'resolved'`).get()?.count || 0;
---

<AdminLayout title="Support Tickets - iSchool">
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-gray-200 p-5 flex items-center gap-4">
      <div class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center"><svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
      <div><p class="text-2xl font-bold text-gray-900">{openCount}</p><p class="text-xs text-gray-500">Open</p></div>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5 flex items-center gap-4">
      <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center"><svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg></div>
      <div><p class="text-2xl font-bold text-gray-900">{inProgressCount}</p><p class="text-xs text-gray-500">In Progress</p></div>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5 flex items-center gap-4">
      <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center"><svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
      <div><p class="text-2xl font-bold text-gray-900">{resolvedCount}</p><p class="text-xs text-gray-500">Resolved</p></div>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <h2 class="text-base font-semibold text-gray-900">Support Tickets</h2>
      <div class="flex gap-2">
        {['all', 'open', 'in_progress', 'resolved', 'closed'].map(s => (
          <a href={s === 'all' ? '/admin/support' : `/admin/support?status=${s}`} class:list={['text-xs font-medium px-3 py-1.5 rounded-lg transition-colors', statusFilter === s ? 'bg-primary-100 text-primary-700' : 'text-gray-500 hover:bg-gray-100']}>{s.replace('_', ' ')}</a>
        ))}
      </div>
    </div>
    <table class="w-full text-sm">
      <thead class="bg-gray-50"><tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Ticket</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Subject</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">User</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Priority</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
      </tr></thead>
      <tbody class="divide-y divide-gray-100">
        {tickets.length === 0 && <tr><td colspan="7" class="px-6 py-8 text-center text-gray-500">No support tickets</td></tr>}
        {tickets.map(t => (
          <tr class="hover:bg-gray-50 cursor-pointer" onclick={`window.location='/admin/support?id=${t.id}'`}>
            <td class="px-6 py-4 font-mono text-xs text-gray-500">{t.ticketNumber}</td>
            <td class="px-6 py-4 text-gray-900 font-medium">{t.subject}</td>
            <td class="px-6 py-4 text-gray-600">{t.userName || 'Unknown'}</td>
            <td class="px-6 py-4 text-gray-600 capitalize">{t.category.replace('_', ' ')}</td>
            <td class="px-6 py-4"><span class:list={['text-xs font-medium px-2 py-0.5 rounded-full', t.priority === 'urgent' ? 'bg-red-100 text-red-700' : t.priority === 'high' ? 'bg-orange-100 text-orange-700' : t.priority === 'medium' ? 'bg-yellow-100 text-yellow-700' : 'bg-gray-100 text-gray-600']}>{t.priority}</span></td>
            <td class="px-6 py-4"><span class:list={['text-xs font-medium px-2.5 py-0.5 rounded-full', t.status === 'open' ? 'bg-orange-100 text-orange-700' : t.status === 'in_progress' ? 'bg-blue-100 text-blue-700' : t.status === 'resolved' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600']}>{t.status.replace('_', ' ')}</span></td>
            <td class="px-6 py-4 text-gray-600">{t.createdAt ? new Date(t.createdAt).toLocaleDateString() : '-'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>
