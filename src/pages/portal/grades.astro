---
import PortalLayout from '../../layouts/PortalLayout.astro';
import { getDb } from '../../lib/db/index.js';
import { grades, students, courses, schoolMembers } from '../../lib/db/schema.js';
import { eq, and, desc } from 'drizzle-orm';

const user = (Astro.locals as any).user;
if (!user) return Astro.redirect('/auth/login');

const db = getDb();
const membership = db.select().from(schoolMembers).where(eq(schoolMembers.userId, user.id)).get();
const schoolId = membership?.schoolId;

let gradeList: any[] = [];
if (schoolId) {
  const student = db.select().from(students).where(and(eq(students.schoolId, schoolId), eq(students.userId, user.id))).get();
  if (student) {
    gradeList = db.select({
      id: grades.id,
      term: grades.term,
      academicYear: grades.academicYear,
      category: grades.category,
      score: grades.score,
      maxScore: grades.maxScore,
      grade: grades.grade,
      comment: grades.comment,
      courseTitle: courses.title,
      createdAt: grades.createdAt,
    }).from(grades)
      .leftJoin(courses, eq(grades.courseId, courses.id))
      .where(eq(grades.studentId, student.id))
      .orderBy(desc(grades.createdAt))
      .all();
  }
}
---

<PortalLayout title="My Grades">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">My Grades</h1>
    <p class="text-gray-500 mt-1">View your academic performance</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b">
        <tr>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Course</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Term</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Category</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Score</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Grade</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Comment</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {gradeList.length === 0 ? (
          <tr><td colspan="6" class="px-4 py-8 text-center text-gray-500">No grades posted yet.</td></tr>
        ) : (
          gradeList.map((g: any) => (
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 text-gray-900 font-medium">{g.courseTitle || 'General'}</td>
              <td class="px-4 py-3 text-gray-600">{g.term || '-'}</td>
              <td class="px-4 py-3 text-gray-600">{g.category || '-'}</td>
              <td class="px-4 py-3 text-gray-900 font-medium">{g.score != null ? `${g.score}/${g.maxScore || 100}` : '-'}</td>
              <td class="px-4 py-3">
                {g.grade && (
                  <span class="text-xs font-bold px-2 py-1 rounded-full bg-primary-100 text-primary-700">{g.grade}</span>
                )}
              </td>
              <td class="px-4 py-3 text-gray-500 text-xs">{g.comment || '-'}</td>
            </tr>
          ))
        )}
      </tbody>
    </table>
  </div>
</PortalLayout>
