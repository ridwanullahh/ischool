---
import PortalLayout from '../../layouts/PortalLayout.astro';
import { getDb } from '../../lib/db/index.js';
import { invoices, students, schoolMembers, payments } from '../../lib/db/schema.js';
import { eq, and, desc } from 'drizzle-orm';

const user = (Astro.locals as any).user;
if (!user) return Astro.redirect('/auth/login');

const db = getDb();
const membership = db.select().from(schoolMembers).where(eq(schoolMembers.userId, user.id)).get();
const schoolId = membership?.schoolId;

let invoiceList: any[] = [];
let summary = { total: 0, paid: 0, outstanding: 0 };

if (schoolId) {
  const student = db.select().from(students).where(and(eq(students.schoolId, schoolId), eq(students.userId, user.id))).get();
  if (student) {
    invoiceList = db.select().from(invoices).where(eq(invoices.studentId, student.id)).orderBy(desc(invoices.createdAt)).all();

    summary.total = invoiceList.reduce((s, inv) => s + (inv.amount || 0), 0);
    summary.paid = invoiceList.reduce((s, inv) => s + (inv.paidAmount || 0), 0);
    summary.outstanding = summary.total - summary.paid;
  }
}
---

<PortalLayout title="My Fees">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">My Fees</h1>
    <p class="text-gray-500 mt-1">View your fee statements and payment history</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-xl border p-4 text-center">
      <p class="text-2xl font-bold text-gray-900">${summary.total.toFixed(2)}</p>
      <p class="text-xs text-gray-500">Total Fees</p>
    </div>
    <div class="bg-white rounded-xl border p-4 text-center">
      <p class="text-2xl font-bold text-green-600">${summary.paid.toFixed(2)}</p>
      <p class="text-xs text-gray-500">Paid</p>
    </div>
    <div class="bg-white rounded-xl border p-4 text-center">
      <p class="text-2xl font-bold text-red-600">${summary.outstanding.toFixed(2)}</p>
      <p class="text-xs text-gray-500">Outstanding</p>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b">
        <tr>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Invoice #</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Amount</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Paid</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Balance</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Status</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500">Due Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {invoiceList.length === 0 ? (
          <tr><td colspan="6" class="px-4 py-8 text-center text-gray-500">No invoices found.</td></tr>
        ) : (
          invoiceList.map((inv: any) => (
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 text-gray-900 font-medium">{inv.invoiceNumber || `#${inv.id}`}</td>
              <td class="px-4 py-3 text-gray-900">${(inv.amount || 0).toFixed(2)}</td>
              <td class="px-4 py-3 text-green-600">${(inv.paidAmount || 0).toFixed(2)}</td>
              <td class="px-4 py-3 text-red-600">${(inv.balance || 0).toFixed(2)}</td>
              <td class="px-4 py-3">
                <span class:list={['text-xs font-medium px-2 py-1 rounded-full',
                  inv.status === 'paid' ? 'bg-green-100 text-green-700' :
                  inv.status === 'partial' ? 'bg-amber-100 text-amber-700' :
                  'bg-red-100 text-red-700'
                ]}>
                  {inv.status}
                </span>
              </td>
              <td class="px-4 py-3 text-gray-500">{inv.dueDate || '-'}</td>
            </tr>
          ))
        )}
      </tbody>
    </table>
  </div>
</PortalLayout>
