---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Input from '../../components/ui/Input.astro';
import Button from '../../components/ui/Button.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { classes } from '../../lib/db/schema.js';
import { eq, asc } from 'drizzle-orm';

const user = Astro.locals.user!;
const schoolId = getUserSchoolId(user.id);
const db = getDb();

const items = schoolId ? db.select().from(classes).where(eq(classes.schoolId, schoolId)).orderBy(asc(classes.sortOrder)).all() : [];
const success = Astro.url.searchParams.get('success');
const editId = Astro.url.searchParams.get('edit');
const editing = editId ? items.find(i => i.id === Number(editId)) : null;
---

<DashboardLayout title="Classes - iSchool">
  {success && (
    <div class="mb-6 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Class saved successfully.</div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <h2 class="text-base font-semibold text-gray-900 mb-4">{editing ? 'Edit' : 'New'} Class</h2>
        <form method="POST" action="/api/dashboard/classes" class="space-y-4">
          {editing && <input type="hidden" name="id" value={editing.id} />}
          <Input label="Class Name" name="name" value={editing?.name || ''} placeholder="e.g., Grade 5 - Section A" required />
          <Input label="Slug" name="slug" value={editing?.slug || ''} placeholder="grade-5-section-a" required />
          <Input label="Grade Level" name="gradeLevel" value={editing?.gradeLevel || ''} placeholder="e.g., Grade 5" />
          <Input label="Teacher Name" name="teacherName" value={editing?.teacherName || ''} placeholder="e.g., Ms. Johnson" />
          <Input label="Capacity" name="capacity" type="number" value={editing?.capacity?.toString() || ''} placeholder="e.g., 25" />
          <Input label="Description" name="description" value={editing?.description || ''} placeholder="Class description..." rows={3} />
          <Input label="Full Content" name="content" value={editing?.content || ''} placeholder="Detailed content for the class page..." rows={6} />
          <Input label="Image URL" name="imageUrl" value={editing?.imageUrl || ''} placeholder="https://..." />
          <Input label="Sort Order" name="sortOrder" type="number" value={editing?.sortOrder?.toString() || '0'} />
          <div class="flex items-center gap-2">
            <input type="checkbox" id="hasDetailPage" name="hasDetailPage" checked={editing ? editing.hasDetailPage : true} class="rounded border-gray-300" />
            <label for="hasDetailPage" class="text-sm text-gray-700">Enable detail page</label>
          </div>
          <Button type="submit" full>{editing ? 'Update' : 'Add'} Class</Button>
          {editing && <a href="/dashboard/classes" class="block text-center text-sm text-gray-500 hover:text-gray-700">Cancel Edit</a>}
        </form>
      </div>
    </div>

    <div class="lg:col-span-2">
      <div class="bg-white rounded-xl border border-gray-200">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-base font-semibold text-gray-900">All Classes ({items.length})</h2>
        </div>
        <div class="divide-y divide-gray-100">
          {items.length === 0 && <p class="p-6 text-sm text-gray-500 text-center">No classes added yet.</p>}
          {items.map(item => (
            <div class="px-6 py-4 flex items-center justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-medium text-gray-900">{item.name}</h3>
                <p class="text-sm text-gray-500">{item.gradeLevel}{item.teacherName ? ` · ${item.teacherName}` : ''}{item.capacity ? ` · ${item.capacity} students` : ''}</p>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <a href={`?edit=${item.id}`} class="text-xs text-primary-600 hover:text-primary-700">Edit</a>
                <form method="POST" action="/api/dashboard/classes">
                  <input type="hidden" name="id" value={item.id} />
                  <input type="hidden" name="action" value="delete" />
                  <button type="submit" class="text-xs text-red-500 hover:text-red-700">Delete</button>
                </form>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>
