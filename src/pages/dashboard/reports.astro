---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { savedReports, students, staff, courses, attendance, invoices } from '../../lib/db/schema.js';
import { eq, desc, sql } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/auth/login');
const schoolId = getUserSchoolId(user.id);

let reports: any[] = [];
let quickStats: any = {};

if (schoolId) {
  const db = getDb();
  reports = db.select().from(savedReports).where(eq(savedReports.schoolId, schoolId)).orderBy(desc(savedReports.createdAt)).all();
  quickStats = {
    students: db.select({ count: sql<number>`count(*)` }).from(students).where(eq(students.schoolId, schoolId)).get()?.count || 0,
    staff: db.select({ count: sql<number>`count(*)` }).from(staff).where(eq(staff.schoolId, schoolId)).get()?.count || 0,
    courses: db.select({ count: sql<number>`count(*)` }).from(courses).where(eq(courses.schoolId, schoolId)).get()?.count || 0,
    attendance: db.select({ count: sql<number>`count(*)` }).from(attendance).where(eq(attendance.schoolId, schoolId)).get()?.count || 0,
  };
}

const reportTypes = [
  { module: 'sis', name: 'Student Enrollment Report', icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z', desc: 'All students by status, class, and enrollment date' },
  { module: 'hr', name: 'Staff Directory Report', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z', desc: 'All staff members by department and designation' },
  { module: 'lms', name: 'Course Catalog Report', icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253', desc: 'All courses by subject, grade level, and status' },
  { module: 'finance', name: 'Fee Collection Report', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', desc: 'Invoice summary, payments received, outstanding balances' },
  { module: 'attendance', name: 'Attendance Report', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4', desc: 'Attendance records by date range and status' },
];
---

<DashboardLayout title="Reports - iSchool">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <div><h2 class="text-2xl font-bold text-gray-900">Reports & Analytics</h2><p class="text-sm text-gray-500 mt-1">Generate and view reports</p></div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Students</p><p class="text-2xl font-bold text-blue-600">{quickStats.students}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Staff</p><p class="text-2xl font-bold text-green-600">{quickStats.staff}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Courses</p><p class="text-2xl font-bold text-purple-600">{quickStats.courses}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Attendance Records</p><p class="text-2xl font-bold text-orange-600">{quickStats.attendance}</p></div>
    </div>

    <h3 class="text-lg font-semibold text-gray-900">Quick Reports</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {reportTypes.map(rt => (
        <div class="bg-white rounded-lg border p-5 hover:shadow-md transition-shadow">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 bg-primary-50 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={rt.icon} /></svg>
            </div>
            <div class="flex-1">
              <h4 class="font-medium text-gray-900">{rt.name}</h4>
              <p class="text-xs text-gray-500 mt-1">{rt.desc}</p>
              <button onclick={`generateReport('${rt.module}', '${rt.name}')`} class="mt-3 text-sm text-primary-600 hover:text-primary-800 font-medium">Generate &rarr;</button>
            </div>
          </div>
        </div>
      ))}
    </div>

    {reports.length > 0 && (
      <>
        <h3 class="text-lg font-semibold text-gray-900">Saved Reports</h3>
        <div class="bg-white rounded-lg shadow overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-gray-50"><tr>
              <th class="px-4 py-3 text-left font-medium text-gray-600">Name</th><th class="px-4 py-3 text-left font-medium text-gray-600">Module</th>
              <th class="px-4 py-3 text-left font-medium text-gray-600">Created</th><th class="px-4 py-3 text-left font-medium text-gray-600">Actions</th>
            </tr></thead>
            <tbody class="divide-y">
              {reports.map(r => (
                <tr>
                  <td class="px-4 py-3 font-medium">{r.name}</td>
                  <td class="px-4 py-3"><span class="px-2 py-1 bg-gray-100 rounded text-xs">{r.module}</span></td>
                  <td class="px-4 py-3 text-gray-500">{new Date(r.createdAt).toLocaleDateString()}</td>
                  <td class="px-4 py-3"><button onclick={`deleteReport(${r.id})`} class="text-red-600 text-xs">Delete</button></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </>
    )}
  </div>

  <script>
    async function generateReport(module: string, name: string) {
      await fetch('/api/dashboard/reports', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({
        name, module, config: { generatedAt: new Date().toISOString() },
      })});
      location.reload();
    }
    async function deleteReport(id: number) {
      if (!confirm('Delete this saved report?')) return;
      await fetch('/api/dashboard/reports', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
      location.reload();
    }
  </script>
</DashboardLayout>
