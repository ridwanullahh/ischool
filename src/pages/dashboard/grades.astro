---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { grades, students, courses } from '../../lib/db/schema.js';
import { eq, desc, sql } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/auth/login');
const schoolId = getUserSchoolId(user.id);

let records: any[] = [];
let allStudents: any[] = [];
let allCourses: any[] = [];
let stats = { total: 0, avgScore: 0 };

if (schoolId) {
  const db = getDb();
  allStudents = db.select().from(students).where(eq(students.schoolId, schoolId)).all();
  allCourses = db.select().from(courses).where(eq(courses.schoolId, schoolId)).all();
  records = db.select({
    id: grades.id, studentId: grades.studentId, courseId: grades.courseId,
    term: grades.term, academicYear: grades.academicYear, category: grades.category,
    score: grades.score, maxScore: grades.maxScore, grade: grades.grade, comment: grades.comment,
    createdAt: grades.createdAt,
    studentName: sql`${students.firstName} || ' ' || ${students.lastName}`.as('student_name'),
    courseTitle: courses.title,
  }).from(grades)
    .leftJoin(students, eq(grades.studentId, students.id))
    .leftJoin(courses, eq(grades.courseId, courses.id))
    .where(eq(grades.schoolId, schoolId))
    .orderBy(desc(grades.createdAt)).limit(200).all();

  const scored = records.filter(r => r.score !== null && r.maxScore !== null);
  stats = {
    total: records.length,
    avgScore: scored.length > 0 ? Math.round(scored.reduce((sum, r) => sum + ((r.score / r.maxScore) * 100), 0) / scored.length) : 0,
  };
}
---

<DashboardLayout title="Grades - iSchool">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <div><h2 class="text-2xl font-bold text-gray-900">Grades</h2><p class="text-sm text-gray-500 mt-1">Student grades and gradebook</p></div>
      <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 font-medium text-sm">+ Add Grade</button>
      <button onclick="exportCsv('grades')" class="bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700 font-medium text-sm">Export CSV</button>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Total Records</p><p class="text-2xl font-bold">{stats.total}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Average Score</p><p class="text-2xl font-bold text-primary-600">{stats.avgScore}%</p></div>
    </div>
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="p-4 border-b"><input type="text" id="searchInput" placeholder="Search..." class="border rounded-lg px-3 py-2 text-sm w-full" oninput="filterTable()" /></div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm" id="dataTable">
          <thead class="bg-gray-50"><tr>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Student</th><th class="px-4 py-3 text-left font-medium text-gray-600">Course</th>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Term</th><th class="px-4 py-3 text-left font-medium text-gray-600">Score</th>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Grade</th><th class="px-4 py-3 text-left font-medium text-gray-600">Actions</th>
          </tr></thead>
          <tbody class="divide-y">
            {records.length === 0 && <tr><td colspan="6" class="px-4 py-8 text-center text-gray-500">No grades recorded</td></tr>}
            {records.map(r => (
              <tr data-search={`${r.studentName} ${r.courseTitle || ''}`.toLowerCase()}>
                <td class="px-4 py-3 font-medium">{r.studentName}</td>
                <td class="px-4 py-3">{r.courseTitle || '-'}</td>
                <td class="px-4 py-3">{r.term || '-'} {r.academicYear ? `(${r.academicYear})` : ''}</td>
                <td class="px-4 py-3">{r.score !== null ? `${r.score}/${r.maxScore}` : '-'}</td>
                <td class="px-4 py-3"><span class="px-2 py-1 rounded-full text-xs font-medium bg-primary-100 text-primary-700">{r.grade || '-'}</span></td>
                <td class="px-4 py-3 flex gap-2">
                  <button onclick={`editRecord(${JSON.stringify(r).replace(/"/g, '&quot;')})`} class="text-primary-600 text-xs font-medium">Edit</button>
                  <button onclick={`deleteRecord(${r.id})`} class="text-red-600 text-xs font-medium">Delete</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="addModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl p-6 w-full max-w-md mx-4">
      <h3 class="text-lg font-bold mb-4" id="modalTitle">Add Grade</h3>
      <form onsubmit="submitForm(event)">
        <input type="hidden" id="editId" value="" />
        <div class="space-y-3">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Student</label>
            <select id="studentId" required class="w-full border rounded-lg px-3 py-2 text-sm">
              <option value="">Select</option>{allStudents.map(s => <option value={s.id}>{s.firstName} {s.lastName}</option>)}
            </select></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Course</label>
            <select id="courseId" class="w-full border rounded-lg px-3 py-2 text-sm">
              <option value="">None</option>{allCourses.map(c => <option value={c.id}>{c.title}</option>)}
            </select></div>
          <div class="grid grid-cols-2 gap-3">
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Score</label>
              <input type="number" id="score" class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Max Score</label>
              <input type="number" id="maxScore" class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Grade Letter</label>
              <input type="text" id="gradeLetter" class="w-full border rounded-lg px-3 py-2 text-sm" placeholder="e.g., A+" /></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
              <input type="text" id="category" class="w-full border rounded-lg px-3 py-2 text-sm" placeholder="e.g., Exam" /></div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Term</label>
              <input type="text" id="term" class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Academic Year</label>
              <input type="text" id="academicYear" class="w-full border rounded-lg px-3 py-2 text-sm" value="2025-2026" /></div>
          </div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Comment</label>
            <input type="text" id="comment" class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="px-4 py-2 border rounded-lg text-sm">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg text-sm hover:bg-primary-700">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function filterTable() {
      const s = (document.getElementById('searchInput') as HTMLInputElement).value.toLowerCase();
      document.querySelectorAll('#dataTable tbody tr[data-search]').forEach(r => { (r as HTMLElement).style.display = !s || (r as HTMLElement).dataset.search!.includes(s) ? '' : 'none'; });
    }
    function editRecord(r: any) {
      (document.getElementById('editId') as HTMLInputElement).value = String(r.id);
      (document.getElementById('studentId') as HTMLSelectElement).value = String(r.studentId || '');
      (document.getElementById('courseId') as HTMLSelectElement).value = String(r.courseId || '');
      (document.getElementById('score') as HTMLInputElement).value = r.score !== null ? String(r.score) : '';
      (document.getElementById('maxScore') as HTMLInputElement).value = r.maxScore !== null ? String(r.maxScore) : '';
      (document.getElementById('gradeLetter') as HTMLInputElement).value = r.grade || '';
      (document.getElementById('category') as HTMLInputElement).value = r.category || '';
      (document.getElementById('term') as HTMLInputElement).value = r.term || '';
      (document.getElementById('academicYear') as HTMLInputElement).value = r.academicYear || '';
      (document.getElementById('comment') as HTMLInputElement).value = r.comment || '';
      document.getElementById('modalTitle')!.textContent = 'Edit Grade';
      document.getElementById('addModal')!.classList.remove('hidden');
    }
    async function submitForm(e: Event) {
      e.preventDefault();
      const editId = (document.getElementById('editId') as HTMLInputElement).value;
      const body: any = {
        studentId: parseInt((document.getElementById('studentId') as HTMLSelectElement).value),
        courseId: (document.getElementById('courseId') as HTMLSelectElement).value ? parseInt((document.getElementById('courseId') as HTMLSelectElement).value) : null,
        score: (document.getElementById('score') as HTMLInputElement).value ? parseInt((document.getElementById('score') as HTMLInputElement).value) : null,
        maxScore: (document.getElementById('maxScore') as HTMLInputElement).value ? parseInt((document.getElementById('maxScore') as HTMLInputElement).value) : null,
        grade: (document.getElementById('gradeLetter') as HTMLInputElement).value || null,
        category: (document.getElementById('category') as HTMLInputElement).value || null,
        term: (document.getElementById('term') as HTMLInputElement).value || null,
        academicYear: (document.getElementById('academicYear') as HTMLInputElement).value || null,
        comment: (document.getElementById('comment') as HTMLInputElement).value || null,
      };
      const method = editId ? 'PUT' : 'POST';
      if (editId) body.id = parseInt(editId);
      await fetch('/api/dashboard/grades', { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      location.reload();
    }
    async function deleteRecord(id: number) {
      if (!confirm('Delete this grade?')) return;
      await fetch('/api/dashboard/grades', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
      location.reload();
    }
  </script>
</DashboardLayout>
