---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getDb } from '../../lib/db/index.js';
import { liveClassRooms, schoolMembers } from '../../lib/db/schema.js';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const db = getDb();
const membership = db.select().from(schoolMembers).where(eq(schoolMembers.userId, user.id)).get();
const schoolId = membership?.schoolId;

const rooms = schoolId ? db.select().from(liveClassRooms).where(eq(liveClassRooms.schoolId, schoolId)).orderBy(desc(liveClassRooms.createdAt)).all() : [];
const scheduledCount = rooms.filter((r: any) => r.status === 'scheduled').length;
const liveCount = rooms.filter((r: any) => r.status === 'live').length;
const endedCount = rooms.filter((r: any) => r.status === 'ended').length;
---

<DashboardLayout title="Live Classes - iSchool">
  <div class="space-y-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">Live Classes</h2>
        <p class="text-sm text-gray-500 mt-1">Manage virtual classrooms and live sessions</p>
      </div>
      <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 font-medium">+ Schedule Class</button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div class="bg-white rounded-lg shadow p-5"><div class="text-sm text-gray-500">Total Classes</div><div class="text-2xl font-bold text-gray-900 mt-1">{rooms.length}</div></div>
      <div class="bg-white rounded-lg shadow p-5"><div class="text-sm text-gray-500">Scheduled</div><div class="text-2xl font-bold text-blue-600 mt-1">{scheduledCount}</div></div>
      <div class="bg-white rounded-lg shadow p-5"><div class="text-sm text-gray-500">Live Now</div><div class="text-2xl font-bold text-green-600 mt-1">{liveCount}</div></div>
      <div class="bg-white rounded-lg shadow p-5"><div class="text-sm text-gray-500">Ended</div><div class="text-2xl font-bold text-gray-600 mt-1">{endedCount}</div></div>
    </div>

    <div class="bg-white rounded-lg shadow">
      <div class="p-4 border-b border-gray-200 flex flex-col sm:flex-row gap-3 justify-between items-center">
        <h3 class="text-lg font-semibold">All Classes</h3>
        <div class="flex gap-2">
          <input id="searchRooms" type="text" placeholder="Search classes..." class="px-3 py-2 border border-gray-300 rounded-lg" />
          <select id="statusFilter" class="px-3 py-2 border border-gray-300 rounded-lg">
            <option value="">All Statuses</option>
            <option value="scheduled">Scheduled</option><option value="live">Live</option>
            <option value="ended">Ended</option><option value="cancelled">Cancelled</option>
          </select>
        </div>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Scheduled</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Duration</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Participants</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            {rooms.length === 0 ? (
              <tr><td colspan="6" class="px-6 py-8 text-center text-gray-500">No live classes scheduled.</td></tr>
            ) : (
              rooms.map((room: any) => (
                <tr class="hover:bg-gray-50 room-row" data-title={room.title.toLowerCase()} data-status={room.status}>
                  <td class="px-6 py-4 text-sm font-medium text-gray-900">{room.title}</td>
                  <td class="px-6 py-4">
                    <span class={`px-2 py-1 text-xs font-medium rounded ${room.status === 'live' ? 'bg-green-100 text-green-700 animate-pulse' : room.status === 'scheduled' ? 'bg-blue-100 text-blue-700' : room.status === 'ended' ? 'bg-gray-100 text-gray-700' : 'bg-red-100 text-red-700'}`}>
                      {room.status === 'live' ? '● LIVE' : room.status}
                    </span>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-600">{room.scheduledStart || '-'}</td>
                  <td class="px-6 py-4 text-sm text-gray-600">{room.duration ? room.duration + ' min' : '-'}</td>
                  <td class="px-6 py-4 text-sm text-gray-600">{room.maxParticipants}</td>
                  <td class="px-6 py-4 text-sm flex gap-2">
                    {room.status === 'scheduled' && (
                      <button onclick={`startClass(${room.id})`} class="text-green-600 hover:text-green-700 font-medium">Start</button>
                    )}
                    {room.status === 'live' && (
                      <>
                        <a href={`/dashboard/live-class/${room.id}`} class="text-primary-600 hover:text-primary-700 font-medium">Join</a>
                        <button onclick={`endClass(${room.id})`} class="text-orange-600 hover:text-orange-700">End</button>
                      </>
                    )}
                    <button onclick={`viewClass(${room.id})`} class="text-gray-600 hover:text-gray-700">Details</button>
                    <button onclick={`confirmDelete(${room.id}, '${room.title.replace(/'/g, "\\'")}')`} class="text-red-600 hover:text-red-700">Delete</button>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Schedule Class Modal -->
  <div id="addModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
    <div class="bg-white rounded-xl shadow-lg p-6 w-full max-w-lg mx-4">
      <h3 class="text-lg font-bold mb-4">Schedule Live Class</h3>
      <form id="classForm" class="space-y-3">
        <input id="f_title" type="text" placeholder="Class Title *" class="w-full px-3 py-2 border border-gray-300 rounded-lg" required />
        <textarea id="f_desc" placeholder="Description" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg"></textarea>
        <div class="grid grid-cols-2 gap-3">
          <input id="f_start" type="datetime-local" class="px-3 py-2 border border-gray-300 rounded-lg" />
          <input id="f_duration" type="number" placeholder="Duration (min)" value="60" class="px-3 py-2 border border-gray-300 rounded-lg" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <input id="f_maxParticipants" type="number" placeholder="Max participants" value="100" class="px-3 py-2 border border-gray-300 rounded-lg" />
          <select id="f_provider" class="px-3 py-2 border border-gray-300 rounded-lg">
            <option value="builtin">Built-in</option>
            <option value="zoom">Zoom</option>
            <option value="google_meet">Google Meet</option>
            <option value="external">External Link</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <input id="f_recurring" type="checkbox" class="rounded" />
          <label for="f_recurring" class="text-sm text-gray-700">Recurring class</label>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="submit" class="flex-1 bg-primary-600 text-white py-2 rounded-lg hover:bg-primary-700 font-medium">Schedule</button>
          <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Class Detail Modal -->
  <div id="detailModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
    <div class="bg-white rounded-xl shadow-lg p-6 w-full max-w-lg mx-4">
      <div class="flex justify-between items-start mb-4">
        <h3 id="detailTitle" class="text-lg font-bold"></h3>
        <button onclick="document.getElementById('detailModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl">&times;</button>
      </div>
      <div id="detailContent" class="space-y-3"></div>
    </div>
  </div>

  <script>
    const searchInput = document.getElementById('searchRooms') as HTMLInputElement;
    const statusSelect = document.getElementById('statusFilter') as HTMLSelectElement;

    function filterRows() {
      const s = searchInput.value.toLowerCase();
      const st = statusSelect.value;
      document.querySelectorAll('.room-row').forEach((row: any) => {
        const matchSearch = !s || row.dataset.title?.includes(s);
        const matchStatus = !st || row.dataset.status === st;
        row.style.display = matchSearch && matchStatus ? '' : 'none';
      });
    }
    searchInput?.addEventListener('input', filterRows);
    statusSelect?.addEventListener('change', filterRows);

    async function startClass(id: number) {
      if (!confirm('Start this live class now?')) return;
      const res = await fetch('/api/dashboard/live-classes', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'start', roomId: id }),
      });
      if (res.ok) location.reload();
      else alert('Failed to start class');
    }

    async function endClass(id: number) {
      if (!confirm('End this live class?')) return;
      const res = await fetch('/api/dashboard/live-classes', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'end', roomId: id }),
      });
      if (res.ok) location.reload();
    }

    async function viewClass(id: number) {
      const res = await fetch(`/api/dashboard/live-classes?action=detail&id=${id}`);
      const data = await res.json();
      document.getElementById('detailTitle')!.textContent = data.room.title;
      document.getElementById('detailContent')!.innerHTML = `
        <p class="text-sm text-gray-600">${data.room.description || 'No description'}</p>
        <div class="grid grid-cols-2 gap-2 text-sm">
          <div><span class="text-gray-500">Status:</span> <span class="font-medium">${data.room.status}</span></div>
          <div><span class="text-gray-500">Duration:</span> <span class="font-medium">${data.room.duration || 60} min</span></div>
          <div><span class="text-gray-500">Max Participants:</span> <span class="font-medium">${data.room.maxParticipants}</span></div>
          <div><span class="text-gray-500">Provider:</span> <span class="font-medium">${data.room.meetingProvider}</span></div>
          <div><span class="text-gray-500">Scheduled:</span> <span class="font-medium">${data.room.scheduledStart || '-'}</span></div>
          ${data.room.recordingUrl ? `<div><span class="text-gray-500">Recording:</span> <a href="${data.room.recordingUrl}" class="text-primary-600">View</a></div>` : ''}
        </div>
        <div class="pt-2"><span class="text-gray-500 text-sm">Chat messages:</span> <span class="font-medium text-sm">${data.messages.length}</span></div>
        <div><span class="text-gray-500 text-sm">Polls:</span> <span class="font-medium text-sm">${data.polls.length}</span></div>
      `;
      document.getElementById('detailModal')!.classList.remove('hidden');
    }

    document.getElementById('classForm')?.addEventListener('submit', async (e: Event) => {
      e.preventDefault();
      const startVal = (document.getElementById('f_start') as HTMLInputElement).value;
      try {
        const res = await fetch('/api/dashboard/live-classes', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            title: (document.getElementById('f_title') as HTMLInputElement).value,
            description: (document.getElementById('f_desc') as HTMLTextAreaElement).value,
            scheduledStart: startVal || null,
            duration: parseInt((document.getElementById('f_duration') as HTMLInputElement).value) || 60,
            maxParticipants: parseInt((document.getElementById('f_maxParticipants') as HTMLInputElement).value) || 100,
            meetingProvider: (document.getElementById('f_provider') as HTMLSelectElement).value,
            isRecurring: (document.getElementById('f_recurring') as HTMLInputElement).checked,
          }),
        });
        if (res.ok) location.reload();
        else alert('Failed to schedule class');
      } catch (e) { alert('Error scheduling class'); }
    });

    async function confirmDelete(id: number, title: string) {
      if (!confirm(`Delete class "${title}"?`)) return;
      try {
        const res = await fetch('/api/dashboard/live-classes', {
          method: 'DELETE', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (res.ok) location.reload();
      } catch (e) { alert('Error deleting class'); }
    }
  </script>
</DashboardLayout>
