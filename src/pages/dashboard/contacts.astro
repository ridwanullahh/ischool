---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Input from '../../components/ui/Input.astro';
import Button from '../../components/ui/Button.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { contactInfo, contactSubmissions } from '../../lib/db/schema.js';
import { eq, asc, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
const schoolId = getUserSchoolId(user.id);
const db = getDb();

const contacts = schoolId ? db.select().from(contactInfo).where(eq(contactInfo.schoolId, schoolId)).orderBy(asc(contactInfo.sortOrder)).all() : [];
const submissions = schoolId ? db.select().from(contactSubmissions).where(eq(contactSubmissions.schoolId, schoolId)).orderBy(desc(contactSubmissions.createdAt)).limit(10).all().map(sub => ({
  ...sub,
  parsedData: sub.data as Record<string, string>,
})) : [];
const success = Astro.url.searchParams.get('success');
---

<DashboardLayout title="Contacts - iSchool">
  {success && (
    <div class="mb-6 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Contact info saved successfully.</div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">Contact Information</h2>
      <form method="POST" action="/api/dashboard/contacts" class="space-y-4">
        <input type="hidden" name="action" value="bulkUpdate" />
        <div id="contacts-container" class="space-y-3">
          {contacts.length > 0 ? contacts.map((c, i) => (
            <div class="contact-row grid grid-cols-12 gap-2 items-end p-3 bg-gray-50 rounded-lg relative">
              <div class="col-span-3">
                <label class="block text-xs font-medium text-gray-500 mb-1">Type</label>
                <select name={`contact_type_${i}`} class="block w-full rounded-lg border border-gray-300 px-2 py-2 text-sm">
                  <option value="general" selected={c.type === 'general'}>General</option>
                  <option value="admissions" selected={c.type === 'admissions'}>Admissions</option>
                  <option value="head_office" selected={c.type === 'head_office'}>Head Office</option>
                </select>
              </div>
              <div class="col-span-4">
                <label class="block text-xs font-medium text-gray-500 mb-1">Label</label>
                <input type="text" name={`contact_label_${i}`} value={c.label} class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
              </div>
              <div class="col-span-4">
                <label class="block text-xs font-medium text-gray-500 mb-1">Value</label>
                <input type="text" name={`contact_value_${i}`} value={c.value} class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
              </div>
              <div class="col-span-1">
                <button type="button" onclick="this.closest('.contact-row').remove()" class="text-gray-400 hover:text-red-500 mt-5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
              </div>
            </div>
          )) : (
            <div class="contact-row grid grid-cols-12 gap-2 items-end p-3 bg-gray-50 rounded-lg">
              <div class="col-span-3">
                <label class="block text-xs font-medium text-gray-500 mb-1">Type</label>
                <select name="contact_type_0" class="block w-full rounded-lg border border-gray-300 px-2 py-2 text-sm">
                  <option value="general">General</option>
                  <option value="admissions">Admissions</option>
                  <option value="head_office">Head Office</option>
                </select>
              </div>
              <div class="col-span-4">
                <label class="block text-xs font-medium text-gray-500 mb-1">Label</label>
                <input type="text" name="contact_label_0" placeholder="Email" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
              </div>
              <div class="col-span-4">
                <label class="block text-xs font-medium text-gray-500 mb-1">Value</label>
                <input type="text" name="contact_value_0" placeholder="info@school.edu" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
              </div>
              <div class="col-span-1">
                <button type="button" onclick="this.closest('.contact-row').remove()" class="text-gray-400 hover:text-red-500 mt-5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
              </div>
            </div>
          )}
        </div>
        <button type="button" id="add-contact" class="text-sm text-primary-600 hover:text-primary-700 font-medium">+ Add Contact</button>
        <Button type="submit" full>Save Contact Info</Button>
      </form>
    </div>

    <div class="bg-white rounded-xl border border-gray-200">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-base font-semibold text-gray-900">Recent Submissions ({submissions.length})</h2>
      </div>
      <div class="divide-y divide-gray-100 max-h-96 overflow-y-auto">
        {submissions.length === 0 && <p class="p-6 text-sm text-gray-500 text-center">No submissions yet.</p>}
        {submissions.map(sub => {
          const data = sub.parsedData;
          return (
            <div class="px-6 py-4">
              <div class="flex items-center justify-between mb-1">
                <span class:list={[
                  'text-xs font-medium px-2 py-0.5 rounded',
                  sub.formType === 'admissions' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-600'
                ]}>
                  {sub.formType}
                </span>
                <span class:list={[
                  'text-xs px-2 py-0.5 rounded',
                  sub.status === 'new' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'
                ]}>
                  {sub.status}
                </span>
              </div>
              {data.name && <p class="text-sm font-medium text-gray-900">{data.name}</p>}
              {data.email && <p class="text-xs text-gray-500">{data.email}</p>}
              {data.message && <p class="text-xs text-gray-500 mt-1 line-clamp-2">{data.message}</p>}
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <script>
    let contactIdx = document.querySelectorAll('.contact-row').length;
    document.getElementById('add-contact')?.addEventListener('click', () => {
      const container = document.getElementById('contacts-container');
      const row = document.createElement('div');
      row.className = 'contact-row grid grid-cols-12 gap-2 items-end p-3 bg-gray-50 rounded-lg';
      row.innerHTML = `
        <div class="col-span-3">
          <label class="block text-xs font-medium text-gray-500 mb-1">Type</label>
          <select name="contact_type_${contactIdx}" class="block w-full rounded-lg border border-gray-300 px-2 py-2 text-sm">
            <option value="general">General</option>
            <option value="admissions">Admissions</option>
            <option value="head_office">Head Office</option>
          </select>
        </div>
        <div class="col-span-4">
          <label class="block text-xs font-medium text-gray-500 mb-1">Label</label>
          <input type="text" name="contact_label_${contactIdx}" placeholder="Email" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div class="col-span-4">
          <label class="block text-xs font-medium text-gray-500 mb-1">Value</label>
          <input type="text" name="contact_value_${contactIdx}" placeholder="info@school.edu" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div class="col-span-1">
          <button type="button" onclick="this.closest('.contact-row').remove()" class="text-gray-400 hover:text-red-500 mt-5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>`;
      container?.appendChild(row);
      contactIdx++;
    });
  </script>
</DashboardLayout>
