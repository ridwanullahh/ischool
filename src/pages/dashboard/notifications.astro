---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { notifications } from '../../lib/db/schema.js';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/auth/login');
const schoolId = getUserSchoolId(user.id);

let records: any[] = [];
let stats = { total: 0, unread: 0, alerts: 0 };

if (schoolId) {
  const db = getDb();
  records = db.select().from(notifications).where(eq(notifications.schoolId, schoolId)).orderBy(desc(notifications.createdAt)).limit(100).all();
  stats = { total: records.length, unread: records.filter(r => !r.isRead).length, alerts: records.filter(r => r.type === 'alert').length };
}
---

<DashboardLayout title="Notifications - iSchool">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <div><h2 class="text-2xl font-bold text-gray-900">Notifications</h2><p class="text-sm text-gray-500 mt-1">Send and manage notifications</p></div>
      <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 font-medium text-sm">+ Send Notification</button>
      <button onclick="exportCsv('notifications')" class="bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700 font-medium text-sm">Export CSV</button>
    </div>
    <div class="grid grid-cols-3 gap-4">
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Total</p><p class="text-2xl font-bold">{stats.total}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Unread</p><p class="text-2xl font-bold text-blue-600">{stats.unread}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Alerts</p><p class="text-2xl font-bold text-red-600">{stats.alerts}</p></div>
    </div>
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="divide-y" id="notifList">
        {records.length === 0 && <div class="p-8 text-center text-gray-500">No notifications</div>}
        {records.map(r => (
          <div class={`p-4 flex items-start justify-between ${!r.isRead ? 'bg-blue-50/50' : ''}`}>
            <div class="flex items-start gap-3">
              <span class={`mt-1 w-2 h-2 rounded-full flex-shrink-0 ${r.type === 'alert' ? 'bg-red-500' : r.type === 'warning' ? 'bg-yellow-500' : r.type === 'success' ? 'bg-green-500' : 'bg-blue-500'}`}></span>
              <div>
                <p class="text-sm font-medium">{r.title}</p>
                <p class="text-sm text-gray-600 mt-1">{r.body || ''}</p>
                <p class="text-xs text-gray-400 mt-1">{new Date(r.createdAt).toLocaleString()} · {r.channel}</p>
              </div>
            </div>
            <button onclick={`deleteNotif(${r.id})`} class="text-red-600 text-xs">Delete</button>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div id="addModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl p-6 w-full max-w-md mx-4">
      <h3 class="text-lg font-bold mb-4">Send Notification</h3>
      <form onsubmit="sendNotif(event)">
        <div class="space-y-3">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
            <input type="text" id="title" required class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Body</label>
            <textarea id="body" rows="3" class="w-full border rounded-lg px-3 py-2 text-sm"></textarea></div>
          <div class="grid grid-cols-2 gap-3">
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
              <select id="type" class="w-full border rounded-lg px-3 py-2 text-sm">
                <option value="info">Info</option><option value="success">Success</option>
                <option value="warning">Warning</option><option value="alert">Alert</option>
              </select></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Channel</label>
              <select id="channel" class="w-full border rounded-lg px-3 py-2 text-sm">
                <option value="in_app">In-App</option><option value="email">Email</option>
                <option value="sms">SMS</option><option value="push">Push</option>
              </select></div>
          </div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Link (optional)</label>
            <input type="text" id="link" class="w-full border rounded-lg px-3 py-2 text-sm" placeholder="/dashboard/students" /></div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="px-4 py-2 border rounded-lg text-sm">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg text-sm hover:bg-primary-700">Send</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    async function sendNotif(e: Event) {
      e.preventDefault();
      await fetch('/api/dashboard/notifications', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({
        title: (document.getElementById('title') as HTMLInputElement).value,
        body: (document.getElementById('body') as HTMLTextAreaElement).value,
        type: (document.getElementById('type') as HTMLSelectElement).value,
        channel: (document.getElementById('channel') as HTMLSelectElement).value,
        link: (document.getElementById('link') as HTMLInputElement).value || null,
      })});
      location.reload();
    }
    async function deleteNotif(id: number) {
      if (!confirm('Delete this notification?')) return;
      await fetch('/api/dashboard/notifications', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
      location.reload();
    }
  </script>
</DashboardLayout>
