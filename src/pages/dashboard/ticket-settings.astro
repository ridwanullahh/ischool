---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getDb } from '../../lib/db/index.js';
import { schoolTicketCategories, schoolMembers, aiSettings } from '../../lib/db/schema.js';
import { eq, asc } from 'drizzle-orm';

const user = Astro.locals.user!;
const db = getDb();
const membership = db.select().from(schoolMembers).where(eq(schoolMembers.userId, user.id)).get();
const schoolId = membership?.schoolId;
if (!schoolId) return Astro.redirect('/dashboard');

const categories = db.select().from(schoolTicketCategories)
  .where(eq(schoolTicketCategories.schoolId, schoolId))
  .orderBy(asc(schoolTicketCategories.sortOrder)).all();

const slaSetting = db.select().from(aiSettings)
  .where(eq(aiSettings.schoolId, schoolId))
  .all()
  .find(s => s.key === 'ticket_sla_hours');

const retentionSetting = db.select().from(aiSettings)
  .where(eq(aiSettings.schoolId, schoolId))
  .all()
  .find(s => s.key === 'conversation_retention_days');

const success = Astro.url.searchParams.get('success');
---

<DashboardLayout title="Ticket Settings - iSchool">
  {success && (
    <div class="mb-6 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Settings saved successfully.</div>
  )}

  <div class="space-y-6">
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-base font-semibold text-gray-900">Ticket Categories</h2>
          <p class="text-sm text-gray-500 mt-1">Manage support ticket categories visible to staff and public</p>
        </div>
        <button onclick="document.getElementById('addCatModal').classList.remove('hidden')" class="bg-primary-600 text-white px-3 py-2 rounded-lg hover:bg-primary-700 font-medium text-sm">+ Add Category</button>
      </div>

      {categories.length === 0 ? (
        <p class="text-sm text-gray-500 py-8 text-center">No categories yet. Add one to get started.</p>
      ) : (
        <div class="divide-y divide-gray-100">
          {categories.map(cat => (
            <div class="flex items-center justify-between py-3">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-primary-50 flex items-center justify-center text-primary-600">
                  {cat.icon || '📁'}
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-900">{cat.name}</p>
                  {cat.description && <p class="text-xs text-gray-500">{cat.description}</p>}
                </div>
              </div>
              <div class="flex items-center gap-3">
                <span class:list={['text-xs px-2 py-0.5 rounded-full', cat.isPublic ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-500']}>
                  {cat.isPublic ? 'Public' : 'Internal'}
                </span>
                <button onclick={`deleteCategory(${cat.id})`} class="text-red-500 hover:text-red-700 text-xs font-medium">Delete</button>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">SLA & Retention Settings</h2>
      <form id="settingsForm" class="space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">SLA Response Time (hours)</label>
            <input type="number" name="slaHours" value={slaSetting?.value || 24} min={1} class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:border-primary-600 focus:outline-none" />
            <p class="text-xs text-gray-500 mt-1">Target time for first response to a ticket</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Conversation Retention (days)</label>
            <input type="number" name="retentionDays" value={retentionSetting?.value || 90} min={1} class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:border-primary-600 focus:outline-none" />
            <p class="text-xs text-gray-500 mt-1">Auto-delete AI conversations older than this</p>
          </div>
        </div>
        <div id="settingsMsg" class="hidden text-sm"></div>
        <button type="submit" class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 font-medium text-sm">Save Settings</button>
      </form>
    </div>
  </div>

  <div id="addCatModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl w-full max-w-md mx-4">
      <div class="flex items-center justify-between p-4 border-b border-gray-200">
        <h3 class="text-lg font-semibold">Add Category</h3>
        <button onclick="document.getElementById('addCatModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
      </div>
      <form id="addCatForm" class="p-6 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
          <input name="name" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="e.g. Technical Support" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
          <input name="description" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="Brief description" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Icon (emoji)</label>
            <input name="icon" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="📁" maxlength={2} />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Visibility</label>
            <select name="isPublic" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
              <option value="true">Public (visible to customers)</option>
              <option value="false">Internal only</option>
            </select>
          </div>
        </div>
        <div id="addCatError" class="text-red-600 text-sm hidden"></div>
        <div class="flex justify-end gap-3 pt-4 border-t border-gray-200">
          <button type="button" onclick="document.getElementById('addCatModal').classList.add('hidden')" class="px-4 py-2 text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700">Add Category</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    document.getElementById('settingsForm')?.addEventListener('submit', async (e: Event) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const fd = new FormData(form);
      const msgEl = document.getElementById('settingsMsg')!;
      try {
        const res = await fetch('/api/dashboard/tickets', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'save_settings', slaHours: Number(fd.get('slaHours')), retentionDays: Number(fd.get('retentionDays')) }),
        });
        msgEl.classList.remove('hidden');
        if (res.ok) {
          msgEl.classList.add('text-green-700');
          msgEl.textContent = 'Settings saved successfully.';
        } else {
          msgEl.classList.add('text-red-600');
          msgEl.textContent = 'Failed to save settings.';
        }
      } catch {
        msgEl.classList.remove('hidden');
        msgEl.classList.add('text-red-600');
        msgEl.textContent = 'Network error.';
      }
    });

    document.getElementById('addCatForm')?.addEventListener('submit', async (e: Event) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const fd = new FormData(form);
      const errEl = document.getElementById('addCatError')!;
      errEl.classList.add('hidden');
      try {
        const res = await fetch('/api/dashboard/tickets', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            action: 'add_category',
            name: fd.get('name'),
            description: fd.get('description'),
            icon: fd.get('icon'),
            isPublic: fd.get('isPublic') === 'true',
          }),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          errEl.textContent = data.error || 'Failed to add category';
          errEl.classList.remove('hidden');
        }
      } catch {
        errEl.textContent = 'Network error';
        errEl.classList.remove('hidden');
      }
    });

    async function deleteCategory(id: number) {
      if (!confirm('Delete this category?')) return;
      await fetch('/api/dashboard/tickets', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'delete_category', id }),
      });
      window.location.reload();
    }
  </script>
</DashboardLayout>
