---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Input from '../../components/ui/Input.astro';
import Button from '../../components/ui/Button.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { announcements } from '../../lib/db/schema.js';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
const schoolId = getUserSchoolId(user.id);
const db = getDb();

const items = schoolId ? db.select().from(announcements).where(eq(announcements.schoolId, schoolId)).orderBy(desc(announcements.createdAt)).all() : [];
const success = Astro.url.searchParams.get('success');
const editId = Astro.url.searchParams.get('edit');
const editing = editId ? items.find(i => i.id === Number(editId)) : null;
---

<DashboardLayout title="Announcements - iSchool">
  {success && (
    <div class="mb-6 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Announcement saved successfully.</div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <h2 class="text-base font-semibold text-gray-900 mb-4">{editing ? 'Edit' : 'New'} Announcement</h2>
        <form method="POST" action="/api/dashboard/announcements" class="space-y-4">
          {editing && <input type="hidden" name="id" value={editing.id} />}
          <Input label="Title" name="title" value={editing?.title || ''} placeholder="Announcement title" required />
          <Input label="Slug" name="slug" value={editing?.slug || ''} placeholder="announcement-url-slug" required />
          <Input label="Content" name="content" value={editing?.content || ''} placeholder="Announcement content..." rows={4} required />
          <Input label="Excerpt" name="excerpt" value={editing?.excerpt || ''} placeholder="Short summary for listing pages" />
          <Input label="Banner Image URL" name="bannerImageUrl" value={editing?.bannerImageUrl || ''} placeholder="https://..." />
          <div class="grid grid-cols-2 gap-3">
            <Input label="CTA Text" name="ctaText" value={editing?.ctaText || ''} placeholder="Learn More" />
            <Input label="CTA URL" name="ctaUrl" value={editing?.ctaUrl || ''} placeholder="/admissions" />
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" id="isPinned" name="isPinned" checked={editing?.isPinned || false} class="rounded border-gray-300" />
            <label for="isPinned" class="text-sm text-gray-700">Pin to top</label>
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" id="published" name="published" checked={editing ? editing.published : true} class="rounded border-gray-300" />
            <label for="published" class="text-sm text-gray-700">Published</label>
          </div>
          <Button type="submit" full>{editing ? 'Update' : 'Create'} Announcement</Button>
          {editing && (
            <a href="/dashboard/announcements" class="block text-center text-sm text-gray-500 hover:text-gray-700">Cancel Edit</a>
          )}
        </form>
      </div>
    </div>

    <div class="lg:col-span-2">
      <div class="bg-white rounded-xl border border-gray-200">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-base font-semibold text-gray-900">All Announcements ({items.length})</h2>
        </div>
        <div class="divide-y divide-gray-100">
          {items.length === 0 && <p class="p-6 text-sm text-gray-500 text-center">No announcements yet. Create your first one.</p>}
          {items.map(item => (
            <div class="px-6 py-4 flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="text-sm font-medium text-gray-900 truncate">{item.title}</h3>
                  {item.isPinned && <span class="text-xs bg-yellow-100 text-yellow-700 px-1.5 py-0.5 rounded">Pinned</span>}
                  {!item.published && <span class="text-xs bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded">Draft</span>}
                </div>
                <p class="text-sm text-gray-500 line-clamp-1">{item.content}</p>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <a href={`?edit=${item.id}`} class="text-xs text-primary-600 hover:text-primary-700">Edit</a>
                <form method="POST" action="/api/dashboard/announcements">
                  <input type="hidden" name="id" value={item.id} />
                  <input type="hidden" name="action" value="delete" />
                  <button type="submit" class="text-xs text-red-500 hover:text-red-700">Delete</button>
                </form>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>
