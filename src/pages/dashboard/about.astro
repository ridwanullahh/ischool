---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Input from '../../components/ui/Input.astro';
import Button from '../../components/ui/Button.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { aboutPages } from '../../lib/db/schema.js';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user!;
const schoolId = getUserSchoolId(user.id);
const db = getDb();

let about = null;
if (schoolId) {
  about = db.select().from(aboutPages).where(eq(aboutPages.schoolId, schoolId)).get();
}

const features: Array<{ title: string; description: string }> = Array.isArray(about?.features) ? about!.features as any : [];
const stats: Array<{ label: string; value: string }> = Array.isArray(about?.stats) ? about!.stats as any : [];
const success = Astro.url.searchParams.get('success');
---

<DashboardLayout title="About Page - iSchool">
  {success && (
    <div class="mb-6 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">About page saved successfully.</div>
  )}

  <form method="POST" action="/api/dashboard/about" class="space-y-8">
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">Mission & Vision</h2>
      <div class="space-y-5">
        <Input label="Mission Statement" name="mission" value={about?.mission || ''} placeholder="Our mission is to..." rows={3} />
        <Input label="Vision Statement" name="vision" value={about?.vision || ''} placeholder="We envision a world where..." rows={3} />
        <Input label="Value Proposition (Why Choose Us)" name="valueProposition" value={about?.valueProposition || ''} placeholder="What makes your school unique..." rows={3} />
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">Key Features</h2>
      <p class="text-sm text-gray-500 mb-4">Add up to 6 features that highlight your school.</p>
      <div id="features-container" class="space-y-4">
        {features.length > 0 ? features.map((f, i) => (
          <div class="feature-row grid grid-cols-1 sm:grid-cols-2 gap-4 p-4 bg-gray-50 rounded-lg relative">
            <input type="text" name={`feature_title_${i}`} value={f.title} placeholder="Feature title" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
            <input type="text" name={`feature_desc_${i}`} value={f.description} placeholder="Description" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
            <button type="button" onclick="this.closest('.feature-row').remove()" class="absolute top-2 right-2 text-gray-400 hover:text-red-500">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
        )) : (
          <div class="feature-row grid grid-cols-1 sm:grid-cols-2 gap-4 p-4 bg-gray-50 rounded-lg relative">
            <input type="text" name="feature_title_0" placeholder="Feature title" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
            <input type="text" name="feature_desc_0" placeholder="Description" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
            <button type="button" onclick="this.closest('.feature-row').remove()" class="absolute top-2 right-2 text-gray-400 hover:text-red-500">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
        )}
      </div>
      <button type="button" id="add-feature" class="mt-4 text-sm text-primary-600 hover:text-primary-700 font-medium">+ Add Feature</button>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">Statistics</h2>
      <p class="text-sm text-gray-500 mb-4">Add impressive numbers about your school.</p>
      <div id="stats-container" class="space-y-4">
        {stats.length > 0 ? stats.map((s, i) => (
          <div class="stat-row grid grid-cols-1 sm:grid-cols-2 gap-4 p-4 bg-gray-50 rounded-lg relative">
            <input type="text" name={`stat_label_${i}`} value={s.label} placeholder="Label (e.g., Students Enrolled)" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
            <input type="text" name={`stat_value_${i}`} value={s.value} placeholder="Value (e.g., 1,200+)" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
            <button type="button" onclick="this.closest('.stat-row').remove()" class="absolute top-2 right-2 text-gray-400 hover:text-red-500">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
        )) : (
          <div class="stat-row grid grid-cols-1 sm:grid-cols-2 gap-4 p-4 bg-gray-50 rounded-lg relative">
            <input type="text" name="stat_label_0" placeholder="Label (e.g., Students Enrolled)" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
            <input type="text" name="stat_value_0" placeholder="Value (e.g., 1,200+)" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
            <button type="button" onclick="this.closest('.stat-row').remove()" class="absolute top-2 right-2 text-gray-400 hover:text-red-500">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
        )}
      </div>
      <button type="button" id="add-stat" class="mt-4 text-sm text-primary-600 hover:text-primary-700 font-medium">+ Add Stat</button>
    </div>

    <Button type="submit">Save About Page</Button>
  </form>

  <script>
    let featureIdx = document.querySelectorAll('.feature-row').length;
    document.getElementById('add-feature')?.addEventListener('click', () => {
      const container = document.getElementById('features-container');
      const row = document.createElement('div');
      row.className = 'feature-row grid grid-cols-1 sm:grid-cols-2 gap-4 p-4 bg-gray-50 rounded-lg relative';
      row.innerHTML = `
        <input type="text" name="feature_title_${featureIdx}" placeholder="Feature title" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
        <input type="text" name="feature_desc_${featureIdx}" placeholder="Description" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
        <button type="button" onclick="this.closest('.feature-row').remove()" class="absolute top-2 right-2 text-gray-400 hover:text-red-500">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>`;
      container?.appendChild(row);
      featureIdx++;
    });

    let statIdx = document.querySelectorAll('.stat-row').length;
    document.getElementById('add-stat')?.addEventListener('click', () => {
      const container = document.getElementById('stats-container');
      const row = document.createElement('div');
      row.className = 'stat-row grid grid-cols-1 sm:grid-cols-2 gap-4 p-4 bg-gray-50 rounded-lg relative';
      row.innerHTML = `
        <input type="text" name="stat_label_${statIdx}" placeholder="Label (e.g., Students Enrolled)" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
        <input type="text" name="stat_value_${statIdx}" placeholder="Value (e.g., 1,200+)" class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
        <button type="button" onclick="this.closest('.stat-row').remove()" class="absolute top-2 right-2 text-gray-400 hover:text-red-500">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>`;
      container?.appendChild(row);
      statIdx++;
    });
  </script>
</DashboardLayout>
