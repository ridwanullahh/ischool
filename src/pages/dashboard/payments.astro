---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { payments, invoices } from '../../lib/db/schema.js';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/auth/login');
const schoolId = getUserSchoolId(user.id);

let records: any[] = [];
let allInvoices: any[] = [];
let stats = { total: 0, totalAmount: 0, completed: 0, pending: 0 };

if (schoolId) {
  const db = getDb();
  allInvoices = db.select().from(invoices).where(eq(invoices.schoolId, schoolId)).all();
  records = db.select({
    id: payments.id, invoiceId: payments.invoiceId, amount: payments.amount,
    method: payments.method, reference: payments.reference, status: payments.status,
    notes: payments.notes, paidAt: payments.paidAt, createdAt: payments.createdAt,
    invoiceNumber: invoices.invoiceNumber,
  }).from(payments)
    .leftJoin(invoices, eq(payments.invoiceId, invoices.id))
    .where(eq(payments.schoolId, schoolId))
    .orderBy(desc(payments.paidAt)).all();
  stats = {
    total: records.length,
    totalAmount: records.filter(r => r.status === 'completed').reduce((s, r) => s + r.amount, 0),
    completed: records.filter(r => r.status === 'completed').length,
    pending: records.filter(r => r.status === 'pending').length,
  };
}
---

<DashboardLayout title="Payments - iSchool">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <div><h2 class="text-2xl font-bold text-gray-900">Payments</h2><p class="text-sm text-gray-500 mt-1">Track and manage payments</p></div>
      <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 font-medium text-sm">+ Record Payment</button>
      <button onclick="exportCsv('payments')" class="bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700 font-medium text-sm">Export CSV</button>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Total Payments</p><p class="text-2xl font-bold">{stats.total}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Total Received</p><p class="text-2xl font-bold text-green-600">${stats.totalAmount.toLocaleString()}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Completed</p><p class="text-2xl font-bold text-green-600">{stats.completed}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Pending</p><p class="text-2xl font-bold text-yellow-600">{stats.pending}</p></div>
    </div>
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50"><tr>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Invoice</th><th class="px-4 py-3 text-left font-medium text-gray-600">Amount</th>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Method</th><th class="px-4 py-3 text-left font-medium text-gray-600">Reference</th>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Status</th><th class="px-4 py-3 text-left font-medium text-gray-600">Date</th>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Actions</th>
          </tr></thead>
          <tbody class="divide-y">
            {records.length === 0 && <tr><td colspan="7" class="px-4 py-8 text-center text-gray-500">No payments recorded</td></tr>}
            {records.map(r => (
              <tr>
                <td class="px-4 py-3 font-medium">{r.invoiceNumber || `#${r.invoiceId}`}</td>
                <td class="px-4 py-3 font-medium text-green-700">${r.amount.toLocaleString()}</td>
                <td class="px-4 py-3 capitalize">{r.method.replace('_', ' ')}</td>
                <td class="px-4 py-3 text-gray-500">{r.reference || '-'}</td>
                <td class="px-4 py-3"><span class={`px-2 py-1 rounded-full text-xs font-medium ${r.status === 'completed' ? 'bg-green-100 text-green-700' : r.status === 'pending' ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700'}`}>{r.status}</span></td>
                <td class="px-4 py-3 text-gray-500">{r.paidAt ? new Date(r.paidAt).toLocaleDateString() : '-'}</td>
                <td class="px-4 py-3"><button onclick={`deleteRecord(${r.id})`} class="text-red-600 text-xs">Delete</button></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="addModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl p-6 w-full max-w-md mx-4">
      <h3 class="text-lg font-bold mb-4">Record Payment</h3>
      <form onsubmit="submitForm(event)">
        <div class="space-y-3">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Invoice</label>
            <select id="invoiceId" required class="w-full border rounded-lg px-3 py-2 text-sm">
              <option value="">Select</option>
              {allInvoices.filter(i => i.status !== 'paid' && i.status !== 'cancelled').map(i => <option value={i.id}>{i.invoiceNumber} - ${i.balance} balance</option>)}
            </select></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Amount</label>
            <input type="number" id="amount" required class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Method</label>
            <select id="method" required class="w-full border rounded-lg px-3 py-2 text-sm">
              <option value="cash">Cash</option><option value="bank_transfer">Bank Transfer</option>
              <option value="stripe">Stripe</option><option value="paystack">Paystack</option>
              <option value="flutterwave">Flutterwave</option><option value="paypal">PayPal</option>
              <option value="other">Other</option>
            </select></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Reference</label>
            <input type="text" id="reference" class="w-full border rounded-lg px-3 py-2 text-sm" placeholder="Transaction reference" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
            <input type="text" id="notes" class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="px-4 py-2 border rounded-lg text-sm">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg text-sm hover:bg-primary-700">Record</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    async function submitForm(e: Event) {
      e.preventDefault();
      await fetch('/api/dashboard/payments', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({
        invoiceId: parseInt((document.getElementById('invoiceId') as HTMLSelectElement).value),
        amount: parseInt((document.getElementById('amount') as HTMLInputElement).value),
        method: (document.getElementById('method') as HTMLSelectElement).value,
        reference: (document.getElementById('reference') as HTMLInputElement).value || null,
        notes: (document.getElementById('notes') as HTMLInputElement).value || null,
      })});
      location.reload();
    }
    async function deleteRecord(id: number) {
      if (!confirm('Delete this payment record?')) return;
      await fetch('/api/dashboard/payments', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
      location.reload();
    }
  </script>
</DashboardLayout>
