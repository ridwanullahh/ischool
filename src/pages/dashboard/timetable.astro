---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { timetableEntries, classes, courses, users } from '../../lib/db/schema.js';
import { eq, asc, sql } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/auth/login');
const schoolId = getUserSchoolId(user.id);

let entries: any[] = [];
let allClasses: any[] = [];
let allCourses: any[] = [];
let allTeachers: any[] = [];

if (schoolId) {
  const db = getDb();
  allClasses = db.select().from(classes).where(eq(classes.schoolId, schoolId)).all();
  allCourses = db.select().from(courses).where(eq(courses.schoolId, schoolId)).all();
  entries = db.select({
    id: timetableEntries.id, classId: timetableEntries.classId, courseId: timetableEntries.courseId,
    teacherId: timetableEntries.teacherId, dayOfWeek: timetableEntries.dayOfWeek,
    periodNumber: timetableEntries.periodNumber, startTime: timetableEntries.startTime,
    endTime: timetableEntries.endTime, room: timetableEntries.room,
    className: classes.name, courseTitle: courses.title, teacherName: users.name,
  }).from(timetableEntries)
    .leftJoin(classes, eq(timetableEntries.classId, classes.id))
    .leftJoin(courses, eq(timetableEntries.courseId, courses.id))
    .leftJoin(users, eq(timetableEntries.teacherId, users.id))
    .where(eq(timetableEntries.schoolId, schoolId))
    .orderBy(asc(timetableEntries.dayOfWeek), asc(timetableEntries.periodNumber)).all();
}

const days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
---

<DashboardLayout title="Timetable - iSchool">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <div><h2 class="text-2xl font-bold text-gray-900">Timetable</h2><p class="text-sm text-gray-500 mt-1">Manage class schedules</p></div>
      <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 font-medium text-sm">+ Add Entry</button>
      <button onclick="exportCsv('timetable')" class="bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700 font-medium text-sm">Export CSV</button>
    </div>

    <div class="bg-white rounded-lg shadow overflow-x-auto">
      <table class="w-full text-sm min-w-[800px]">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-3 py-3 text-left font-medium text-gray-600 w-20">Period</th>
            {days.slice(0, 5).map(day => <th class="px-3 py-3 text-left font-medium text-gray-600">{day}</th>)}
          </tr>
        </thead>
        <tbody class="divide-y">
          {[1, 2, 3, 4, 5, 6, 7, 8].map(period => (
            <tr>
              <td class="px-3 py-3 font-medium text-gray-600">Period {period}</td>
              {[1, 2, 3, 4, 5].map(day => {
                const entry = entries.find(e => e.dayOfWeek === day && e.periodNumber === period);
                return (
                  <td class="px-3 py-3">
                    {entry ? (
                      <div class="bg-primary-50 rounded-lg p-2 text-xs relative group">
                        <p class="font-medium text-primary-800">{entry.courseTitle || 'Free'}</p>
                        <p class="text-primary-600">{entry.className || ''}</p>
                        <p class="text-gray-500">{entry.startTime}-{entry.endTime}</p>
                        <p class="text-gray-400">{entry.teacherName || ''} {entry.room ? `| ${entry.room}` : ''}</p>
                        <div class="hidden group-hover:flex absolute top-1 right-1 gap-1">
                          <button onclick={`editEntry(${JSON.stringify(entry).replace(/"/g, '&quot;')})`} class="text-primary-600 bg-white rounded px-1 shadow text-xs">Edit</button>
                          <button onclick={`deleteEntry(${entry.id})`} class="text-red-600 bg-white rounded px-1 shadow text-xs">Del</button>
                        </div>
                      </div>
                    ) : (
                      <div class="border border-dashed border-gray-200 rounded-lg p-2 text-center text-xs text-gray-300 cursor-pointer hover:border-primary-300 hover:text-primary-400"
                        onclick={`quickAdd(${day}, ${period})`}>+ Add</div>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    {entries.length > 0 && (
      <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="p-4 border-b font-medium text-gray-700">All Entries ({entries.length})</div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-50"><tr>
              <th class="px-4 py-2 text-left font-medium text-gray-600">Day</th><th class="px-4 py-2 text-left font-medium text-gray-600">Period</th>
              <th class="px-4 py-2 text-left font-medium text-gray-600">Course</th><th class="px-4 py-2 text-left font-medium text-gray-600">Class</th>
              <th class="px-4 py-2 text-left font-medium text-gray-600">Teacher</th><th class="px-4 py-2 text-left font-medium text-gray-600">Time</th>
              <th class="px-4 py-2 text-left font-medium text-gray-600">Room</th>
            </tr></thead>
            <tbody class="divide-y">
              {entries.map(e => (
                <tr>
                  <td class="px-4 py-2">{days[e.dayOfWeek - 1] || `Day ${e.dayOfWeek}`}</td>
                  <td class="px-4 py-2">{e.periodNumber}</td><td class="px-4 py-2 font-medium">{e.courseTitle || '-'}</td>
                  <td class="px-4 py-2">{e.className || '-'}</td><td class="px-4 py-2">{e.teacherName || '-'}</td>
                  <td class="px-4 py-2">{e.startTime}-{e.endTime}</td><td class="px-4 py-2">{e.room || '-'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}
  </div>

  <div id="addModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl p-6 w-full max-w-md mx-4">
      <h3 class="text-lg font-bold mb-4" id="modalTitle">Add Timetable Entry</h3>
      <form onsubmit="submitForm(event)">
        <input type="hidden" id="editId" value="" />
        <div class="space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Day</label>
              <select id="dayOfWeek" required class="w-full border rounded-lg px-3 py-2 text-sm">
                {days.map((d, i) => <option value={i + 1}>{d}</option>)}
              </select></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Period</label>
              <input type="number" id="periodNumber" required min="1" max="12" class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
          </div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Course</label>
            <select id="courseId" class="w-full border rounded-lg px-3 py-2 text-sm">
              <option value="">None</option>{allCourses.map(c => <option value={c.id}>{c.title}</option>)}
            </select></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Class</label>
            <select id="classId" class="w-full border rounded-lg px-3 py-2 text-sm">
              <option value="">None</option>{allClasses.map(c => <option value={c.id}>{c.name}</option>)}
            </select></div>
          <div class="grid grid-cols-2 gap-3">
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Start Time</label>
              <input type="time" id="startTime" required class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">End Time</label>
              <input type="time" id="endTime" required class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
          </div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Room</label>
            <input type="text" id="room" class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="px-4 py-2 border rounded-lg text-sm">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg text-sm hover:bg-primary-700">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function quickAdd(day: number, period: number) {
      (document.getElementById('dayOfWeek') as HTMLSelectElement).value = String(day);
      (document.getElementById('periodNumber') as HTMLInputElement).value = String(period);
      document.getElementById('addModal')!.classList.remove('hidden');
    }
    function editEntry(e: any) {
      (document.getElementById('editId') as HTMLInputElement).value = String(e.id);
      (document.getElementById('dayOfWeek') as HTMLSelectElement).value = String(e.dayOfWeek);
      (document.getElementById('periodNumber') as HTMLInputElement).value = String(e.periodNumber);
      (document.getElementById('courseId') as HTMLSelectElement).value = String(e.courseId || '');
      (document.getElementById('classId') as HTMLSelectElement).value = String(e.classId || '');
      (document.getElementById('startTime') as HTMLInputElement).value = e.startTime;
      (document.getElementById('endTime') as HTMLInputElement).value = e.endTime;
      (document.getElementById('room') as HTMLInputElement).value = e.room || '';
      document.getElementById('modalTitle')!.textContent = 'Edit Entry';
      document.getElementById('addModal')!.classList.remove('hidden');
    }
    async function submitForm(e: Event) {
      e.preventDefault();
      const editId = (document.getElementById('editId') as HTMLInputElement).value;
      const body: any = {
        dayOfWeek: parseInt((document.getElementById('dayOfWeek') as HTMLSelectElement).value),
        periodNumber: parseInt((document.getElementById('periodNumber') as HTMLInputElement).value),
        courseId: (document.getElementById('courseId') as HTMLSelectElement).value ? parseInt((document.getElementById('courseId') as HTMLSelectElement).value) : null,
        classId: (document.getElementById('classId') as HTMLSelectElement).value ? parseInt((document.getElementById('classId') as HTMLSelectElement).value) : null,
        startTime: (document.getElementById('startTime') as HTMLInputElement).value,
        endTime: (document.getElementById('endTime') as HTMLInputElement).value,
        room: (document.getElementById('room') as HTMLInputElement).value || null,
      };
      const method = editId ? 'PUT' : 'POST';
      if (editId) body.id = parseInt(editId);
      await fetch('/api/dashboard/timetable', { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      location.reload();
    }
    async function deleteEntry(id: number) {
      if (!confirm('Delete this entry?')) return;
      await fetch('/api/dashboard/timetable', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
      location.reload();
    }
  </script>
</DashboardLayout>
