---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Input from '../../components/ui/Input.astro';
import Button from '../../components/ui/Button.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { faqs } from '../../lib/db/schema.js';
import { eq, asc } from 'drizzle-orm';

const user = Astro.locals.user!;
const schoolId = getUserSchoolId(user.id);
const db = getDb();

const items = schoolId ? db.select().from(faqs).where(eq(faqs.schoolId, schoolId)).orderBy(asc(faqs.sortOrder)).all() : [];
const success = Astro.url.searchParams.get('success');
const editId = Astro.url.searchParams.get('edit');
const editing = editId ? items.find(i => i.id === Number(editId)) : null;
---

<DashboardLayout title="FAQs - iSchool">
  {success && (
    <div class="mb-6 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">FAQ saved successfully.</div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <h2 class="text-base font-semibold text-gray-900 mb-4">{editing ? 'Edit' : 'New'} FAQ</h2>
        <form method="POST" action="/api/dashboard/faqs" class="space-y-4">
          {editing && <input type="hidden" name="id" value={editing.id} />}
          <Input label="Question" name="question" value={editing?.question || ''} placeholder="What is...?" required />
          <Input label="Answer" name="answer" value={editing?.answer || ''} placeholder="The answer is..." rows={4} required />
          <Input label="Category" name="category" value={editing?.category || 'General'} placeholder="e.g., General, Admissions, Academics" />
          <Input label="Sort Order" name="sortOrder" type="number" value={editing?.sortOrder?.toString() || '0'} />
          <Button type="submit" full>{editing ? 'Update' : 'Add'} FAQ</Button>
          {editing && <a href="/dashboard/faqs" class="block text-center text-sm text-gray-500 hover:text-gray-700">Cancel Edit</a>}
        </form>
      </div>
    </div>

    <div class="lg:col-span-2">
      <div class="bg-white rounded-xl border border-gray-200">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-base font-semibold text-gray-900">All FAQs ({items.length})</h2>
        </div>
        <div class="divide-y divide-gray-100">
          {items.length === 0 && <p class="p-6 text-sm text-gray-500 text-center">No FAQs added yet.</p>}
          {items.map(item => (
            <div class="px-6 py-4 flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="text-sm font-medium text-gray-900">{item.question}</h3>
                  <span class="text-xs bg-gray-100 text-gray-600 px-1.5 py-0.5 rounded shrink-0">{item.category}</span>
                </div>
                <p class="text-sm text-gray-500 line-clamp-2">{item.answer}</p>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <a href={`?edit=${item.id}`} class="text-xs text-primary-600 hover:text-primary-700">Edit</a>
                <form method="POST" action="/api/dashboard/faqs">
                  <input type="hidden" name="id" value={item.id} />
                  <input type="hidden" name="action" value="delete" />
                  <button type="submit" class="text-xs text-red-500 hover:text-red-700">Delete</button>
                </form>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>
