---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Input from '../../components/ui/Input.astro';
import Button from '../../components/ui/Button.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { banners } from '../../lib/db/schema.js';
import { eq, asc } from 'drizzle-orm';

const user = Astro.locals.user!;
const schoolId = getUserSchoolId(user.id);
const db = getDb();
const items = schoolId ? db.select().from(banners).where(eq(banners.schoolId, schoolId)).orderBy(asc(banners.sortOrder)).all() : [];
const success = Astro.url.searchParams.get('success');
const editId = Astro.url.searchParams.get('edit');
const editing = editId ? items.find(i => i.id === Number(editId)) : null;
const positions = ['top', 'header_below', 'hero', 'sidebar', 'footer'];
---

<DashboardLayout title="Banners - iSchool">
  {success && <div class="mb-6 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Banner saved successfully.</div>}
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <h2 class="text-base font-semibold text-gray-900 mb-4">{editing ? 'Edit' : 'Add'} Banner</h2>
        <form method="POST" action="/api/dashboard/banners" class="space-y-4">
          {editing && <input type="hidden" name="id" value={editing.id} />}
          <Input label="Title" name="title" value={editing?.title || ''} placeholder="Banner headline" required />
          <Input label="Subtitle" name="subtitle" value={editing?.subtitle || ''} placeholder="Supporting text" />
          <Input label="Image URL" name="imageUrl" value={editing?.imageUrl || ''} placeholder="https://... or upload via media library" required />
          <div class="grid grid-cols-2 gap-3">
            <Input label="Link URL" name="linkUrl" value={editing?.linkUrl || ''} placeholder="/admissions" />
            <Input label="Link Text" name="linkText" value={editing?.linkText || ''} placeholder="Learn More" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Position</label>
            <select name="position" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
              {positions.map(p => <option value={p} selected={editing?.position === p}>{p.replace('_', ' ')}</option>)}
            </select>
          </div>
          <Input label="Display Pages" name="displayPages" value={editing?.displayPages ? JSON.parse(editing.displayPages as string).join(', ') : 'all'} placeholder="all, /, /about, /admissions" />
          <div class="grid grid-cols-2 gap-3">
            <Input label="Start Date" name="startDate" type="date" value={editing?.startDate || ''} />
            <Input label="End Date" name="endDate" type="date" value={editing?.endDate || ''} />
          </div>
          <Input label="Sort Order" name="sortOrder" type="number" value={editing?.sortOrder?.toString() || '0'} />
          <Button type="submit" full>{editing ? 'Update' : 'Create'} Banner</Button>
          {editing && <a href="/dashboard/banners" class="block text-center text-sm text-gray-500 hover:text-gray-700">Cancel Edit</a>}
        </form>
      </div>
    </div>
    <div class="lg:col-span-2">
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
          <h2 class="text-base font-semibold text-gray-900">Active Banners ({items.length})</h2>
        </div>
        {items.length === 0 ? (
          <div class="p-12 text-center text-gray-400">
            <svg class="w-12 h-12 mx-auto mb-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <p>No banners yet. Create your first banner to promote content on your school website.</p>
          </div>
        ) : (
          <div class="divide-y divide-gray-100">
            {items.map(item => (
              <div class="flex items-center gap-4 px-6 py-4 hover:bg-gray-50">
                <img src={item.imageUrl} alt={item.title} class="w-20 h-12 object-cover rounded-lg" />
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-medium text-gray-900 truncate">{item.title}</span>
                    <span class:list={['px-2 py-0.5 text-xs rounded-full', item.isActive ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500']}>{item.isActive ? 'Active' : 'Inactive'}</span>
                    <span class="px-2 py-0.5 text-xs rounded-full bg-blue-50 text-blue-600">{item.position}</span>
                  </div>
                  <p class="text-xs text-gray-500 mt-0.5">{item.subtitle || 'No subtitle'}</p>
                </div>
                <div class="flex items-center gap-2">
                  <form method="POST" action="/api/dashboard/banners" class="inline">
                    <input type="hidden" name="id" value={item.id} />
                    <input type="hidden" name="action" value="toggle" />
                    <button type="submit" class="text-xs text-gray-500 hover:text-gray-700">{item.isActive ? 'Disable' : 'Enable'}</button>
                  </form>
                  <a href={`/dashboard/banners?edit=${item.id}`} class="text-xs text-primary-600 hover:text-primary-700">Edit</a>
                  <form method="POST" action="/api/dashboard/banners" class="inline" onsubmit="return confirm('Delete this banner?')">
                    <input type="hidden" name="id" value={item.id} />
                    <input type="hidden" name="action" value="delete" />
                    <button type="submit" class="text-xs text-red-500 hover:text-red-700">Delete</button>
                  </form>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</DashboardLayout>
