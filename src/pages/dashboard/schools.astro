---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getDb } from '../../lib/db/index.js';
import { schools, schoolMembers } from '../../lib/db/schema.js';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user!;
const db = getDb();
const memberships = db.select().from(schoolMembers).where(eq(schoolMembers.userId, user.id)).all();
const memberSchools = memberships.map(m => {
  const s = db.select().from(schools).where(eq(schools.id, m.schoolId)).get();
  return s ? { ...s, memberRole: m.role, isActive: m.active } : null;
}).filter(Boolean);
---
<DashboardLayout title="Schools - iSchool">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-lg font-semibold text-gray-900">Your Schools</h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {memberSchools.map(s => (
      <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between mb-3">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center text-white font-bold text-sm" style={`background:${s!.primaryColor || '#2563eb'}`}>
              {s!.name.charAt(0)}
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">{s!.name}</h3>
              <span class="text-xs text-gray-500">/{s!.slug}</span>
            </div>
          </div>
          {s!.isActive && <span class="text-[10px] font-medium bg-green-50 text-green-600 px-2 py-0.5 rounded-full">Active</span>}
        </div>
        {s!.tagline && <p class="text-sm text-gray-500 mb-3">{s!.tagline}</p>}
        <div class="flex items-center gap-2">
          <a href={`/${s!.slug}`} target="_blank" class="text-sm text-primary-600 hover:text-primary-700 font-medium">View Site</a>
          {!s!.isActive && (
            <form method="POST" action="/api/dashboard/switch-school" class="inline">
              <input type="hidden" name="schoolId" value={s!.id} />
              <button type="submit" class="text-sm text-gray-500 hover:text-gray-700 font-medium">Switch to</button>
            </form>
          )}
        </div>
      </div>
    ))}
  </div>
</DashboardLayout>
