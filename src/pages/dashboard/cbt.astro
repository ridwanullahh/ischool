---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getDb } from '../../lib/db/index.js';
import { cbtExams, cbtCandidates, schoolMembers } from '../../lib/db/schema.js';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const db = getDb();
const membership = db.select().from(schoolMembers).where(eq(schoolMembers.userId, user.id)).get();
const schoolId = membership?.schoolId;

const allExams = schoolId ? db.select().from(cbtExams).where(eq(cbtExams.schoolId, schoolId)).all() : [];
const allCandidates = allExams.length > 0
  ? db.select().from(cbtCandidates).all().filter((c: any) => allExams.some((e: any) => e.id === c.examId))
  : [];
---

<DashboardLayout title="e-Exam (CBT) - iSchool">
  <div class="space-y-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">e-Exam (CBT)</h2>
        <p class="text-sm text-gray-500 mt-1">Manage computer-based testing and online examinations</p>
      </div>
      <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 font-medium">+ Create e-Exam</button>
      <button onclick="exportCsv('cbt')" class="bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700 font-medium text-sm">Export CSV</button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div class="bg-white rounded-lg shadow p-5"><div class="text-sm text-gray-500">Total Exams</div><div class="text-2xl font-bold text-gray-900 mt-1">{allExams.length}</div></div>
      <div class="bg-white rounded-lg shadow p-5"><div class="text-sm text-gray-500">Published</div><div class="text-2xl font-bold text-green-600 mt-1">{allExams.filter((e: any) => e.status === 'published').length}</div></div>
      <div class="bg-white rounded-lg shadow p-5"><div class="text-sm text-gray-500">Candidates</div><div class="text-2xl font-bold text-blue-600 mt-1">{allCandidates.length}</div></div>
      <div class="bg-white rounded-lg shadow p-5"><div class="text-sm text-gray-500">Proctored</div><div class="text-2xl font-bold text-purple-600 mt-1">{allExams.filter((e: any) => e.proctoring).length}</div></div>
    </div>

    <div class="bg-white rounded-lg shadow">
      <div class="p-4 border-b border-gray-200 flex flex-col sm:flex-row gap-3 justify-between items-center">
        <h3 class="text-lg font-semibold">CBT Exams</h3>
        <input id="searchExams" type="text" placeholder="Search exams..." class="px-3 py-2 border border-gray-300 rounded-lg" />
      </div>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Duration</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Marks</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Access</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Schedule</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            {allExams.length === 0 ? (
              <tr><td colspan="8" class="px-6 py-8 text-center text-gray-500">No CBT exams created.</td></tr>
            ) : (
              allExams.map((exam: any) => (
                <tr class="hover:bg-gray-50 exam-row" data-title={exam.title.toLowerCase()}>
                  <td class="px-6 py-4 text-sm font-medium text-gray-900">{exam.title}</td>
                  <td class="px-6 py-4 text-sm text-gray-600 capitalize">{exam.type}</td>
                  <td class="px-6 py-4 text-sm text-gray-600">{exam.duration ? `${exam.duration} min` : '-'}</td>
                  <td class="px-6 py-4 text-sm text-gray-600">{exam.totalMarks || '-'}</td>
                  <td class="px-6 py-4 text-sm text-gray-600 capitalize">{exam.accessMode?.replace('_', ' ')}</td>
                  <td class="px-6 py-4 text-sm text-gray-600">{exam.scheduledStart || '-'}</td>
                  <td class="px-6 py-4">
                    <span class={`px-2 py-1 text-xs font-medium rounded ${exam.status === 'published' ? 'bg-green-100 text-green-700' : exam.status === 'closed' ? 'bg-gray-100 text-gray-700' : exam.status === 'archived' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700'}`}>{exam.status}</span>
                  </td>
                  <td class="px-6 py-4 text-sm flex gap-2">
                    <button onclick={`editExam(${exam.id}, '${exam.title.replace(/'/g, "\\'")}', '${exam.type}', ${exam.duration || 'null'}, ${exam.totalMarks || 'null'}, '${exam.accessMode}', '${exam.status}', ${exam.proctoring ? 'true' : 'false'}, ${exam.lockdown ? 'true' : 'false'}, ${exam.negativeMarking ? 'true' : 'false'})`} class="text-primary-600 hover:text-primary-700">Edit</button>
                    <button onclick={`confirmDelete(${exam.id}, '${exam.title.replace(/'/g, "\\'")}')`} class="text-red-600 hover:text-red-700">Delete</button>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Add CBT Exam Modal -->
  <div id="addModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4 max-h-[90vh] overflow-y-auto">
      <div class="p-6 border-b border-gray-200 flex justify-between items-center">
        <h3 class="text-lg font-semibold">Create CBT Exam</h3>
        <button onclick="document.getElementById('addModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
      </div>
      <form id="addForm" class="p-6 space-y-4">
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Title *</label><input name="title" required class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Type *</label>
            <select name="type" required class="w-full px-3 py-2 border border-gray-300 rounded-lg">
              <option value="academic">Academic</option><option value="entrance">Entrance</option><option value="employment">Employment</option><option value="certification">Certification</option><option value="custom">Custom</option>
            </select>
          </div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Access Mode</label>
            <select name="accessMode" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
              <option value="open">Open</option><option value="restricted">Restricted</option><option value="class_based">Class Based</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Duration (min)</label><input name="duration" type="number" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Total Marks</label><input name="totalMarks" type="number" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Max Attempts</label><input name="maxAttempts" type="number" value="1" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Start</label><input name="scheduledStart" type="datetime-local" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">End</label><input name="scheduledEnd" type="datetime-local" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
        </div>
        <div class="flex gap-6">
          <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="proctoring" class="rounded" /> Proctoring</label>
          <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="lockdown" class="rounded" /> Lockdown</label>
          <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="negativeMarking" class="rounded" /> Negative Marking</label>
        </div>
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Description</label><textarea name="description" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg"></textarea></div>
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Instructions</label><textarea name="instructions" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg"></textarea></div>
        <div id="addError" class="text-red-600 text-sm hidden"></div>
        <div class="flex justify-end gap-3 pt-4 border-t border-gray-200">
          <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="px-4 py-2 text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700">Create Exam</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit CBT Exam Modal -->
  <div id="editModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4 max-h-[90vh] overflow-y-auto">
      <div class="p-6 border-b border-gray-200 flex justify-between items-center">
        <h3 class="text-lg font-semibold">Edit CBT Exam</h3>
        <button onclick="document.getElementById('editModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
      </div>
      <form id="editForm" class="p-6 space-y-4">
        <input type="hidden" name="id" id="editId" />
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Title *</label><input name="title" id="editTitle" required class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
            <select name="type" id="editType" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
              <option value="academic">Academic</option><option value="entrance">Entrance</option><option value="employment">Employment</option><option value="certification">Certification</option><option value="custom">Custom</option>
            </select>
          </div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
            <select name="status" id="editStatus" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
              <option value="draft">Draft</option><option value="published">Published</option><option value="closed">Closed</option><option value="archived">Archived</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Duration (min)</label><input name="duration" id="editDuration" type="number" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Total Marks</label><input name="totalMarks" id="editTotalMarks" type="number" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
        </div>
        <div class="flex gap-6">
          <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="proctoring" id="editProctoring" class="rounded" /> Proctoring</label>
          <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="lockdown" id="editLockdown" class="rounded" /> Lockdown</label>
          <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="negativeMarking" id="editNegMark" class="rounded" /> Negative Marking</label>
        </div>
        <div id="editError" class="text-red-600 text-sm hidden"></div>
        <div class="flex justify-end gap-3 pt-4 border-t border-gray-200">
          <button type="button" onclick="document.getElementById('editModal').classList.add('hidden')" class="px-4 py-2 text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Modal -->
  <div id="deleteModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-sm mx-4 p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-2">Confirm Delete</h3>
      <p class="text-gray-600 mb-6">Are you sure you want to delete <strong id="deleteName"></strong>?</p>
      <div class="flex justify-end gap-3">
        <button onclick="document.getElementById('deleteModal').classList.add('hidden')" class="px-4 py-2 text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</button>
        <button id="confirmDeleteBtn" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">Delete</button>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('searchExams')?.addEventListener('input', (e: Event) => {
      const q = ((e.target as HTMLInputElement).value || '').toLowerCase();
      document.querySelectorAll('.exam-row').forEach((row: Element) => {
        const el = row as HTMLElement;
        el.style.display = !q || (el.dataset.title || '').includes(q) ? '' : 'none';
      });
    });

    document.getElementById('addForm')?.addEventListener('submit', async (e: Event) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const fd = new FormData(form);
      const data: any = Object.fromEntries(fd);
      if (data.duration) data.duration = Number(data.duration);
      if (data.totalMarks) data.totalMarks = Number(data.totalMarks);
      if (data.maxAttempts) data.maxAttempts = Number(data.maxAttempts);
      data.proctoring = fd.has('proctoring');
      data.lockdown = fd.has('lockdown');
      data.negativeMarking = fd.has('negativeMarking');
      const errEl = document.getElementById('addError')!;
      errEl.classList.add('hidden');
      try {
        const res = await fetch('/api/dashboard/cbt', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
        if (!res.ok) { const err = await res.json(); throw new Error(err.error || 'Failed'); }
        window.location.reload();
      } catch (err: any) { errEl.textContent = err.message; errEl.classList.remove('hidden'); }
    });

    (window as any).editExam = (id: number, title: string, type: string, duration: number|null, totalMarks: number|null, accessMode: string, status: string, proctoring: boolean, lockdown: boolean, negMark: boolean) => {
      (document.getElementById('editId') as HTMLInputElement).value = String(id);
      (document.getElementById('editTitle') as HTMLInputElement).value = title;
      (document.getElementById('editType') as HTMLSelectElement).value = type;
      (document.getElementById('editDuration') as HTMLInputElement).value = duration ? String(duration) : '';
      (document.getElementById('editTotalMarks') as HTMLInputElement).value = totalMarks ? String(totalMarks) : '';
      (document.getElementById('editStatus') as HTMLSelectElement).value = status;
      (document.getElementById('editProctoring') as HTMLInputElement).checked = proctoring;
      (document.getElementById('editLockdown') as HTMLInputElement).checked = lockdown;
      (document.getElementById('editNegMark') as HTMLInputElement).checked = negMark;
      document.getElementById('editModal')!.classList.remove('hidden');
    };

    document.getElementById('editForm')?.addEventListener('submit', async (e: Event) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const fd = new FormData(form);
      const data: any = Object.fromEntries(fd);
      if (data.duration) data.duration = Number(data.duration);
      if (data.totalMarks) data.totalMarks = Number(data.totalMarks);
      data.proctoring = fd.has('proctoring');
      data.lockdown = fd.has('lockdown');
      data.negativeMarking = fd.has('negativeMarking');
      const errEl = document.getElementById('editError')!;
      errEl.classList.add('hidden');
      try {
        const res = await fetch('/api/dashboard/cbt', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: Number(data.id), ...data }) });
        if (!res.ok) { const err = await res.json(); throw new Error(err.error || 'Failed'); }
        window.location.reload();
      } catch (err: any) { errEl.textContent = err.message; errEl.classList.remove('hidden'); }
    });

    let deleteTargetId: number | null = null;
    (window as any).confirmDelete = (id: number, name: string) => {
      deleteTargetId = id;
      document.getElementById('deleteName')!.textContent = name;
      document.getElementById('deleteModal')!.classList.remove('hidden');
    };

    document.getElementById('confirmDeleteBtn')?.addEventListener('click', async () => {
      if (!deleteTargetId) return;
      try {
        await fetch('/api/dashboard/cbt', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: deleteTargetId }) });
        window.location.reload();
      } catch { document.getElementById('deleteModal')!.classList.add('hidden'); }
    });
  </script>
</DashboardLayout>
