---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { payroll, staff } from '../../lib/db/schema.js';
import { eq, desc, sql } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/auth/login');
const schoolId = getUserSchoolId(user.id);

let records: any[] = [];
let allStaff: any[] = [];
let stats = { total: 0, totalNetPay: 0, draft: 0, paid: 0 };

if (schoolId) {
  const db = getDb();
  allStaff = db.select().from(staff).where(eq(staff.schoolId, schoolId)).all();
  records = db.select({
    id: payroll.id, staffId: payroll.staffId, month: payroll.month, year: payroll.year,
    basicSalary: payroll.basicSalary, grossPay: payroll.grossPay, netPay: payroll.netPay,
    status: payroll.status, paidAt: payroll.paidAt, createdAt: payroll.createdAt,
    staffName: sql`${staff.firstName} || ' ' || ${staff.lastName}`.as('staff_name'),
    department: staff.department,
  }).from(payroll)
    .leftJoin(staff, eq(payroll.staffId, staff.id))
    .where(eq(payroll.schoolId, schoolId))
    .orderBy(desc(payroll.createdAt)).all();
  stats = { total: records.length, totalNetPay: records.reduce((s, r) => s + r.netPay, 0), draft: records.filter(r => r.status === 'draft').length, paid: records.filter(r => r.status === 'paid').length };
}
---

<DashboardLayout title="Payroll - iSchool">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <div><h2 class="text-2xl font-bold text-gray-900">Payroll</h2><p class="text-sm text-gray-500 mt-1">Manage staff payroll</p></div>
      <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 font-medium text-sm">+ Run Payroll</button>
      <button onclick="exportCsv('payroll')" class="bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700 font-medium text-sm">Export CSV</button>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Records</p><p class="text-2xl font-bold">{stats.total}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Total Net Pay</p><p class="text-2xl font-bold text-green-600">${stats.totalNetPay.toLocaleString()}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Draft</p><p class="text-2xl font-bold text-yellow-600">{stats.draft}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Paid</p><p class="text-2xl font-bold text-green-600">{stats.paid}</p></div>
    </div>
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50"><tr>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Staff</th><th class="px-4 py-3 text-left font-medium text-gray-600">Period</th>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Basic</th><th class="px-4 py-3 text-left font-medium text-gray-600">Gross</th>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Net Pay</th><th class="px-4 py-3 text-left font-medium text-gray-600">Status</th>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Actions</th>
          </tr></thead>
          <tbody class="divide-y">
            {records.length === 0 && <tr><td colspan="7" class="px-4 py-8 text-center text-gray-500">No payroll records</td></tr>}
            {records.map(r => (
              <tr>
                <td class="px-4 py-3 font-medium">{r.staffName} <span class="text-gray-400 text-xs">({r.department || ''})</span></td>
                <td class="px-4 py-3">{r.month} {r.year}</td>
                <td class="px-4 py-3">${r.basicSalary.toLocaleString()}</td>
                <td class="px-4 py-3">${r.grossPay.toLocaleString()}</td>
                <td class="px-4 py-3 font-medium">${r.netPay.toLocaleString()}</td>
                <td class="px-4 py-3"><span class={`px-2 py-1 rounded-full text-xs font-medium ${r.status === 'paid' ? 'bg-green-100 text-green-700' : r.status === 'approved' ? 'bg-blue-100 text-blue-700' : 'bg-yellow-100 text-yellow-700'}`}>{r.status}</span></td>
                <td class="px-4 py-3 flex gap-2">
                  {r.status === 'draft' && <button onclick={`updateStatus(${r.id}, 'approved')`} class="text-blue-600 text-xs">Approve</button>}
                  {r.status === 'approved' && <button onclick={`updateStatus(${r.id}, 'paid')`} class="text-green-600 text-xs">Mark Paid</button>}
                  <button onclick={`deleteRecord(${r.id})`} class="text-red-600 text-xs">Delete</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="addModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl p-6 w-full max-w-md mx-4">
      <h3 class="text-lg font-bold mb-4">Generate Payroll</h3>
      <form onsubmit="submitForm(event)">
        <div class="space-y-3">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Staff</label>
            <select id="staffId" required class="w-full border rounded-lg px-3 py-2 text-sm">
              <option value="">Select</option>{allStaff.map(s => <option value={s.id}>{s.firstName} {s.lastName} (Salary: ${s.salary || 0})</option>)}
            </select></div>
          <div class="grid grid-cols-2 gap-3">
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Month</label>
              <select id="month" required class="w-full border rounded-lg px-3 py-2 text-sm">
                {['January','February','March','April','May','June','July','August','September','October','November','December'].map(m => <option value={m}>{m}</option>)}
              </select></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Year</label>
              <input type="number" id="year" required class="w-full border rounded-lg px-3 py-2 text-sm" value={new Date().getFullYear()} /></div>
          </div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Basic Salary</label>
            <input type="number" id="basicSalary" required class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="px-4 py-2 border rounded-lg text-sm">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg text-sm hover:bg-primary-700">Generate</button>
        </div>
      </form>
    </div>
  </div>

  <script define:vars={{ staffData: allStaff.map((s: any) => ({ id: s.id, salary: s.salary || 0 })) }}>
    const _staffData = staffData;
    (document.getElementById('staffId') as HTMLSelectElement)?.addEventListener('change', function() {
      const selected = _staffData.find((s: any) => s.id === parseInt((this as HTMLSelectElement).value));
      if (selected) (document.getElementById('basicSalary') as HTMLInputElement).value = String(selected.salary);
    });
    async function submitForm(e: Event) {
      e.preventDefault();
      await fetch('/api/dashboard/payroll', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({
        staffId: parseInt((document.getElementById('staffId') as HTMLSelectElement).value),
        month: (document.getElementById('month') as HTMLSelectElement).value,
        year: parseInt((document.getElementById('year') as HTMLInputElement).value),
        basicSalary: parseInt((document.getElementById('basicSalary') as HTMLInputElement).value),
      })});
      location.reload();
    }
    async function updateStatus(id: number, status: string) {
      await fetch('/api/dashboard/payroll', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, status }) });
      location.reload();
    }
    async function deleteRecord(id: number) {
      if (!confirm('Delete this payroll record?')) return;
      await fetch('/api/dashboard/payroll', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
      location.reload();
    }
  </script>
</DashboardLayout>
