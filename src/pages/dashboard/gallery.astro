---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { galleryItems, galleryAlbums, virtualTours } from '../../lib/db/schema.js';
import { eq, asc, and } from 'drizzle-orm';

const user = Astro.locals.user!;
const schoolId = getUserSchoolId(user.id);
const db = getDb();

const tab = Astro.url.searchParams.get('tab') || 'items';
const success = Astro.url.searchParams.get('success');
const editId = Astro.url.searchParams.get('edit');

const albums = schoolId ? db.select().from(galleryAlbums).where(eq(galleryAlbums.schoolId, schoolId)).orderBy(asc(galleryAlbums.sortOrder)).all() : [];
const items = schoolId ? db.select().from(galleryItems).where(eq(galleryItems.schoolId, schoolId)).orderBy(asc(galleryItems.sortOrder)).all() : [];
const tours = schoolId ? db.select().from(virtualTours).where(eq(virtualTours.schoolId, schoolId)).orderBy(asc(virtualTours.sortOrder)).all() : [];

const editingItem = editId && tab === 'items' ? items.find(i => i.id === Number(editId)) : null;
const editingAlbum = editId && tab === 'albums' ? albums.find(a => a.id === Number(editId)) : null;
const editingTour = editId && tab === 'tours' ? tours.find(t => t.id === Number(editId)) : null;

const albumTypes = [
  { value: 'campus', label: 'School Buildings / Campus' },
  { value: 'facilities', label: 'Facilities Showcase' },
  { value: 'students', label: 'Student Showcase' },
  { value: 'activities', label: 'Activities & Events' },
  { value: 'events', label: 'Special Events' },
  { value: 'sports', label: 'Sports & Athletics' },
  { value: 'virtual_tour', label: 'Virtual Tour' },
  { value: 'custom', label: 'Custom Album' },
];
---

<DashboardLayout title="Gallery - iSchool">
  {success && (
    <div class="mb-6 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Saved successfully.</div>
  )}

  <div class="flex gap-2 mb-6">
    {[
      { key: 'items', label: `Gallery Items (${items.length})` },
      { key: 'albums', label: `Albums (${albums.length})` },
      { key: 'tours', label: `Virtual Tours (${tours.length})` },
    ].map(t => (
      <a href={`?tab=${t.key}`} class:list={[
        'px-4 py-2 text-sm font-medium rounded-lg transition-all',
        tab === t.key ? 'bg-primary-600 text-white' : 'bg-white text-gray-600 border border-gray-200 hover:bg-gray-50'
      ]}>{t.label}</a>
    ))}
  </div>

  {tab === 'items' && (
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-1">
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-base font-semibold text-gray-900 mb-4">{editingItem ? 'Edit' : 'Add'} Gallery Item</h2>
          <form method="POST" action="/api/dashboard/gallery" class="space-y-4" enctype="multipart/form-data">
            {editingItem && <input type="hidden" name="id" value={editingItem.id} />}
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Title</label>
              <input type="text" name="title" value={editingItem?.title || ''} placeholder="Image title" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Upload Image</label>
              <input type="file" name="file" accept="image/*" class="w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100" />
              <p class="text-[11px] text-gray-400 mt-1">Or enter URL below</p>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Image URL</label>
              <input type="text" name="imageUrl" value={editingItem?.imageUrl || ''} placeholder="https://..." class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Caption</label>
              <input type="text" name="caption" value={editingItem?.caption || ''} placeholder="Brief description" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Album</label>
              <select name="albumId" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                <option value="">No Album</option>
                {albums.map(a => (
                  <option value={a.id} selected={editingItem?.albumId === a.id}>{a.name} ({a.type})</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Category</label>
              <input type="text" name="category" value={editingItem?.category || 'General'} placeholder="e.g., Campus, Events" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Sort Order</label>
              <input type="number" name="sortOrder" value={editingItem?.sortOrder?.toString() || '0'} class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
            </div>
            <button type="submit" class="w-full py-2.5 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors">{editingItem ? 'Update' : 'Add'} Item</button>
            {editingItem && <a href="/dashboard/gallery?tab=items" class="block text-center text-sm text-gray-500 hover:text-gray-700">Cancel</a>}
          </form>
        </div>
      </div>

      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl border border-gray-200">
          <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
            <h2 class="text-base font-semibold text-gray-900">Gallery Items ({items.length})</h2>
          </div>
          <div class="p-4 grid grid-cols-2 sm:grid-cols-3 gap-4">
            {items.length === 0 && <p class="col-span-full p-6 text-sm text-gray-500 text-center">No gallery items yet.</p>}
            {items.map(item => {
              const album = albums.find(a => a.id === item.albumId);
              return (
                <div class="group relative rounded-lg overflow-hidden border border-gray-200">
                  <img src={item.imageUrl} alt={item.title || ''} class="w-full h-32 object-cover" loading="lazy" />
                  <div class="p-2">
                    <p class="text-xs font-medium text-gray-900 truncate">{item.title || 'Untitled'}</p>
                    <p class="text-[11px] text-gray-500">{album ? album.name : item.category}</p>
                  </div>
                  <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-3">
                    <a href={`?tab=items&edit=${item.id}`} class="text-xs text-white bg-white/20 px-2 py-1 rounded hover:bg-white/30">Edit</a>
                    <form method="POST" action="/api/dashboard/gallery">
                      <input type="hidden" name="id" value={item.id} />
                      <input type="hidden" name="action" value="delete" />
                      <button type="submit" class="text-xs text-white bg-red-500/70 px-2 py-1 rounded hover:bg-red-500">Delete</button>
                    </form>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  )}

  {tab === 'albums' && (
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-1">
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-base font-semibold text-gray-900 mb-4">{editingAlbum ? 'Edit' : 'Create'} Album</h2>
          <form method="POST" action="/api/dashboard/gallery" class="space-y-4">
            <input type="hidden" name="resource" value="album" />
            {editingAlbum && <input type="hidden" name="id" value={editingAlbum.id} />}
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Album Name</label>
              <input type="text" name="name" value={editingAlbum?.name || ''} required placeholder="e.g., Main Campus" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Slug</label>
              <input type="text" name="slug" value={editingAlbum?.slug || ''} required placeholder="main-campus" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Description</label>
              <textarea name="description" rows={2} placeholder="Album description" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">{editingAlbum?.description || ''}</textarea>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Type</label>
              <select name="type" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                {albumTypes.map(t => (
                  <option value={t.value} selected={editingAlbum?.type === t.value}>{t.label}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Cover Image URL</label>
              <input type="text" name="coverImageUrl" value={editingAlbum?.coverImageUrl || ''} placeholder="https://..." class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
            </div>
            <div class="flex items-center gap-3">
              <label class="text-xs font-medium text-gray-600">Published</label>
              <input type="checkbox" name="isPublished" value="1" checked={editingAlbum?.isPublished !== false} class="rounded text-primary-600" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Sort Order</label>
              <input type="number" name="sortOrder" value={editingAlbum?.sortOrder?.toString() || '0'} class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
            </div>
            <button type="submit" class="w-full py-2.5 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors">{editingAlbum ? 'Update' : 'Create'} Album</button>
            {editingAlbum && <a href="/dashboard/gallery?tab=albums" class="block text-center text-sm text-gray-500 hover:text-gray-700">Cancel</a>}
          </form>
        </div>
      </div>

      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl border border-gray-200">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-base font-semibold text-gray-900">Albums ({albums.length})</h2>
          </div>
          <div class="divide-y divide-gray-100">
            {albums.length === 0 && <p class="p-6 text-sm text-gray-500 text-center">No albums created yet.</p>}
            {albums.map(album => {
              const albumItems = items.filter(i => i.albumId === album.id);
              return (
                <div class="px-6 py-4 flex items-center gap-4">
                  <div class="w-16 h-16 rounded-lg bg-gray-100 flex-shrink-0 overflow-hidden">
                    {album.coverImageUrl ? (
                      <img src={album.coverImageUrl} alt={album.name} class="w-full h-full object-cover" />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center text-2xl text-gray-300">
                        {album.type === 'campus' ? '🏫' : album.type === 'facilities' ? '🏊' : album.type === 'students' ? '🎓' : album.type === 'activities' ? '🎭' : album.type === 'sports' ? '⚽' : album.type === 'virtual_tour' ? '🔭' : '📁'}
                      </div>
                    )}
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                      <h3 class="text-sm font-semibold text-gray-900 truncate">{album.name}</h3>
                      <span class:list={['text-[10px] px-2 py-0.5 rounded-full font-medium',
                        album.type === 'campus' ? 'bg-blue-50 text-blue-700' :
                        album.type === 'facilities' ? 'bg-green-50 text-green-700' :
                        album.type === 'students' ? 'bg-purple-50 text-purple-700' :
                        album.type === 'activities' ? 'bg-orange-50 text-orange-700' :
                        album.type === 'sports' ? 'bg-red-50 text-red-700' :
                        album.type === 'virtual_tour' ? 'bg-cyan-50 text-cyan-700' :
                        'bg-gray-50 text-gray-700'
                      ]}>{album.type}</span>
                      {!album.isPublished && <span class="text-[10px] px-2 py-0.5 rounded-full bg-yellow-50 text-yellow-700">Draft</span>}
                    </div>
                    <p class="text-xs text-gray-500 mt-0.5">{album.description || 'No description'}</p>
                    <p class="text-[11px] text-gray-400 mt-1">{albumItems.length} item{albumItems.length !== 1 ? 's' : ''}</p>
                  </div>
                  <div class="flex items-center gap-2">
                    <a href={`?tab=albums&edit=${album.id}`} class="text-xs text-primary-600 hover:text-primary-700">Edit</a>
                    <form method="POST" action="/api/dashboard/gallery">
                      <input type="hidden" name="resource" value="album" />
                      <input type="hidden" name="id" value={album.id} />
                      <input type="hidden" name="action" value="delete" />
                      <button type="submit" class="text-xs text-red-500 hover:text-red-700">Delete</button>
                    </form>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  )}

  {tab === 'tours' && (
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-1">
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-base font-semibold text-gray-900 mb-4">{editingTour ? 'Edit' : 'Add'} Virtual Tour</h2>
          <form method="POST" action="/api/dashboard/gallery" class="space-y-4">
            <input type="hidden" name="resource" value="tour" />
            {editingTour && <input type="hidden" name="id" value={editingTour.id} />}
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Title</label>
              <input type="text" name="title" value={editingTour?.title || ''} required placeholder="e.g., Main Campus 360°" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Description</label>
              <textarea name="description" rows={2} placeholder="Tour description" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">{editingTour?.description || ''}</textarea>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Embed URL (360° / Google Street View / YouTube)</label>
              <input type="text" name="embedUrl" value={editingTour?.embedUrl || ''} required placeholder="https://..." class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Thumbnail URL</label>
              <input type="text" name="thumbnailUrl" value={editingTour?.thumbnailUrl || ''} placeholder="https://..." class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Location</label>
              <input type="text" name="location" value={editingTour?.location || ''} placeholder="e.g., Main Building" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
            </div>
            <div class="flex items-center gap-3">
              <label class="text-xs font-medium text-gray-600">Published</label>
              <input type="checkbox" name="isPublished" value="1" checked={editingTour?.isPublished !== false} class="rounded text-primary-600" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Sort Order</label>
              <input type="number" name="sortOrder" value={editingTour?.sortOrder?.toString() || '0'} class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
            </div>
            <button type="submit" class="w-full py-2.5 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors">{editingTour ? 'Update' : 'Add'} Tour</button>
            {editingTour && <a href="/dashboard/gallery?tab=tours" class="block text-center text-sm text-gray-500 hover:text-gray-700">Cancel</a>}
          </form>
        </div>
      </div>

      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl border border-gray-200">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-base font-semibold text-gray-900">Virtual Tours ({tours.length})</h2>
          </div>
          <div class="divide-y divide-gray-100">
            {tours.length === 0 && <p class="p-6 text-sm text-gray-500 text-center">No virtual tours yet.</p>}
            {tours.map(tour => (
              <div class="px-6 py-4 flex items-center gap-4">
                <div class="w-20 h-14 rounded-lg bg-gray-100 flex-shrink-0 overflow-hidden">
                  {tour.thumbnailUrl ? (
                    <img src={tour.thumbnailUrl} alt={tour.title} class="w-full h-full object-cover" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-2xl text-gray-300">🔭</div>
                  )}
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2">
                    <h3 class="text-sm font-semibold text-gray-900 truncate">{tour.title}</h3>
                    {!tour.isPublished && <span class="text-[10px] px-2 py-0.5 rounded-full bg-yellow-50 text-yellow-700">Draft</span>}
                  </div>
                  <p class="text-xs text-gray-500 mt-0.5">{tour.location || 'No location'}</p>
                  <p class="text-[11px] text-gray-400 mt-0.5 truncate">{tour.embedUrl}</p>
                </div>
                <div class="flex items-center gap-2">
                  <a href={`?tab=tours&edit=${tour.id}`} class="text-xs text-primary-600 hover:text-primary-700">Edit</a>
                  <form method="POST" action="/api/dashboard/gallery">
                    <input type="hidden" name="resource" value="tour" />
                    <input type="hidden" name="id" value={tour.id} />
                    <input type="hidden" name="action" value="delete" />
                    <button type="submit" class="text-xs text-red-500 hover:text-red-700">Delete</button>
                  </form>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  )}
</DashboardLayout>
