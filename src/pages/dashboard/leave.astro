---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { leaveRequests, staff } from '../../lib/db/schema.js';
import { eq, desc, sql } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/auth/login');
const schoolId = getUserSchoolId(user.id);

let records: any[] = [];
let allStaff: any[] = [];
let stats = { total: 0, pending: 0, approved: 0, rejected: 0 };

if (schoolId) {
  const db = getDb();
  allStaff = db.select().from(staff).where(eq(staff.schoolId, schoolId)).all();
  records = db.select({
    id: leaveRequests.id, staffId: leaveRequests.staffId, type: leaveRequests.type,
    startDate: leaveRequests.startDate, endDate: leaveRequests.endDate,
    reason: leaveRequests.reason, status: leaveRequests.status,
    createdAt: leaveRequests.createdAt,
    staffName: sql`${staff.firstName} || ' ' || ${staff.lastName}`.as('staff_name'),
    department: staff.department,
  }).from(leaveRequests)
    .leftJoin(staff, eq(leaveRequests.staffId, staff.id))
    .where(eq(leaveRequests.schoolId, schoolId))
    .orderBy(desc(leaveRequests.createdAt)).all();
  stats = { total: records.length, pending: records.filter(r => r.status === 'pending').length, approved: records.filter(r => r.status === 'approved').length, rejected: records.filter(r => r.status === 'rejected').length };
}
---

<DashboardLayout title="Leave Requests - iSchool">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <div><h2 class="text-2xl font-bold text-gray-900">Leave Requests</h2><p class="text-sm text-gray-500 mt-1">Manage staff leave</p></div>
      <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 font-medium text-sm">+ Request Leave</button>
      <button onclick="exportCsv('leave')" class="bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700 font-medium text-sm">Export CSV</button>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Total</p><p class="text-2xl font-bold">{stats.total}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Pending</p><p class="text-2xl font-bold text-yellow-600">{stats.pending}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Approved</p><p class="text-2xl font-bold text-green-600">{stats.approved}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Rejected</p><p class="text-2xl font-bold text-red-600">{stats.rejected}</p></div>
    </div>
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50"><tr>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Staff</th><th class="px-4 py-3 text-left font-medium text-gray-600">Type</th>
            <th class="px-4 py-3 text-left font-medium text-gray-600">From</th><th class="px-4 py-3 text-left font-medium text-gray-600">To</th>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Status</th><th class="px-4 py-3 text-left font-medium text-gray-600">Actions</th>
          </tr></thead>
          <tbody class="divide-y">
            {records.length === 0 && <tr><td colspan="6" class="px-4 py-8 text-center text-gray-500">No leave requests</td></tr>}
            {records.map(r => (
              <tr>
                <td class="px-4 py-3 font-medium">{r.staffName} <span class="text-gray-400 text-xs">({r.department || ''})</span></td>
                <td class="px-4 py-3 capitalize">{r.type}</td>
                <td class="px-4 py-3">{r.startDate}</td><td class="px-4 py-3">{r.endDate}</td>
                <td class="px-4 py-3"><span class={`px-2 py-1 rounded-full text-xs font-medium ${r.status === 'approved' ? 'bg-green-100 text-green-700' : r.status === 'rejected' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700'}`}>{r.status}</span></td>
                <td class="px-4 py-3 flex gap-2">
                  {r.status === 'pending' && <>
                    <button onclick={`updateStatus(${r.id}, 'approved')`} class="text-green-600 text-xs font-medium">Approve</button>
                    <button onclick={`updateStatus(${r.id}, 'rejected')`} class="text-red-600 text-xs font-medium">Reject</button>
                  </>}
                  <button onclick={`deleteRecord(${r.id})`} class="text-gray-600 text-xs">Delete</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="addModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl p-6 w-full max-w-md mx-4">
      <h3 class="text-lg font-bold mb-4">Request Leave</h3>
      <form onsubmit="submitForm(event)">
        <div class="space-y-3">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Staff</label>
            <select id="staffId" required class="w-full border rounded-lg px-3 py-2 text-sm">
              <option value="">Select</option>{allStaff.map(s => <option value={s.id}>{s.firstName} {s.lastName}</option>)}
            </select></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
            <select id="leaveType" required class="w-full border rounded-lg px-3 py-2 text-sm">
              <option value="annual">Annual</option><option value="sick">Sick</option><option value="maternity">Maternity</option>
              <option value="paternity">Paternity</option><option value="unpaid">Unpaid</option><option value="other">Other</option>
            </select></div>
          <div class="grid grid-cols-2 gap-3">
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Start Date</label>
              <input type="date" id="startDate" required class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">End Date</label>
              <input type="date" id="endDate" required class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
          </div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Reason</label>
            <textarea id="reason" rows="3" class="w-full border rounded-lg px-3 py-2 text-sm"></textarea></div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="px-4 py-2 border rounded-lg text-sm">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg text-sm hover:bg-primary-700">Submit</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    async function submitForm(e: Event) {
      e.preventDefault();
      await fetch('/api/dashboard/leave', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({
        staffId: parseInt((document.getElementById('staffId') as HTMLSelectElement).value),
        type: (document.getElementById('leaveType') as HTMLSelectElement).value,
        startDate: (document.getElementById('startDate') as HTMLInputElement).value,
        endDate: (document.getElementById('endDate') as HTMLInputElement).value,
        reason: (document.getElementById('reason') as HTMLTextAreaElement).value,
      })});
      location.reload();
    }
    async function updateStatus(id: number, status: string) {
      await fetch('/api/dashboard/leave', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, status }) });
      location.reload();
    }
    async function deleteRecord(id: number) {
      if (!confirm('Delete this leave request?')) return;
      await fetch('/api/dashboard/leave', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
      location.reload();
    }
  </script>
</DashboardLayout>
