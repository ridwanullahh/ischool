---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Input from '../../components/ui/Input.astro';
import Button from '../../components/ui/Button.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { popups } from '../../lib/db/schema.js';
import { eq, asc } from 'drizzle-orm';

const user = Astro.locals.user!;
const schoolId = getUserSchoolId(user.id);
const db = getDb();
const items = schoolId ? db.select().from(popups).where(eq(popups.schoolId, schoolId)).orderBy(asc(popups.createdAt)).all() : [];
const success = Astro.url.searchParams.get('success');
const editId = Astro.url.searchParams.get('edit');
const editing = editId ? items.find(i => i.id === Number(editId)) : null;
const triggerTypes = ['on_load', 'scroll', 'exit_intent', 'timed', 'click'];
const frequencies = ['every_visit', 'once_per_session', 'once_per_day', 'once'];
---

<DashboardLayout title="Popups - iSchool">
  {success && <div class="mb-6 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Popup saved successfully.</div>}
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <h2 class="text-base font-semibold text-gray-900 mb-4">{editing ? 'Edit' : 'Add'} Popup</h2>
        <form method="POST" action="/api/dashboard/popups" class="space-y-4">
          {editing && <input type="hidden" name="id" value={editing.id} />}
          <Input label="Title" name="title" value={editing?.title || ''} placeholder="Popup headline" required />
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Content</label>
            <textarea name="content" rows="3" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary-500" placeholder="Popup message..." required>{editing?.content || ''}</textarea>
          </div>
          <Input label="Image URL (optional)" name="imageUrl" value={editing?.imageUrl || ''} placeholder="https://..." />
          <div class="grid grid-cols-2 gap-3">
            <Input label="Link URL" name="linkUrl" value={editing?.linkUrl || ''} placeholder="/admissions" />
            <Input label="Link Text" name="linkText" value={editing?.linkText || ''} placeholder="Register Now" />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Trigger</label>
              <select name="triggerType" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
                {triggerTypes.map(t => <option value={t} selected={editing?.triggerType === t}>{t.replace('_', ' ')}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Frequency</label>
              <select name="displayFrequency" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
                {frequencies.map(f => <option value={f} selected={editing?.displayFrequency === f}>{f.replace(/_/g, ' ')}</option>)}
              </select>
            </div>
          </div>
          <Input label="Delay (seconds)" name="triggerDelay" type="number" value={editing?.triggerDelay?.toString() || '0'} placeholder="0" />
          <Input label="Display Pages" name="displayPages" value={editing?.displayPages ? JSON.parse(editing.displayPages as string).join(', ') : 'all'} placeholder="all, /, /about" />
          <div class="grid grid-cols-2 gap-3">
            <Input label="Start Date" name="startDate" type="date" value={editing?.startDate || ''} />
            <Input label="End Date" name="endDate" type="date" value={editing?.endDate || ''} />
          </div>
          <Button type="submit" full>{editing ? 'Update' : 'Create'} Popup</Button>
          {editing && <a href="/dashboard/popups" class="block text-center text-sm text-gray-500 hover:text-gray-700">Cancel Edit</a>}
        </form>
      </div>
    </div>
    <div class="lg:col-span-2">
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
          <h2 class="text-base font-semibold text-gray-900">Popups ({items.length})</h2>
        </div>
        {items.length === 0 ? (
          <div class="p-12 text-center text-gray-400">
            <svg class="w-12 h-12 mx-auto mb-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
            <p>No popups yet. Create popups to engage visitors with announcements, offers, and calls to action.</p>
          </div>
        ) : (
          <div class="divide-y divide-gray-100">
            {items.map(item => (
              <div class="flex items-center gap-4 px-6 py-4 hover:bg-gray-50">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-medium text-gray-900 truncate">{item.title}</span>
                    <span class:list={['px-2 py-0.5 text-xs rounded-full', item.isActive ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500']}>{item.isActive ? 'Active' : 'Inactive'}</span>
                    <span class="px-2 py-0.5 text-xs rounded-full bg-purple-50 text-purple-600">{item.triggerType?.replace('_', ' ')}</span>
                  </div>
                  <p class="text-xs text-gray-500 mt-0.5 line-clamp-1">{item.content}</p>
                </div>
                <div class="flex items-center gap-2">
                  <form method="POST" action="/api/dashboard/popups" class="inline"><input type="hidden" name="id" value={item.id} /><input type="hidden" name="action" value="toggle" /><button type="submit" class="text-xs text-gray-500 hover:text-gray-700">{item.isActive ? 'Disable' : 'Enable'}</button></form>
                  <a href={`/dashboard/popups?edit=${item.id}`} class="text-xs text-primary-600 hover:text-primary-700">Edit</a>
                  <form method="POST" action="/api/dashboard/popups" class="inline" onsubmit="return confirm('Delete?')"><input type="hidden" name="id" value={item.id} /><input type="hidden" name="action" value="delete" /><button type="submit" class="text-xs text-red-500 hover:text-red-700">Delete</button></form>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</DashboardLayout>
