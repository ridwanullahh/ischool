---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getDb } from '../../lib/db/index.js';
import { assets, inventoryItems, schoolMembers } from '../../lib/db/schema.js';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const db = getDb();
const membership = db.select().from(schoolMembers).where(eq(schoolMembers.userId, user.id)).get();
const schoolId = membership?.schoolId;

const allAssets = schoolId ? db.select().from(assets).where(eq(assets.schoolId, schoolId)).all() : [];
const allItems = schoolId ? db.select().from(inventoryItems).where(eq(inventoryItems.schoolId, schoolId)).all() : [];
---

<DashboardLayout title="Inventory - iSchool">
  <div class="space-y-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">Inventory & Assets</h2>
        <p class="text-sm text-gray-500 mt-1">Manage school assets and inventory items</p>
      </div>
      <div class="flex gap-2">
        <button onclick="document.getElementById('addAssetModal').classList.remove('hidden')" class="bg-gray-700 text-white px-4 py-2 rounded-lg hover:bg-gray-800 font-medium text-sm">+ Add Asset</button>
        <button onclick="document.getElementById('addItemModal').classList.remove('hidden')" class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 font-medium text-sm">+ Add Item</button>
        <button onclick="exportCsv('inventory', 'exportType=assets')" class="bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700 font-medium text-sm">Export Assets</button>
        <button onclick="exportCsv('inventory', 'exportType=items')" class="bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700 font-medium text-sm">Export Items</button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div class="bg-white rounded-lg shadow p-5"><div class="text-sm text-gray-500">Assets</div><div class="text-2xl font-bold text-gray-900 mt-1">{allAssets.length}</div></div>
      <div class="bg-white rounded-lg shadow p-5"><div class="text-sm text-gray-500">Inventory Items</div><div class="text-2xl font-bold text-gray-900 mt-1">{allItems.length}</div></div>
      <div class="bg-white rounded-lg shadow p-5"><div class="text-sm text-gray-500">Low Stock</div><div class="text-2xl font-bold text-yellow-600 mt-1">{allItems.filter((i: any) => i.quantity <= i.reorderLevel).length}</div></div>
      <div class="bg-white rounded-lg shadow p-5"><div class="text-sm text-gray-500">Damaged</div><div class="text-2xl font-bold text-red-600 mt-1">{allAssets.filter((a: any) => a.condition === 'damaged' || a.condition === 'decommissioned').length}</div></div>
    </div>

    <!-- Assets Table -->
    <div class="bg-white rounded-lg shadow">
      <div class="p-4 border-b border-gray-200 flex flex-col sm:flex-row gap-3 justify-between items-center">
        <h3 class="text-lg font-semibold">Assets</h3>
        <input id="searchAssets" type="text" placeholder="Search assets..." class="px-3 py-2 border border-gray-300 rounded-lg" />
      </div>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Serial #</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Location</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Condition</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            {allAssets.length === 0 ? (
              <tr><td colspan="6" class="px-6 py-8 text-center text-gray-500">No assets registered.</td></tr>
            ) : (
              allAssets.map((asset: any) => (
                <tr class="hover:bg-gray-50 asset-row" data-name={`${asset.name} ${asset.category || ''}`.toLowerCase()}>
                  <td class="px-6 py-4 text-sm font-medium text-gray-900">{asset.name}</td>
                  <td class="px-6 py-4 text-sm text-gray-600">{asset.category || '-'}</td>
                  <td class="px-6 py-4 text-sm text-gray-600 font-mono">{asset.serialNumber || '-'}</td>
                  <td class="px-6 py-4 text-sm text-gray-600">{asset.location || '-'}</td>
                  <td class="px-6 py-4">
                    <span class={`px-2 py-1 text-xs font-medium rounded ${asset.condition === 'new' ? 'bg-green-100 text-green-700' : asset.condition === 'good' ? 'bg-blue-100 text-blue-700' : asset.condition === 'fair' ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700'}`}>{asset.condition}</span>
                  </td>
                  <td class="px-6 py-4 text-sm">
                    <button onclick={`confirmDeleteAsset(${asset.id}, '${asset.name.replace(/'/g, "\\'")}')`} class="text-red-600 hover:text-red-700">Delete</button>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Inventory Items Table -->
    <div class="bg-white rounded-lg shadow">
      <div class="p-4 border-b border-gray-200 flex flex-col sm:flex-row gap-3 justify-between items-center">
        <h3 class="text-lg font-semibold">Inventory Items</h3>
        <input id="searchItems" type="text" placeholder="Search items..." class="px-3 py-2 border border-gray-300 rounded-lg" />
      </div>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Qty</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Reorder</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Unit</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Supplier</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            {allItems.length === 0 ? (
              <tr><td colspan="7" class="px-6 py-8 text-center text-gray-500">No inventory items.</td></tr>
            ) : (
              allItems.map((item: any) => (
                <tr class="hover:bg-gray-50 item-row" data-name={`${item.name} ${item.category || ''}`.toLowerCase()}>
                  <td class="px-6 py-4 text-sm font-medium text-gray-900">{item.name}</td>
                  <td class="px-6 py-4 text-sm text-gray-600">{item.category || '-'}</td>
                  <td class="px-6 py-4 text-sm">
                    <span class={`font-medium ${item.quantity <= item.reorderLevel ? 'text-red-600' : 'text-gray-900'}`}>{item.quantity}</span>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-600">{item.reorderLevel}</td>
                  <td class="px-6 py-4 text-sm text-gray-600">{item.unit || '-'}</td>
                  <td class="px-6 py-4 text-sm text-gray-600">{item.supplier || '-'}</td>
                  <td class="px-6 py-4 text-sm">
                    <button onclick={`confirmDeleteItem(${item.id}, '${item.name.replace(/'/g, "\\'")}')`} class="text-red-600 hover:text-red-700">Delete</button>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Add Asset Modal -->
  <div id="addAssetModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4 max-h-[90vh] overflow-y-auto">
      <div class="p-6 border-b border-gray-200 flex justify-between items-center">
        <h3 class="text-lg font-semibold">Add Asset</h3>
        <button onclick="document.getElementById('addAssetModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
      </div>
      <form id="addAssetForm" class="p-6 space-y-4">
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Name *</label><input name="name" required class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Category</label><input name="category" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Serial Number</label><input name="serialNumber" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Location</label><input name="location" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Condition</label>
            <select name="condition" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
              <option value="new">New</option><option value="good">Good</option><option value="fair">Fair</option><option value="damaged">Damaged</option><option value="decommissioned">Decommissioned</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Purchase Date</label><input name="purchaseDate" type="date" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Purchase Price</label><input name="purchasePrice" type="number" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
        </div>
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Description</label><textarea name="description" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg"></textarea></div>
        <div id="addAssetError" class="text-red-600 text-sm hidden"></div>
        <div class="flex justify-end gap-3 pt-4 border-t border-gray-200">
          <button type="button" onclick="document.getElementById('addAssetModal').classList.add('hidden')" class="px-4 py-2 text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700">Add Asset</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Add Item Modal -->
  <div id="addItemModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4">
      <div class="p-6 border-b border-gray-200 flex justify-between items-center">
        <h3 class="text-lg font-semibold">Add Inventory Item</h3>
        <button onclick="document.getElementById('addItemModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
      </div>
      <form id="addItemForm" class="p-6 space-y-4">
        <div><label class="block text-sm font-medium text-gray-700 mb-1">Name *</label><input name="name" required class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
        <div class="grid grid-cols-3 gap-4">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Category</label><input name="category" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Quantity</label><input name="quantity" type="number" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Reorder Level</label><input name="reorderLevel" type="number" value="5" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Unit</label><input name="unit" placeholder="pcs, kg, etc." class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Supplier</label><input name="supplier" class="w-full px-3 py-2 border border-gray-300 rounded-lg" /></div>
        </div>
        <div id="addItemError" class="text-red-600 text-sm hidden"></div>
        <div class="flex justify-end gap-3 pt-4 border-t border-gray-200">
          <button type="button" onclick="document.getElementById('addItemModal').classList.add('hidden')" class="px-4 py-2 text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700">Add Item</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Modal -->
  <div id="deleteModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-sm mx-4 p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-2">Confirm Delete</h3>
      <p class="text-gray-600 mb-6">Are you sure you want to delete <strong id="deleteName"></strong>?</p>
      <div class="flex justify-end gap-3">
        <button onclick="document.getElementById('deleteModal').classList.add('hidden')" class="px-4 py-2 text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</button>
        <button id="confirmDeleteBtn" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">Delete</button>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('searchAssets')?.addEventListener('input', (e: Event) => {
      const q = ((e.target as HTMLInputElement).value || '').toLowerCase();
      document.querySelectorAll('.asset-row').forEach((row: Element) => {
        const el = row as HTMLElement;
        el.style.display = !q || (el.dataset.name || '').includes(q) ? '' : 'none';
      });
    });

    document.getElementById('searchItems')?.addEventListener('input', (e: Event) => {
      const q = ((e.target as HTMLInputElement).value || '').toLowerCase();
      document.querySelectorAll('.item-row').forEach((row: Element) => {
        const el = row as HTMLElement;
        el.style.display = !q || (el.dataset.name || '').includes(q) ? '' : 'none';
      });
    });

    document.getElementById('addAssetForm')?.addEventListener('submit', async (e: Event) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const data = Object.fromEntries(new FormData(form));
      if (data.purchasePrice) data.purchasePrice = Number(data.purchasePrice);
      const errEl = document.getElementById('addAssetError')!;
      errEl.classList.add('hidden');
      try {
        const res = await fetch('/api/dashboard/inventory', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type: 'asset', ...data }) });
        if (!res.ok) { const err = await res.json(); throw new Error(err.error || 'Failed'); }
        window.location.reload();
      } catch (err: any) { errEl.textContent = err.message; errEl.classList.remove('hidden'); }
    });

    document.getElementById('addItemForm')?.addEventListener('submit', async (e: Event) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const data = Object.fromEntries(new FormData(form));
      if (data.quantity) data.quantity = Number(data.quantity);
      if (data.reorderLevel) data.reorderLevel = Number(data.reorderLevel);
      const errEl = document.getElementById('addItemError')!;
      errEl.classList.add('hidden');
      try {
        const res = await fetch('/api/dashboard/inventory', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type: 'item', ...data }) });
        if (!res.ok) { const err = await res.json(); throw new Error(err.error || 'Failed'); }
        window.location.reload();
      } catch (err: any) { errEl.textContent = err.message; errEl.classList.remove('hidden'); }
    });

    let deleteTarget: { id: number; type: string } | null = null;
    (window as any).confirmDeleteAsset = (id: number, name: string) => {
      deleteTarget = { id, type: 'asset' };
      document.getElementById('deleteName')!.textContent = name;
      document.getElementById('deleteModal')!.classList.remove('hidden');
    };
    (window as any).confirmDeleteItem = (id: number, name: string) => {
      deleteTarget = { id, type: 'item' };
      document.getElementById('deleteName')!.textContent = name;
      document.getElementById('deleteModal')!.classList.remove('hidden');
    };

    document.getElementById('confirmDeleteBtn')?.addEventListener('click', async () => {
      if (!deleteTarget) return;
      try {
        await fetch('/api/dashboard/inventory', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: deleteTarget.id, type: deleteTarget.type }) });
        window.location.reload();
      } catch { document.getElementById('deleteModal')!.classList.add('hidden'); }
    });
  </script>
</DashboardLayout>
