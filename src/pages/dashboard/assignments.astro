---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { assignments, courses } from '../../lib/db/schema.js';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/auth/login');
const schoolId = getUserSchoolId(user.id);

let records: any[] = [];
let allCourses: any[] = [];
let stats = { total: 0, essay: 0, file: 0, link: 0 };

if (schoolId) {
  const db = getDb();
  allCourses = db.select().from(courses).where(eq(courses.schoolId, schoolId)).all();
  records = db.select().from(assignments).where(eq(assignments.schoolId, schoolId)).orderBy(desc(assignments.createdAt)).all();
  stats = { total: records.length, essay: records.filter(r => r.type === 'essay').length, file: records.filter(r => r.type === 'file_upload').length, link: records.filter(r => r.type === 'link').length };
}
---

<DashboardLayout title="Assignments - iSchool">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <div><h2 class="text-2xl font-bold text-gray-900">Assignments</h2><p class="text-sm text-gray-500 mt-1">Manage course assignments</p></div>
      <button onclick="document.getElementById('addModal').classList.remove('hidden')" class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 font-medium text-sm">+ Add Assignment</button>
      <button onclick="exportCsv('assignments')" class="bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700 font-medium text-sm">Export CSV</button>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Total</p><p class="text-2xl font-bold">{stats.total}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Essay</p><p class="text-2xl font-bold text-blue-600">{stats.essay}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">File Upload</p><p class="text-2xl font-bold text-green-600">{stats.file}</p></div>
      <div class="bg-white rounded-lg border p-4"><p class="text-sm text-gray-500">Link</p><p class="text-2xl font-bold text-purple-600">{stats.link}</p></div>
    </div>
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="p-4 border-b flex gap-3">
        <input type="text" id="searchInput" placeholder="Search assignments..." class="border rounded-lg px-3 py-2 text-sm flex-1" oninput="filterTable()" />
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm" id="dataTable">
          <thead class="bg-gray-50"><tr>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Title</th><th class="px-4 py-3 text-left font-medium text-gray-600">Course</th>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Type</th><th class="px-4 py-3 text-left font-medium text-gray-600">Due Date</th>
            <th class="px-4 py-3 text-left font-medium text-gray-600">Max Points</th><th class="px-4 py-3 text-left font-medium text-gray-600">Actions</th>
          </tr></thead>
          <tbody class="divide-y">
            {records.length === 0 && <tr><td colspan="6" class="px-4 py-8 text-center text-gray-500">No assignments found</td></tr>}
            {records.map(r => {
              const course = allCourses.find(c => c.id === r.courseId);
              return (
              <tr data-search={r.title.toLowerCase()}>
                <td class="px-4 py-3 font-medium">{r.title}</td>
                <td class="px-4 py-3">{course?.title || '-'}</td>
                <td class="px-4 py-3"><span class="px-2 py-1 rounded-full text-xs bg-gray-100">{r.type}</span></td>
                <td class="px-4 py-3">{r.dueDate || '-'}</td>
                <td class="px-4 py-3">{r.maxPoints}</td>
                <td class="px-4 py-3 flex gap-2">
                  <button onclick={`editRecord(${JSON.stringify(r)})`} class="text-primary-600 hover:text-primary-800 text-xs font-medium">Edit</button>
                  <button onclick={`deleteRecord(${r.id})`} class="text-red-600 hover:text-red-800 text-xs font-medium">Delete</button>
                </td>
              </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="addModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl p-6 w-full max-w-md mx-4">
      <h3 class="text-lg font-bold mb-4" id="modalTitle">Add Assignment</h3>
      <form onsubmit="submitForm(event)">
        <input type="hidden" id="editId" value="" />
        <div class="space-y-3">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
            <input type="text" id="title" required class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Course</label>
            <select id="courseId" required class="w-full border rounded-lg px-3 py-2 text-sm">
              <option value="">Select</option>{allCourses.map(c => <option value={c.id}>{c.title}</option>)}
            </select></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Instructions</label>
            <textarea id="instructions" class="w-full border rounded-lg px-3 py-2 text-sm" rows="3"></textarea></div>
          <div class="grid grid-cols-2 gap-3">
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
              <select id="type" class="w-full border rounded-lg px-3 py-2 text-sm">
                <option value="file_upload">File Upload</option><option value="essay">Essay</option>
                <option value="link">Link</option><option value="offline">Offline</option>
              </select></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Max Points</label>
              <input type="number" id="maxPoints" class="w-full border rounded-lg px-3 py-2 text-sm" value="100" /></div>
          </div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">Due Date</label>
            <input type="date" id="dueDate" class="w-full border rounded-lg px-3 py-2 text-sm" /></div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')" class="px-4 py-2 border rounded-lg text-sm">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary-600 text-white rounded-lg text-sm hover:bg-primary-700">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function filterTable() {
      const s = (document.getElementById('searchInput') as HTMLInputElement).value.toLowerCase();
      document.querySelectorAll('#dataTable tbody tr[data-search]').forEach(r => { (r as HTMLElement).style.display = !s || (r as HTMLElement).dataset.search!.includes(s) ? '' : 'none'; });
    }
    function editRecord(r: any) {
      (document.getElementById('editId') as HTMLInputElement).value = String(r.id);
      (document.getElementById('title') as HTMLInputElement).value = r.title;
      (document.getElementById('courseId') as HTMLSelectElement).value = String(r.courseId || '');
      (document.getElementById('instructions') as HTMLTextAreaElement).value = r.instructions || '';
      (document.getElementById('type') as HTMLSelectElement).value = r.type;
      (document.getElementById('maxPoints') as HTMLInputElement).value = String(r.maxPoints);
      (document.getElementById('dueDate') as HTMLInputElement).value = r.dueDate || '';
      document.getElementById('modalTitle')!.textContent = 'Edit Assignment';
      document.getElementById('addModal')!.classList.remove('hidden');
    }
    async function submitForm(e: Event) {
      e.preventDefault();
      const editId = (document.getElementById('editId') as HTMLInputElement).value;
      const body: any = {
        title: (document.getElementById('title') as HTMLInputElement).value,
        courseId: parseInt((document.getElementById('courseId') as HTMLSelectElement).value),
        instructions: (document.getElementById('instructions') as HTMLTextAreaElement).value,
        type: (document.getElementById('type') as HTMLSelectElement).value,
        maxPoints: parseInt((document.getElementById('maxPoints') as HTMLInputElement).value),
        dueDate: (document.getElementById('dueDate') as HTMLInputElement).value || null,
      };
      const method = editId ? 'PUT' : 'POST';
      if (editId) body.id = parseInt(editId);
      await fetch('/api/dashboard/assignments', { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      location.reload();
    }
    async function deleteRecord(id: number) {
      if (!confirm('Delete this assignment?')) return;
      await fetch('/api/dashboard/assignments', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
      location.reload();
    }
  </script>
</DashboardLayout>
