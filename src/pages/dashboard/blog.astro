---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Input from '../../components/ui/Input.astro';
import Button from '../../components/ui/Button.astro';
import { getUserSchoolId } from '../../lib/school.js';
import { getDb } from '../../lib/db/index.js';
import { blogPosts } from '../../lib/db/schema.js';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
const schoolId = getUserSchoolId(user.id);
const db = getDb();

const posts = schoolId ? db.select().from(blogPosts).where(eq(blogPosts.schoolId, schoolId)).orderBy(desc(blogPosts.createdAt)).all() : [];
const success = Astro.url.searchParams.get('success');
const editId = Astro.url.searchParams.get('edit');
const editing = editId ? posts.find(p => p.id === Number(editId)) : null;
---

<DashboardLayout title="Blog - iSchool">
  {success && (
    <div class="mb-6 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Blog post saved successfully.</div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <h2 class="text-base font-semibold text-gray-900 mb-4">{editing ? 'Edit' : 'New'} Post</h2>
        <form method="POST" action="/api/dashboard/blog" class="space-y-4">
          {editing && <input type="hidden" name="id" value={editing.id} />}
          <Input label="Title" name="title" value={editing?.title || ''} placeholder="Post title" required />
          <Input label="Slug" name="slug" value={editing?.slug || ''} placeholder="post-url-slug" />
          <Input label="Excerpt" name="excerpt" value={editing?.excerpt || ''} placeholder="Brief summary..." rows={2} />
          <Input label="Cover Image URL" name="coverImageUrl" value={editing?.coverImageUrl || ''} placeholder="https://..." />
          <Input label="Content" name="content" value={editing?.content || ''} placeholder="Full post content..." rows={8} required />
          <div class="flex items-center gap-2">
            <input type="checkbox" id="isPublished" name="isPublished" checked={editing?.isPublished || false} class="rounded border-gray-300" />
            <label for="isPublished" class="text-sm text-gray-700">Publish now</label>
          </div>
          <Button type="submit" full>{editing ? 'Update' : 'Create'} Post</Button>
          {editing && (
            <a href="/dashboard/blog" class="block text-center text-sm text-gray-500 hover:text-gray-700">Cancel Edit</a>
          )}
        </form>
      </div>
    </div>

    <div class="lg:col-span-2">
      <div class="bg-white rounded-xl border border-gray-200">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-base font-semibold text-gray-900">All Posts ({posts.length})</h2>
        </div>
        <div class="divide-y divide-gray-100">
          {posts.length === 0 && <p class="p-6 text-sm text-gray-500 text-center">No blog posts yet. Write your first one.</p>}
          {posts.map(post => (
            <div class="px-6 py-4 flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="text-sm font-medium text-gray-900 truncate">{post.title}</h3>
                  {post.isPublished ? (
                    <span class="text-xs bg-green-100 text-green-700 px-1.5 py-0.5 rounded">Published</span>
                  ) : (
                    <span class="text-xs bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded">Draft</span>
                  )}
                </div>
                <p class="text-sm text-gray-500 line-clamp-1">{post.excerpt || post.content}</p>
                <p class="text-xs text-gray-400 mt-1">/{post.slug}</p>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <a href={`?edit=${post.id}`} class="text-xs text-primary-600 hover:text-primary-700">Edit</a>
                <form method="POST" action="/api/dashboard/blog">
                  <input type="hidden" name="id" value={post.id} />
                  <input type="hidden" name="action" value="delete" />
                  <button type="submit" class="text-xs text-red-500 hover:text-red-700">Delete</button>
                </form>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>
