---
import Layout from '../../layouts/MarketingLayout.astro';
import Input from '../../components/ui/Input.astro';
import Button from '../../components/ui/Button.astro';

const message = Astro.url.searchParams.get('message');
const error = Astro.url.searchParams.get('error');
---

<Layout title="Forgot Password - iSchool">
  <div class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Reset Password</h1>
        <p class="mt-2 text-sm text-gray-600">Enter your email and we'll send you a reset link</p>
      </div>

      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
        {message && (
          <div class="mb-6 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">{message}</div>
        )}
        {error && (
          <div class="mb-6 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">{error}</div>
        )}

        <div id="reset-result" class="hidden mb-6 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700"></div>

        <form id="reset-form" class="space-y-5">
          <Input label="Email Address" name="email" type="email" placeholder="you@school.edu" required />
          <Button type="submit" full>Send Reset Link</Button>
        </form>
      </div>

      <p class="mt-6 text-center text-sm text-gray-600">
        Remember your password?{' '}
        <a href="/auth/login" class="font-medium text-primary-600 hover:text-primary-700">Sign in</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  document.getElementById('reset-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const email = (form.querySelector('[name="email"]') as HTMLInputElement).value;
    const resultEl = document.getElementById('reset-result')!;
    try {
      const res = await fetch('/api/auth/password-reset', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const data = await res.json();
      resultEl.textContent = data.message || 'Reset link sent!';
      resultEl.classList.remove('hidden');
    } catch {
      resultEl.textContent = 'Something went wrong. Please try again.';
      resultEl.classList.remove('hidden');
    }
  });
</script>
