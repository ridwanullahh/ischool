---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { getDb } from '../../lib/db/index.js';
import { platformBlogPosts } from '../../lib/db/schema.js';
import { eq, desc, and } from 'drizzle-orm';
import { formatDate } from '../../lib/utils.js';

const db = getDb();
const posts = db.select().from(platformBlogPosts)
  .where(eq(platformBlogPosts.isPublished, true))
  .orderBy(desc(platformBlogPosts.publishedAt)).all();
---

<MarketingLayout title="Blog - iSchool">
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-gray-900">Blog</h1>
      <p class="mt-3 text-lg text-gray-600">Insights, updates, and stories from the iSchool team.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length === 0 ? (
        <p class="text-gray-500 text-center py-12">No posts yet. Check back soon!</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map(post => (
            <a href={`/blog/${post.slug}`} class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow group">
              {post.coverImageUrl && (
                <img src={post.coverImageUrl} alt={post.title} class="w-full h-48 object-cover" loading="lazy" />
              )}
              <div class="p-6">
                <div class="flex items-center gap-2 mb-2">
                  {post.category && <span class="text-xs font-medium bg-primary-50 text-primary-700 px-2 py-0.5 rounded-full">{post.category}</span>}
                  {post.publishedAt && <span class="text-xs text-gray-500">{formatDate(post.publishedAt)}</span>}
                </div>
                <h2 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-primary-600 transition-colors">{post.title}</h2>
                <p class="text-sm text-gray-600 line-clamp-2">{post.excerpt || post.content}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</MarketingLayout>
