---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Page Not Found - iSchool">
  <div class="min-h-[60vh] flex items-center justify-center px-4">
    <div class="text-center">
      <h1 class="text-6xl font-extrabold text-gray-200">404</h1>
      <h2 class="mt-4 text-2xl font-bold text-gray-900">Page not found</h2>
      <p class="mt-2 text-gray-600">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="mt-8 inline-flex items-center justify-center px-6 py-3 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 shadow-sm">
        Back to Home
      </a>
    </div>
  </div>
</MarketingLayout>
