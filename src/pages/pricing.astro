---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { getDb } from '../lib/db/index.js';
import { subscriptionPlans } from '../lib/db/schema.js';

const db = getDb();
const plans = db.select().from(subscriptionPlans).where(subscriptionPlans.isActive).orderBy(subscriptionPlans.sortOrder).all();
---

<MarketingLayout title="Pricing - iSchool" description="Simple, transparent pricing for school management software. Start free, upgrade when you're ready.">
  <section class="py-20 sm:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block text-sm font-bold text-primary-600 bg-primary-50 px-3 py-1 rounded-full mb-4">PRICING</span>
        <h1 class="text-4xl sm:text-5xl font-black text-gray-900 tracking-tight">Simple, transparent pricing</h1>
        <p class="mt-4 text-lg text-gray-600">Choose the plan that fits your school. Start with a free plan, upgrade as you grow. All plans include a 14-day free trial.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
        {plans.map(plan => {
          const features = (plan.features as string[]) || [];
          return (
            <div class:list={['bg-white rounded-2xl p-6 shadow-sm relative flex flex-col', plan.isPopular ? 'border-2 border-primary-500 shadow-xl shadow-primary-100' : 'border border-gray-200']}>
              {plan.isPopular && <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-gradient-to-r from-primary-600 to-primary-700 text-white text-xs font-bold px-4 py-1 rounded-full shadow-lg">Most Popular</div>}
              {plan.isFree && <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-green-500 text-white text-xs font-bold px-4 py-1 rounded-full">Free Forever</div>}
              <div class="mb-4">
                <h3 class="text-lg font-bold text-gray-900">{plan.name}</h3>
                <p class="text-sm text-gray-500 mt-1">{plan.description}</p>
              </div>
              <div class="mb-6">
                <div class="flex items-baseline gap-1">
                  <span class="text-4xl font-black text-gray-900">${(plan.monthlyPrice / 100).toFixed(0)}</span>
                  <span class="text-gray-500 text-sm">/mo</span>
                </div>
                {plan.annualPrice > 0 && (
                  <p class="text-sm text-gray-500 mt-1">or ${(plan.annualPrice / 100).toFixed(0)}/year <span class="text-green-600 font-medium">(save {Math.round((1 - plan.annualPrice / (plan.monthlyPrice * 12)) * 100)}%)</span></p>
                )}
              </div>
              <ul class="space-y-2.5 mb-6 flex-1">
                {features.map(f => (
                  <li class="flex items-start gap-2.5 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    {f}
                  </li>
                ))}
                <li class="flex items-start gap-2.5 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Up to {plan.maxStudents || 'Unlimited'} students
                </li>
                <li class="flex items-start gap-2.5 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Up to {plan.maxStaff || 'Unlimited'} staff
                </li>
                {plan.customDomain && <li class="flex items-start gap-2.5 text-sm text-gray-600"><svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Custom domain</li>}
                {plan.apiAccess && <li class="flex items-start gap-2.5 text-sm text-gray-600"><svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>API access</li>}
                {plan.prioritySupport && <li class="flex items-start gap-2.5 text-sm text-gray-600"><svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Priority support</li>}
              </ul>
              <a href={`/checkout?plan=${plan.slug}`} class:list={['block w-full text-center px-4 py-3 text-sm font-bold rounded-xl transition-all', plan.isPopular ? 'text-white bg-gradient-to-r from-primary-600 to-primary-700 hover:from-primary-700 hover:to-primary-800 shadow-lg shadow-primary-200' : plan.isFree ? 'text-green-700 bg-green-50 border border-green-200 hover:bg-green-100' : 'text-primary-700 border-2 border-primary-200 hover:bg-primary-50']}>
                {plan.isFree ? 'Get Started Free' : 'Start Free Trial'}
              </a>
            </div>
          );
        })}
      </div>

      {plans.length === 0 && (
        <div class="text-center py-16">
          <p class="text-gray-500 text-lg">No plans available yet. Contact us for custom pricing.</p>
          <a href="/contact" class="mt-4 inline-block text-primary-600 font-semibold hover:text-primary-700">Contact Sales</a>
        </div>
      )}

      <div class="mt-16 text-center">
        <p class="text-gray-500 text-sm">All paid plans include a {plans[0]?.trialDays || 14}-day free trial. No credit card required. Cancel anytime.</p>
        <div class="mt-6 flex items-center justify-center gap-6 text-sm text-gray-500">
          <span class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg> Secure payments</span>
          <span class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Stripe, PayPal, Paystack</span>
          <span class="flex items-center gap-2"><svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Coupon codes accepted</span>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
