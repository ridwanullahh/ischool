---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const modules = [
  { slug: 'sis', name: 'Student Information System', icon: '👨‍🎓', desc: 'Complete student records, enrollment management, attendance tracking, and parent portals. Everything about your students in one place.', color: 'from-blue-500 to-blue-600' },
  { slug: 'lms', name: 'Learning Management System', icon: '📚', desc: 'Create courses, upload lessons, manage assignments, quizzes, and track student progress with a modern LMS built for schools.', color: 'from-purple-500 to-purple-600' },
  { slug: 'timetable', name: 'Timetable & Scheduling', icon: '📅', desc: 'Smart timetable generation, bell schedules, academic period management, and conflict-free class scheduling.', color: 'from-teal-500 to-teal-600' },
  { slug: 'exams', name: 'Examinations & Results', icon: '📝', desc: 'Exam series management, result processing, report card generation, and comprehensive academic analytics.', color: 'from-red-500 to-red-600' },
  { slug: 'finance', name: 'Finance & Fee Management', icon: '💰', desc: 'Fee structures, automated invoicing, payment collection via Stripe/PayPal/Paystack, and financial reporting.', color: 'from-green-500 to-green-600' },
  { slug: 'hr', name: 'HR & Staff Management', icon: '👔', desc: 'Staff records, leave management, payroll processing, qualifications tracking, and performance reviews.', color: 'from-amber-500 to-amber-600' },
  { slug: 'communication', name: 'Communication Hub', icon: '💬', desc: 'Internal messaging, broadcast notifications, email/SMS integration, and parent-teacher communication channels.', color: 'from-pink-500 to-pink-600' },
  { slug: 'library', name: 'Library Management', icon: '📖', desc: 'Book cataloging, loan management, barcode scanning, fine tracking, and digital library integration.', color: 'from-indigo-500 to-indigo-600' },
  { slug: 'hostel', name: 'Hostel & Dormitory', icon: '🏠', desc: 'Room allocation, bed management, warden assignment, occupancy tracking, and hostel fee billing.', color: 'from-cyan-500 to-cyan-600' },
  { slug: 'transport', name: 'Transport Management', icon: '🚌', desc: 'Route planning, vehicle tracking, driver management, student transport assignments, and GPS integration.', color: 'from-orange-500 to-orange-600' },
  { slug: 'inventory', name: 'Inventory & Assets', icon: '📦', desc: 'Asset tracking, inventory management, depreciation calculation, reorder alerts, and barcode integration.', color: 'from-emerald-500 to-emerald-600' },
  { slug: 'events', name: 'Events & Calendar', icon: '🎉', desc: 'School event management, calendar scheduling, RSVP tracking, audience targeting, and event reminders.', color: 'from-violet-500 to-violet-600' },
  { slug: 'classroom', name: 'Classroom Tools', icon: '🎯', desc: 'Lesson planning, behavior logging, student merit/demerit tracking, and teaching aid management.', color: 'from-rose-500 to-rose-600' },
  { slug: 'analytics', name: 'Reports & Analytics', icon: '📊', desc: 'Custom report builder, enrollment analytics, financial dashboards, academic performance insights, and saved reports.', color: 'from-sky-500 to-sky-600' },
  { slug: 'it-admin', name: 'IT & System Admin', icon: '🛡️', desc: 'Module enable/disable controls, audit logs, user permission management, system settings, and security monitoring.', color: 'from-slate-500 to-slate-600' },
  { slug: 'cbt', name: 'e-Exam & CBT', icon: '💻', desc: 'Computer-based testing, exam lockdown mode, proctoring, auto-grading, integrity reports, and candidate management.', color: 'from-fuchsia-500 to-fuchsia-600' },
];

const testimonials = [
  { name: 'Dr. Khadijah Ibrahim', role: 'Principal, Darul Hikmah School', text: 'iSchool transformed how we manage our school. The Cambridge exam integration and Arabic immersion tracking are game-changers.' },
  { name: 'Ustadh Ahmad Al-Farsi', role: 'Director, Al-Noor Islamic Academy', text: 'From Hifz tracking to fee collection, everything just works. Parents love the portal, and our admin time has been cut by 60%.' },
  { name: 'Sarah Thompson', role: 'IT Director, Green Valley Schools', text: 'We evaluated 12 platforms before choosing iSchool. The CBT module alone saved us thousands in external exam software costs.' },
];
---

<MarketingLayout>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-gray-50 via-white to-primary-50">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute -top-40 -right-40 w-80 h-80 bg-primary-100 rounded-full opacity-30 blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-blue-100 rounded-full opacity-30 blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-36">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 bg-white border border-primary-200 text-primary-700 rounded-full px-4 py-1.5 text-sm font-medium mb-8 shadow-sm">
          <span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-400 opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-primary-500"></span></span>
          Trusted by 500+ schools across 30 countries
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-black text-gray-900 leading-[1.1] tracking-tight">
          One platform to run your{' '}
          <span class="bg-gradient-to-r from-primary-600 via-blue-600 to-primary-700 bg-clip-text text-transparent">entire school</span>
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto">
          16 powerful modules. From student enrollment to report cards, from fee collection to e-exams.
          Everything your school needs, unified in one beautiful dashboard.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/auth/register" class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-bold text-white bg-gradient-to-r from-primary-600 to-primary-700 rounded-2xl hover:from-primary-700 hover:to-primary-800 shadow-xl shadow-primary-200 transition-all hover:shadow-2xl hover:shadow-primary-300 hover:-translate-y-0.5">
            Start Free — No Card Required
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href="/pricing" class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-semibold text-gray-700 bg-white border-2 border-gray-200 rounded-2xl hover:border-primary-300 hover:bg-primary-50 transition-all">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            View Pricing
          </a>
        </div>
        <div class="mt-8 flex items-center justify-center gap-6 text-sm text-gray-500">
          <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> 14-day free trial</span>
          <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> No credit card</span>
          <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Cancel anytime</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof Bar -->
  <section class="border-y border-gray-100 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div><p class="text-3xl font-black text-gray-900">500+</p><p class="text-sm text-gray-500 mt-1">Schools Worldwide</p></div>
        <div><p class="text-3xl font-black text-gray-900">50,000+</p><p class="text-sm text-gray-500 mt-1">Students Managed</p></div>
        <div><p class="text-3xl font-black text-gray-900">16</p><p class="text-sm text-gray-500 mt-1">Integrated Modules</p></div>
        <div><p class="text-3xl font-black text-gray-900">99.9%</p><p class="text-sm text-gray-500 mt-1">Uptime SLA</p></div>
      </div>
    </div>
  </section>

  <!-- 16 Modules Section -->
  <section id="features" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block text-sm font-bold text-primary-600 bg-primary-50 px-3 py-1 rounded-full mb-4">16 MODULES, ONE PLATFORM</span>
        <h2 class="text-3xl sm:text-5xl font-black text-gray-900 tracking-tight">Every tool your school needs</h2>
        <p class="mt-4 text-lg text-gray-600 leading-relaxed">From admissions to graduation, iSchool covers every aspect of school management with purpose-built modules that work together seamlessly.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {modules.map((m, i) => (
          <a href={`/modules/${m.slug}`} class="group relative bg-white rounded-2xl border border-gray-100 p-5 hover:border-primary-200 hover:shadow-xl hover:shadow-primary-50 transition-all duration-300 hover:-translate-y-1">
            <div class={`w-11 h-11 bg-gradient-to-br ${m.color} rounded-xl flex items-center justify-center text-xl mb-3 shadow-lg`}>
              {m.icon}
            </div>
            <h3 class="text-sm font-bold text-gray-900 group-hover:text-primary-700 transition-colors mb-1.5">{m.name}</h3>
            <p class="text-xs text-gray-500 leading-relaxed line-clamp-3">{m.desc}</p>
            <div class="mt-3 flex items-center gap-1 text-xs font-semibold text-primary-600 opacity-0 group-hover:opacity-100 transition-opacity">
              Learn more <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-24 bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="inline-block text-sm font-bold text-primary-600 bg-primary-50 px-3 py-1 rounded-full mb-4">GETTING STARTED</span>
        <h2 class="text-3xl sm:text-4xl font-black text-gray-900">Up and running in 3 simple steps</h2>
        <p class="mt-4 text-lg text-gray-600">No technical expertise needed. If you can use email, you can use iSchool.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {[
          { step: '01', title: 'Create Your School', desc: 'Sign up in 30 seconds. Your school website and dashboard are created instantly.', icon: '🚀' },
          { step: '02', title: 'Add Your Content', desc: 'Students, staff, courses, fees — import everything through our intuitive dashboard.', icon: '📝' },
          { step: '03', title: 'Go Live', desc: 'Your professional school platform is live! Share it with parents, students, and staff.', icon: '🎉' },
        ].map(item => (
          <div class="relative bg-white rounded-2xl p-8 border border-gray-200 shadow-sm text-center">
            <div class="text-4xl mb-4">{item.icon}</div>
            <span class="text-5xl font-black text-primary-100 absolute top-4 right-4">{item.step}</span>
            <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
            <p class="text-gray-600 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Key Benefits -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="inline-block text-sm font-bold text-primary-600 bg-primary-50 px-3 py-1 rounded-full mb-4">WHY iSCHOOL</span>
          <h2 class="text-3xl sm:text-4xl font-black text-gray-900 tracking-tight">Built for schools that demand excellence</h2>
          <p class="mt-4 text-lg text-gray-600 leading-relaxed">Stop juggling 10 different tools. iSchool brings everything under one roof with enterprise-grade security and beautiful interfaces.</p>
          <div class="mt-8 space-y-4">
            {[
              { title: 'Unified Dashboard', desc: 'All modules accessible from one beautiful, role-based dashboard.' },
              { title: 'Beautiful School Website', desc: '21 themes, custom branding, and CMS tools for a stunning public presence.' },
              { title: 'Secure Payments', desc: 'Collect fees via Stripe, PayPal, Paystack, or Flutterwave with automated invoicing.' },
              { title: 'Data-Driven Decisions', desc: 'Real-time analytics across enrollment, academics, finance, and operations.' },
            ].map(b => (
              <div class="flex gap-4">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                </div>
                <div>
                  <p class="text-sm font-bold text-gray-900">{b.title}</p>
                  <p class="text-sm text-gray-600">{b.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-gradient-to-br from-primary-50 to-blue-50 rounded-3xl p-8 border border-primary-100">
          <div class="bg-white rounded-2xl shadow-xl p-6 border border-gray-100">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 bg-primary-600 rounded-xl flex items-center justify-center"><span class="text-white font-bold text-sm">iS</span></div>
              <div><p class="text-sm font-bold text-gray-900">Dashboard Overview</p><p class="text-xs text-gray-500">Al-Noor Islamic Academy</p></div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              {[{ label: 'Students', value: '856', color: 'bg-blue-500' }, { label: 'Revenue', value: '$42.5K', color: 'bg-green-500' }, { label: 'Attendance', value: '94.2%', color: 'bg-purple-500' }, { label: 'Active Courses', value: '24', color: 'bg-orange-500' }].map(s => (
                <div class="bg-gray-50 rounded-xl p-3">
                  <div class={`w-2 h-2 rounded-full ${s.color} mb-2`}></div>
                  <p class="text-lg font-bold text-gray-900">{s.value}</p>
                  <p class="text-xs text-gray-500">{s.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="inline-block text-sm font-bold text-primary-600 bg-primary-50 px-3 py-1 rounded-full mb-4">TESTIMONIALS</span>
        <h2 class="text-3xl sm:text-4xl font-black text-gray-900">Loved by school leaders</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map(t => (
          <div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm">
            <div class="flex gap-1 mb-4">{[...Array(5)].map(() => <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}</div>
            <p class="text-gray-700 leading-relaxed mb-6">"{t.text}"</p>
            <div>
              <p class="text-sm font-bold text-gray-900">{t.name}</p>
              <p class="text-xs text-gray-500">{t.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-primary-600 via-primary-700 to-blue-800 rounded-3xl p-12 sm:p-16 text-center relative overflow-hidden">
        <div class="absolute inset-0 opacity-10"><div class="absolute top-0 left-0 w-64 h-64 bg-white rounded-full blur-3xl"></div><div class="absolute bottom-0 right-0 w-64 h-64 bg-white rounded-full blur-3xl"></div></div>
        <div class="relative">
          <h2 class="text-3xl sm:text-5xl font-black text-white tracking-tight">Ready to transform your school?</h2>
          <p class="mt-4 text-lg text-primary-100 max-w-2xl mx-auto">Join 500+ schools already using iSchool. Start your 14-day free trial today — no credit card required.</p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/auth/register" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-primary-700 bg-white rounded-2xl hover:bg-primary-50 transition-colors shadow-xl">
              Get Started Free
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white border-2 border-white/30 rounded-2xl hover:bg-white/10 transition-colors">
              Talk to Sales
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
