---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { getDb } from '../lib/db/index.js';
import { subscriptionPlans } from '../lib/db/schema.js';
import { sql } from 'drizzle-orm';

const db = getDb();
const planSlug = Astro.url.searchParams.get('plan') || 'free';
const selectedPlan = db.select().from(subscriptionPlans).where(sql`slug = ${planSlug}`).get();
const allPlans = db.select().from(subscriptionPlans).where(subscriptionPlans.isActive).orderBy(subscriptionPlans.sortOrder).all();
const plan = selectedPlan || allPlans[0];

const gateways = [
  { id: 'stripe', name: 'Credit/Debit Card (Stripe)', desc: 'Visa, Mastercard, Amex, Apple Pay, Google Pay', icon: '💳' },
  { id: 'paypal', name: 'PayPal', desc: 'Pay with PayPal balance or linked cards', icon: '🅿️' },
  { id: 'paystack', name: 'Paystack', desc: 'Cards, Bank Transfer, USSD (Nigeria, Ghana, South Africa)', icon: '🇳🇬' },
  { id: 'flutterwave', name: 'Flutterwave', desc: 'Cards, Mobile Money, Bank Transfer (Africa-wide)', icon: '🌍' },
  { id: 'coupon', name: 'Coupon / Voucher', desc: 'Apply a coupon code for full or partial discount', icon: '🎟️' },
  { id: 'bank_transfer', name: 'Bank Transfer', desc: 'Direct wire transfer (manual verification within 24-48 hours)', icon: '🏦' },
];
---

<MarketingLayout title="Checkout - iSchool" description="Complete your subscription checkout">
  <section class="py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-3xl sm:text-4xl font-black text-gray-900">Complete Your Subscription</h1>
        <p class="mt-3 text-gray-600">Choose your plan and payment method to get started.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
        <div class="lg:col-span-3 space-y-6">
          <!-- Plan Selection -->
          <div class="bg-white rounded-2xl border border-gray-200 p-6">
            <h2 class="text-lg font-bold text-gray-900 mb-4">Select Plan</h2>
            <div class="space-y-3">
              {allPlans.map(p => (
                <label class:list={['flex items-center justify-between p-4 rounded-xl border-2 cursor-pointer transition-all', plan?.id === p.id ? 'border-primary-500 bg-primary-50' : 'border-gray-100 hover:border-primary-200']}>
                  <div class="flex items-center gap-3">
                    <input type="radio" name="plan" value={p.slug} checked={plan?.id === p.id} class="text-primary-600 border-gray-300 focus:ring-primary-500" />
                    <div>
                      <p class="text-sm font-bold text-gray-900">{p.name}</p>
                      <p class="text-xs text-gray-500">{p.description}</p>
                    </div>
                  </div>
                  <div class="text-right">
                    <p class="text-sm font-bold text-gray-900">${(p.monthlyPrice / 100).toFixed(0)}/mo</p>
                    <p class="text-xs text-gray-500">${(p.annualPrice / 100).toFixed(0)}/yr</p>
                  </div>
                </label>
              ))}
            </div>
          </div>

          <!-- Billing Cycle -->
          <div class="bg-white rounded-2xl border border-gray-200 p-6">
            <h2 class="text-lg font-bold text-gray-900 mb-4">Billing Cycle</h2>
            <div class="flex gap-3">
              <label class="flex-1 flex items-center justify-center gap-2 p-3 rounded-xl border-2 border-primary-500 bg-primary-50 cursor-pointer">
                <input type="radio" name="cycle" value="monthly" checked class="text-primary-600" />
                <span class="text-sm font-medium text-gray-900">Monthly</span>
              </label>
              <label class="flex-1 flex items-center justify-center gap-2 p-3 rounded-xl border-2 border-gray-100 hover:border-primary-200 cursor-pointer">
                <input type="radio" name="cycle" value="annual" class="text-primary-600" />
                <span class="text-sm font-medium text-gray-900">Annual <span class="text-green-600 font-bold">(Save 20%)</span></span>
              </label>
            </div>
          </div>

          <!-- Payment Gateway -->
          <div class="bg-white rounded-2xl border border-gray-200 p-6">
            <h2 class="text-lg font-bold text-gray-900 mb-4">Payment Method</h2>
            <div class="space-y-2">
              {gateways.map(g => (
                <label class="flex items-center gap-3 p-3 rounded-xl border border-gray-100 hover:border-primary-200 cursor-pointer transition-all">
                  <input type="radio" name="gateway" value={g.id} class="text-primary-600 border-gray-300 focus:ring-primary-500" />
                  <span class="text-xl">{g.icon}</span>
                  <div>
                    <p class="text-sm font-semibold text-gray-900">{g.name}</p>
                    <p class="text-xs text-gray-500">{g.desc}</p>
                  </div>
                </label>
              ))}
            </div>
          </div>

          <!-- Coupon -->
          <div class="bg-white rounded-2xl border border-gray-200 p-6">
            <h2 class="text-lg font-bold text-gray-900 mb-4">Have a coupon?</h2>
            <div class="flex gap-3">
              <input type="text" id="coupon-input" placeholder="Enter coupon code" class="flex-1 px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500 uppercase" />
              <button onclick="applyCoupon()" class="px-6 py-2.5 bg-gray-900 text-white text-sm font-semibold rounded-xl hover:bg-gray-800 transition-colors">Apply</button>
            </div>
            <p id="coupon-message" class="mt-2 text-sm hidden"></p>
          </div>
        </div>

        <!-- Order Summary -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl border border-gray-200 p-6 sticky top-24">
            <h2 class="text-lg font-bold text-gray-900 mb-4">Order Summary</h2>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-600">Plan</span>
                <span class="font-semibold text-gray-900" id="summary-plan">{plan?.name || 'N/A'}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">Billing</span>
                <span class="font-semibold text-gray-900" id="summary-cycle">Monthly</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">Subtotal</span>
                <span class="font-semibold text-gray-900" id="summary-subtotal">${plan ? (plan.monthlyPrice / 100).toFixed(2) : '0.00'}</span>
              </div>
              <div class="flex justify-between text-green-600 hidden" id="discount-row">
                <span>Discount</span>
                <span class="font-semibold" id="summary-discount">-$0.00</span>
              </div>
              <hr class="border-gray-100" />
              <div class="flex justify-between text-base">
                <span class="font-bold text-gray-900">Total</span>
                <span class="font-black text-gray-900" id="summary-total">${plan ? (plan.monthlyPrice / 100).toFixed(2) : '0.00'}</span>
              </div>
            </div>
            <button onclick="proceedToPayment()" class="mt-6 w-full py-3.5 bg-gradient-to-r from-primary-600 to-primary-700 text-white font-bold rounded-xl hover:from-primary-700 hover:to-primary-800 shadow-lg shadow-primary-200 transition-all text-sm">
              {plan?.isFree ? 'Start Free' : 'Proceed to Payment'}
            </button>
            <p class="mt-4 text-xs text-gray-500 text-center">
              {plan?.isFree ? 'No payment required for the free plan.' : `${plan?.trialDays || 14}-day free trial. Cancel anytime during trial.`}
            </p>
            <div class="mt-4 flex items-center justify-center gap-4 text-xs text-gray-400">
              <span class="flex items-center gap-1"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg> SSL Secured</span>
              <span>256-bit encryption</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    function applyCoupon() {
      const input = document.getElementById('coupon-input') as HTMLInputElement;
      const msg = document.getElementById('coupon-message')!;
      if (!input.value.trim()) return;
      msg.classList.remove('hidden');
      msg.className = 'mt-2 text-sm text-green-600 font-medium';
      msg.textContent = `Coupon "${input.value.toUpperCase()}" applied!`;
    }

    function proceedToPayment() {
      const planRadio = document.querySelector('input[name="plan"]:checked') as HTMLInputElement;
      const cycleRadio = document.querySelector('input[name="cycle"]:checked') as HTMLInputElement;
      const gatewayRadio = document.querySelector('input[name="gateway"]:checked') as HTMLInputElement;
      const coupon = (document.getElementById('coupon-input') as HTMLInputElement).value;

      if (!planRadio) { alert('Please select a plan'); return; }
      if (!gatewayRadio) { alert('Please select a payment method'); return; }

      const user = document.querySelector('a[href="/dashboard"]');
      if (!user) {
        window.location.href = `/auth/register?plan=${planRadio.value}&cycle=${cycleRadio?.value || 'monthly'}&gateway=${gatewayRadio.value}${coupon ? '&coupon=' + coupon : ''}`;
      } else {
        alert('Subscription flow initiated. In production, this redirects to the payment gateway.');
      }
    }
  </script>
</MarketingLayout>
