---
import { getThemeLayout } from '../../themes/index.js';
import { getDb } from '../../lib/db/index.js';
import { schools, contactInfo, contactSubmissions } from '../../lib/db/schema.js';
import { eq, asc } from 'drizzle-orm';

const slug = Astro.params.slug!;
const db = getDb();
const school = db.select().from(schools).where(eq(schools.slug, slug)).get();
if (!school) return Astro.redirect('/404');

const Layout = getThemeLayout(school.theme || 'harmony');

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const data: Record<string, string> = {};
  form.forEach((value, key) => { if (key !== 'formType') data[key] = value.toString(); });
  db.insert(contactSubmissions).values({
    schoolId: school.id,
    formType: 'general',
    data,
  }).run();
  return Astro.redirect(`/${slug}/contact?success=1`);
}

const contacts = db.select().from(contactInfo)
  .where(eq(contactInfo.schoolId, school.id)).orderBy(asc(contactInfo.sortOrder)).all();

const generalContacts = contacts.filter(c => c.type === 'general');
const success = Astro.url.searchParams.get('success');
---

<Layout school={school} title="Contact">
  <section class="py-16 bg-[var(--bg)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-[var(--text)]">Contact Us</h1>
      <p class="mt-2 text-[var(--muted)]">We'd love to hear from you</p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        {success && (
          <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">
            Thank you! Your message has been sent. We'll get back to you soon.
          </div>
        )}

        <h2 class="text-xl font-semibold text-[var(--text)] mb-6">Send us a message</h2>
        <form method="POST" action={`/${slug}/contact`} class="space-y-5">
          <input type="hidden" name="formType" value="general" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="space-y-1">
              <label class="block text-sm font-medium text-[var(--text)]">Name *</label>
              <input type="text" name="name" required class="block w-full rounded-lg border border-[var(--border)] px-3 py-2.5 text-sm bg-[var(--surface)] text-[var(--text)] focus:border-[var(--primary)] focus:outline-none focus:ring-1 focus:ring-[var(--primary)]" />
            </div>
            <div class="space-y-1">
              <label class="block text-sm font-medium text-[var(--text)]">Email *</label>
              <input type="email" name="email" required class="block w-full rounded-lg border border-[var(--border)] px-3 py-2.5 text-sm bg-[var(--surface)] text-[var(--text)] focus:border-[var(--primary)] focus:outline-none focus:ring-1 focus:ring-[var(--primary)]" />
            </div>
          </div>
          <div class="space-y-1">
            <label class="block text-sm font-medium text-[var(--text)]">Phone</label>
            <input type="tel" name="phone" class="block w-full rounded-lg border border-[var(--border)] px-3 py-2.5 text-sm bg-[var(--surface)] text-[var(--text)] focus:border-[var(--primary)] focus:outline-none focus:ring-1 focus:ring-[var(--primary)]" />
          </div>
          <div class="space-y-1">
            <label class="block text-sm font-medium text-[var(--text)]">Message *</label>
            <textarea name="message" required rows={5} class="block w-full rounded-lg border border-[var(--border)] px-3 py-2.5 text-sm bg-[var(--surface)] text-[var(--text)] focus:border-[var(--primary)] focus:outline-none focus:ring-1 focus:ring-[var(--primary)]"></textarea>
          </div>
          <button type="submit" class="w-full px-6 py-3 text-sm font-medium text-white rounded-lg bg-[var(--primary)] hover:opacity-90 transition-opacity shadow-sm">
            Send Message
          </button>
        </form>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--text)] mb-6">Get in touch</h2>
        <div class="space-y-4">
          {generalContacts.map(c => (
            <div class="flex items-start gap-3 p-4 bg-[var(--bg)] rounded-xl">
              <div class="w-10 h-10 bg-[var(--primary)] rounded-lg flex items-center justify-center opacity-80 shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  {c.label.toLowerCase().includes('email') ? (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  ) : c.label.toLowerCase().includes('phone') ? (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  ) : (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  )}
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-[var(--text)]">{c.label}</p>
                <p class="text-sm text-[var(--muted)]">{c.value}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>
