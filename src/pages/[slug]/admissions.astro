---
import { getThemeLayout } from '../../themes/index.js';
import { getDb } from '../../lib/db/index.js';
import { schools, contactInfo, contactSubmissions } from '../../lib/db/schema.js';
import { eq, asc } from 'drizzle-orm';

const slug = Astro.params.slug!;
const db = getDb();
const school = db.select().from(schools).where(eq(schools.slug, slug)).get();
if (!school) return Astro.redirect('/404');

const Layout = getThemeLayout(school.theme || 'harmony');

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const data: Record<string, string> = {};
  form.forEach((value, key) => { if (key !== 'formType') data[key] = value.toString(); });
  db.insert(contactSubmissions).values({
    schoolId: school.id,
    formType: 'admissions',
    data,
  }).run();
  return Astro.redirect(`/${slug}/admissions?success=1`);
}

const contacts = db.select().from(contactInfo)
  .where(eq(contactInfo.schoolId, school.id)).orderBy(asc(contactInfo.sortOrder)).all();

const admissionContacts = contacts.filter(c => c.type === 'admissions');
const generalContacts = contacts.filter(c => c.type === 'general');
const success = Astro.url.searchParams.get('success');
---

<Layout school={school} title="Admissions">
  <section class="py-16 bg-[var(--bg)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-[var(--text)]">Admissions</h1>
      <p class="mt-2 text-[var(--muted)]">Join the {school.name} family</p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2">
        {success && (
          <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">
            Thank you for your interest! Your application inquiry has been received. Our admissions team will contact you shortly.
          </div>
        )}

        <h2 class="text-xl font-semibold text-[var(--text)] mb-6">Admissions Inquiry</h2>
        <form method="POST" action={`/${slug}/admissions`} class="space-y-5 bg-[var(--surface)] rounded-xl border border-[var(--border)] p-8">
          <input type="hidden" name="formType" value="admissions" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="space-y-1">
              <label class="block text-sm font-medium text-[var(--text)]">Parent/Guardian Name *</label>
              <input type="text" name="parentName" required class="block w-full rounded-lg border border-[var(--border)] px-3 py-2.5 text-sm bg-[var(--surface)] text-[var(--text)] focus:border-[var(--primary)] focus:outline-none focus:ring-1 focus:ring-[var(--primary)]" />
            </div>
            <div class="space-y-1">
              <label class="block text-sm font-medium text-[var(--text)]">Email *</label>
              <input type="email" name="email" required class="block w-full rounded-lg border border-[var(--border)] px-3 py-2.5 text-sm bg-[var(--surface)] text-[var(--text)] focus:border-[var(--primary)] focus:outline-none focus:ring-1 focus:ring-[var(--primary)]" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="space-y-1">
              <label class="block text-sm font-medium text-[var(--text)]">Phone *</label>
              <input type="tel" name="phone" required class="block w-full rounded-lg border border-[var(--border)] px-3 py-2.5 text-sm bg-[var(--surface)] text-[var(--text)] focus:border-[var(--primary)] focus:outline-none focus:ring-1 focus:ring-[var(--primary)]" />
            </div>
            <div class="space-y-1">
              <label class="block text-sm font-medium text-[var(--text)]">Student Name *</label>
              <input type="text" name="studentName" required class="block w-full rounded-lg border border-[var(--border)] px-3 py-2.5 text-sm bg-[var(--surface)] text-[var(--text)] focus:border-[var(--primary)] focus:outline-none focus:ring-1 focus:ring-[var(--primary)]" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="space-y-1">
              <label class="block text-sm font-medium text-[var(--text)]">Grade Applying For *</label>
              <input type="text" name="grade" required class="block w-full rounded-lg border border-[var(--border)] px-3 py-2.5 text-sm bg-[var(--surface)] text-[var(--text)] focus:border-[var(--primary)] focus:outline-none focus:ring-1 focus:ring-[var(--primary)]" />
            </div>
            <div class="space-y-1">
              <label class="block text-sm font-medium text-[var(--text)]">Current School</label>
              <input type="text" name="currentSchool" class="block w-full rounded-lg border border-[var(--border)] px-3 py-2.5 text-sm bg-[var(--surface)] text-[var(--text)] focus:border-[var(--primary)] focus:outline-none focus:ring-1 focus:ring-[var(--primary)]" />
            </div>
          </div>

          <div class="space-y-1">
            <label class="block text-sm font-medium text-[var(--text)]">Additional Message</label>
            <textarea name="message" rows={4} class="block w-full rounded-lg border border-[var(--border)] px-3 py-2.5 text-sm bg-[var(--surface)] text-[var(--text)] focus:border-[var(--primary)] focus:outline-none focus:ring-1 focus:ring-[var(--primary)]" placeholder="Any specific questions or information you'd like to share..."></textarea>
          </div>

          <button type="submit" class="w-full px-6 py-3 text-sm font-medium text-white rounded-lg bg-[var(--primary)] hover:opacity-90 transition-opacity shadow-sm">
            Submit Inquiry
          </button>
        </form>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--text)] mb-6">Admissions Office</h2>
        <div class="space-y-4 mb-8">
          {admissionContacts.length > 0 ? admissionContacts.map(c => (
            <div class="p-4 bg-[var(--bg)] rounded-xl">
              <p class="text-sm font-medium text-[var(--text)]">{c.label}</p>
              <p class="text-sm text-[var(--muted)]">{c.value}</p>
            </div>
          )) : generalContacts.map(c => (
            <div class="p-4 bg-[var(--bg)] rounded-xl">
              <p class="text-sm font-medium text-[var(--text)]">{c.label}</p>
              <p class="text-sm text-[var(--muted)]">{c.value}</p>
            </div>
          ))}
        </div>

        <div class="bg-[var(--bg)] rounded-xl p-6">
          <h3 class="font-semibold text-[var(--text)] mb-3">How to Apply</h3>
          <ol class="space-y-3 text-sm text-[var(--muted)]">
            <li class="flex gap-3"><span class="text-[var(--primary)] font-bold">1.</span> Submit this inquiry form</li>
            <li class="flex gap-3"><span class="text-[var(--primary)] font-bold">2.</span> Our team will contact you</li>
            <li class="flex gap-3"><span class="text-[var(--primary)] font-bold">3.</span> Schedule a school tour</li>
            <li class="flex gap-3"><span class="text-[var(--primary)] font-bold">4.</span> Complete the application</li>
            <li class="flex gap-3"><span class="text-[var(--primary)] font-bold">5.</span> Receive admission decision</li>
          </ol>
        </div>
      </div>
    </div>
  </div>
</Layout>
