---
import { getThemeLayout } from '../../../themes/index.js';
import { getDb } from '../../../lib/db/index.js';
import { schools, programs } from '../../../lib/db/schema.js';
import { eq, and } from 'drizzle-orm';

const slug = Astro.params.slug!;
const programSlug = Astro.params.program!;
const db = getDb();
const school = db.select().from(schools).where(eq(schools.slug, slug)).get();
if (!school) return Astro.redirect('/404');

const Layout = getThemeLayout(school.theme || 'harmony');

const item = db.select().from(programs)
  .where(and(eq(programs.schoolId, school.id), eq(programs.slug, programSlug)))
  .get();
if (!item) return Astro.redirect(`/${slug}/programs`);
---

<Layout school={school} title={item.name}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <a href={`/${slug}/programs`} class="text-sm text-[var(--primary)] hover:underline mb-6 inline-block">&larr; Back to Programs</a>

    {item.imageUrl && (
      <img src={item.imageUrl} alt={item.name} class="w-full h-64 sm:h-80 object-cover rounded-xl mb-8" />
    )}

    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-[var(--text)] leading-tight">{item.name}</h1>
      <div class="flex flex-wrap gap-3 mt-4">
        {item.level && <span class="text-sm px-3 py-1 rounded-full font-medium" style="background:color-mix(in srgb, var(--primary) 12%, transparent);color:var(--primary)">{item.level}</span>}
        {item.duration && <span class="text-sm bg-[var(--bg)] px-3 py-1 rounded-full text-[var(--muted)]">{item.duration}</span>}
      </div>
    </header>

    {item.description && (
      <div class="mb-8">
        <p class="text-lg leading-relaxed text-[var(--muted)]">{item.description}</p>
      </div>
    )}

    {item.content && (
      <div class="prose max-w-none">
        {item.content.split('\n').map(para => para.trim()).filter(Boolean).map(para => (
          <p class="leading-relaxed mb-4 text-[var(--text)]">{para}</p>
        ))}
      </div>
    )}

    <div class="mt-10 p-6 bg-[var(--bg)] rounded-xl border border-[var(--border)] text-center">
      <p class="mb-4 text-[var(--muted)]">Interested in this program?</p>
      <a href={`/${slug}/admissions`} class="inline-flex items-center justify-center px-8 py-3 text-base font-semibold text-white bg-[var(--primary)] rounded-lg hover:opacity-90 transition-colors shadow-sm">
        Apply for Admission
      </a>
    </div>
  </article>
</Layout>
