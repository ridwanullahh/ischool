---
import { getThemeLayout } from '../../themes/index.js';
import { getDb } from '../../lib/db/index.js';
import { schools, aboutPages } from '../../lib/db/schema.js';
import { eq } from 'drizzle-orm';

const slug = Astro.params.slug!;
const db = getDb();
const school = db.select().from(schools).where(eq(schools.slug, slug)).get();
if (!school) return Astro.redirect('/404');

const Layout = getThemeLayout(school.theme || 'harmony');

const about = db.select().from(aboutPages).where(eq(aboutPages.schoolId, school.id)).get();
const features: Array<{ title: string; description: string }> = Array.isArray(about?.features) ? about!.features as any : [];
const stats: Array<{ label: string; value: string }> = Array.isArray(about?.stats) ? about!.stats as any : [];
---

<Layout school={school} title="About Us">
  <section class="py-16 bg-[var(--bg)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-[var(--text)] mb-4">About {school.name}</h1>
      {school.tagline && <p class="text-xl text-[var(--muted)]">{school.tagline}</p>}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">
    {about?.mission && (
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold text-[var(--text)] mb-4">Our Mission</h2>
        <p class="text-lg leading-relaxed text-[var(--muted)]">{about.mission}</p>
      </div>
    )}

    {about?.vision && (
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold text-[var(--text)] mb-4">Our Vision</h2>
        <p class="text-lg leading-relaxed text-[var(--muted)]">{about.vision}</p>
      </div>
    )}

    {about?.valueProposition && (
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold text-[var(--text)] mb-4">Why Choose Us</h2>
        <p class="text-lg leading-relaxed text-[var(--muted)]">{about.valueProposition}</p>
      </div>
    )}

    {features.length > 0 && (
      <div>
        <h2 class="text-2xl font-bold text-[var(--text)] mb-8">What Sets Us Apart</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {features.map(f => (
            <div class="p-6 bg-[var(--bg)] rounded-xl">
              <h3 class="font-semibold text-[var(--text)] mb-2">{f.title}</h3>
              <p class="text-[var(--muted)]">{f.description}</p>
            </div>
          ))}
        </div>
      </div>
    )}

    {stats.length > 0 && (
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 p-8 bg-[var(--primary)] rounded-2xl">
        {stats.map(s => (
          <div class="text-center">
            <p class="text-3xl font-bold text-white">{s.value}</p>
            <p class="text-sm text-white/80 mt-1">{s.label}</p>
          </div>
        ))}
      </div>
    )}
  </div>
</Layout>
